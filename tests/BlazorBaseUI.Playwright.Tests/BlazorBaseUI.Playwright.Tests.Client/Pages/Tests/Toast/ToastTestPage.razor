@page "/tests/toast/wasm"
@using BlazorBaseUI.Toast
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Toast Test Page (WASM)</PageTitle>

<style>
    .toast-viewport {
        position: fixed;
        right: 24px;
        bottom: 24px;
        display: grid;
        gap: 8px;
    }

    .toast-root {
        width: 280px;
        padding: 12px;
        border: 1px solid #999;
        background: white;
    }
</style>

<div data-testid="test-container" data-interactive="@RendererInfo.IsInteractive.ToString().ToLowerInvariant()">
    <button type="button" data-testid="before-toast" @onclick="() => beforeFocused = true">Before</button>
    <button type="button" data-testid="add-low" @onclick="AddLowToast">Add Low</button>
    <button type="button" data-testid="add-high" @onclick="AddHighToast">Add High</button>
    <button type="button" data-testid="add-three" @onclick="AddThreeToasts">Add Three</button>
    <button type="button" data-testid="add-disabled-action" @onclick="AddDisabledActionToast">Add Disabled Action</button>
    <button type="button" data-testid="add-promise" @onclick="AddPromiseToast">Add Promise</button>

    <ToastProvider Timeout="0" Limit="2" ToastManager="manager" Context="toast">
        <ToastViewport class="toast-viewport" data-testid="toast-viewport">
            @foreach (var item in toast.Toasts)
            {
                <ToastRoot Toast="item" class="toast-root" data-testid="@($"toast-{item.Id}")">
                    <ToastContent data-testid="@($"toast-content-{item.Id}")">
                        <ToastTitle Id="@($"title-{item.Id}")" />
                        <ToastDescription Id="@($"description-{item.Id}")" />
                        <ToastAction data-testid="@($"toast-action-{item.Id}")" />
                        <ToastClose data-testid="@($"toast-close-{item.Id}")">Close</ToastClose>
                    </ToastContent>
                </ToastRoot>
            }
        </ToastViewport>
    </ToastProvider>

    <button type="button" data-testid="after-toast">After</button>

    <div data-testid="closed-count">@closedCount</div>
    <div data-testid="removed-count">@removedCount</div>
    <div data-testid="action-count">@actionCount</div>
    <div data-testid="before-focused">@beforeFocused</div>
</div>

@code {
    private readonly ToastManager manager = new();
    private int closedCount;
    private int removedCount;
    private int actionCount;
    private bool beforeFocused;

    private void AddLowToast()
    {
        manager.Add(new ToastManagerAddOptions
        {
            Id = "low",
            Title = "Low",
            Description = "Low priority",
            Type = "info",
            Timeout = 0,
            OnCloseCallback = EventCallback.Factory.Create(this, () => closedCount++),
            OnRemoveCallback = EventCallback.Factory.Create(this, () => removedCount++)
        });
    }

    private void AddHighToast()
    {
        manager.Add(new ToastManagerAddOptions
        {
            Id = "high",
            Title = "High",
            Description = "High priority",
            Priority = ToastPriority.High,
            Type = "warning",
            Timeout = 0
        });
    }

    private void AddThreeToasts()
    {
        for (var index = 1; index <= 3; index++)
        {
            manager.Add(new ToastManagerAddOptions
            {
                Id = $"limit-{index}",
                Title = $"Limit {index}",
                Description = $"Toast {index}",
                Timeout = 0
            });
        }
    }

    private void AddDisabledActionToast()
    {
        manager.Add(new ToastManagerAddOptions
        {
            Id = "disabled-action",
            Title = "Disabled",
            Description = "Disabled action",
            Timeout = 0,
            ActionProps = new ToastActionOptions
            {
                Disabled = true,
                ChildContent = builder => builder.AddContent(0, "Disabled Action"),
                OnClick = EventCallback.Factory.Create<MouseEventArgs>(this, () => actionCount++)
            }
        });
    }

    private void AddPromiseToast()
    {
        _ = manager.Promise(ResolvePromiseAsync(), new ToastManagerPromiseOptions<int>
        {
            Loading = "Loading promise",
            Success = ToastPromiseOption<int>.From(value => new ToastManagerUpdateOptions
            {
                Description = $"Promise resolved {value}",
                Type = "success",
                Timeout = 0
            }),
            Error = "Promise failed"
        });
    }

    private static async Task<int> ResolvePromiseAsync()
    {
        await Task.Delay(150);
        return 7;
    }
}
