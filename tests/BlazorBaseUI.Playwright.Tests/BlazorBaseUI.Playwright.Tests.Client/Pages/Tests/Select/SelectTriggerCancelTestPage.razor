@page "/tests/select-trigger-cancel/wasm"
@using BlazorBaseUI.Select
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Select Trigger Cancel Test Page (WASM)</PageTitle>

<div data-testid="test-container" data-interactive="@RendererInfo.IsInteractive.ToString().ToLowerInvariant()">
    <SelectRoot TValue="string" Id="fruit-select">
        <SelectTrigger data-testid="select-trigger" style="width:120px;height:32px;padding:4px 8px;">
            <SelectValue TValue="string" Placeholder="Select a fruit..." />
        </SelectTrigger>
        <SelectPortal>
            <SelectPositioner data-testid="select-positioner">
                <SelectPopup data-testid="select-popup" style="padding:4px;min-width:120px;">
                    <SelectItem TValue="string" Value="@("apple")" Label="Apple" data-testid="select-item-apple">
                        <SelectItemText>Apple</SelectItemText>
                    </SelectItem>
                    <SelectItem TValue="string" Value="@("banana")" Label="Banana" data-testid="select-item-banana">
                        <SelectItemText>Banana</SelectItemText>
                    </SelectItem>
                </SelectPopup>
            </SelectPositioner>
        </SelectPortal>
    </SelectRoot>

    <input data-testid="outside-input" style="position:absolute;top:400px;left:400px;" />
</div>
