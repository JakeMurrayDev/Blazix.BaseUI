@page "/tests/toast/server"
@using Blazix.BaseUI.Toast
@using Microsoft.AspNetCore.Components.Web
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Toast Test Page (Server)</PageTitle>

<style>
    .toast-viewport {
        position: fixed;
        right: 24px;
        bottom: 24px;
        display: grid;
        gap: 8px;
    }

    .toast-root {
        width: 280px;
        padding: 12px;
        border: 1px solid #999;
        background: white;
    }
</style>

<div data-testid="test-container" data-interactive="@RendererInfo.IsInteractive.ToString().ToLowerInvariant()">
    <button type="button" data-testid="before-toast" @onclick="() => beforeFocused = true">Before</button>
    <button type="button" data-testid="add-low" @onclick="AddLowToast">Add Low</button>
    <button type="button" data-testid="add-high" @onclick="AddHighToast">Add High</button>
    <button type="button" data-testid="add-three" @onclick="AddThreeToasts">Add Three</button>
    <button type="button" data-testid="add-disabled-action" @onclick="AddDisabledActionToast">Add Disabled Action</button>
    <button type="button" data-testid="add-promise" @onclick="AddPromiseToast">Add Promise</button>
    <button type="button" data-testid="add-keyboard-action" @onclick="AddKeyboardActionToast">Add Keyboard Action</button>
    <button type="button" data-testid="add-keyboard-close" @onclick="AddKeyboardCloseToast">Add Keyboard Close</button>
    <button type="button" data-testid="add-ignore" @onclick="AddIgnoreToast">Add Ignore Target</button>
    <button type="button" data-testid="close-all" @onclick="() => manager.Close()">Close All</button>
    <button type="button" data-testid="limit-zero" @onclick="() => limit = 0">Limit Zero</button>
    <button type="button" data-testid="limit-two" @onclick="() => limit = 2">Limit Two</button>

    <ToastProvider Timeout="0" Limit="limit" ToastManager="manager" Context="toast">
        <ToastViewport class="toast-viewport" data-testid="toast-viewport">
            @foreach (var item in toast.Toasts)
            {
                <ToastRoot @key="item.Id" Toast="item" class="toast-root" data-testid="@($"toast-{item.Id}")">
                    <ToastContent data-testid="@($"toast-content-{item.Id}")">
                        <ToastTitle Id="@($"title-{item.Id}")" />
                        <ToastDescription Id="@($"description-{item.Id}")" />
                        @if (item.Id == "ignore")
                        {
                            <div data-testid="swipe-ignore" data-base-ui-swipe-ignore>Ignore drag</div>
                        }
                        <ToastAction data-testid="@($"toast-action-{item.Id}")"
                                     Render="@(item.Id == "keyboard-action" ? RenderNonNativeAction : null)" />
                        <ToastClose data-testid="@($"toast-close-{item.Id}")"
                                    NativeButton="@(item.Id != "keyboard-close")"
                                    Render="@(item.Id == "keyboard-close" ? RenderNonNativeClose : null)">Close</ToastClose>
                    </ToastContent>
                </ToastRoot>
            }
        </ToastViewport>
    </ToastProvider>

    <button type="button" data-testid="after-toast">After</button>

    <div data-testid="closed-count">@closedCount</div>
    <div data-testid="removed-count">@removedCount</div>
    <div data-testid="action-count">@actionCount</div>
    <div data-testid="before-focused">@beforeFocused</div>
</div>

@code {
    private readonly ToastManager manager = new();
    private int closedCount;
    private int removedCount;
    private int actionCount;
    private bool beforeFocused;
    private int limit = 2;

    private RenderFragment<RenderProps<ToastActionState>> RenderNonNativeAction => props => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddMultipleAttributes(1, props.Attributes);
        builder.AddElementReferenceCapture(2, element => props.ElementReferenceCallback?.Invoke(element));
        builder.AddContent(3, props.ChildContent);
        builder.CloseElement();
    };

    private RenderFragment<RenderProps<ToastCloseState>> RenderNonNativeClose => props => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddMultipleAttributes(1, props.Attributes);
        builder.AddElementReferenceCapture(2, element => props.ElementReferenceCallback?.Invoke(element));
        builder.AddContent(3, props.ChildContent);
        builder.CloseElement();
    };

    private void AddLowToast()
    {
        manager.Add(new ToastManagerAddOptions
        {
            Id = "low",
            Title = "Low",
            Description = "Low priority",
            Type = "info",
            Timeout = 0,
            OnCloseCallback = EventCallback.Factory.Create(this, () => closedCount++),
            OnRemoveCallback = EventCallback.Factory.Create(this, () => removedCount++)
        });
    }

    private void AddHighToast()
    {
        manager.Add(new ToastManagerAddOptions
        {
            Id = "high",
            Title = "High",
            Description = "High priority",
            Priority = ToastPriority.High,
            Type = "warning",
            Timeout = 0
        });
    }

    private void AddThreeToasts()
    {
        for (var index = 1; index <= 3; index++)
        {
            manager.Add(new ToastManagerAddOptions
            {
                Id = $"limit-{index}",
                Title = $"Limit {index}",
                Description = $"Toast {index}",
                Timeout = 0
            });
        }
    }

    private void AddDisabledActionToast()
    {
        manager.Add(new ToastManagerAddOptions
        {
            Id = "disabled-action",
            Title = "Disabled",
            Description = "Disabled action",
            Timeout = 0,
            ActionProps = new ToastActionOptions
            {
                Disabled = true,
                ChildContent = builder => builder.AddContent(0, "Disabled Action"),
                OnClick = EventCallback.Factory.Create<MouseEventArgs>(this, () => actionCount++)
            }
        });
    }

    private void AddPromiseToast()
    {
        _ = manager.Promise(ResolvePromiseAsync(), new ToastManagerPromiseOptions<int>
        {
            Loading = "Loading promise",
            Success = ToastPromiseOption<int>.From(value => new ToastManagerUpdateOptions
            {
                Description = $"Promise resolved {value}",
                Type = "success",
                Timeout = 0
            }),
            Error = "Promise failed"
        });
    }

    private void AddKeyboardActionToast()
    {
        manager.Add(new ToastManagerAddOptions
        {
            Id = "keyboard-action",
            Description = "Keyboard action",
            Timeout = 0,
            ActionProps = new ToastActionOptions
            {
                NativeButton = false,
                ChildContent = builder => builder.AddContent(0, "Run action"),
                OnClick = EventCallback.Factory.Create<MouseEventArgs>(this, () => actionCount++)
            }
        });
    }

    private void AddKeyboardCloseToast()
    {
        manager.Add(new ToastManagerAddOptions
        {
            Id = "keyboard-close",
            Description = "Keyboard close",
            Timeout = 0,
            OnCloseCallback = EventCallback.Factory.Create(this, () => closedCount++),
            OnRemoveCallback = EventCallback.Factory.Create(this, () => removedCount++)
        });
    }

    private void AddIgnoreToast()
    {
        manager.Add(new ToastManagerAddOptions
        {
            Id = "ignore",
            Description = "Ignore target",
            Timeout = 0,
            OnCloseCallback = EventCallback.Factory.Create(this, () => closedCount++)
        });
    }

    private static async Task<int> ResolvePromiseAsync()
    {
        await Task.Delay(150);
        return 7;
    }
}
