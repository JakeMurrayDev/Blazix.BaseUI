@page "/tests/select/wasm"
@using Blazix.BaseUI.Select
@using Blazix.BaseUI.Utilities.FloatingFocusManager
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Select Test Page (WASM)</PageTitle>

<div data-testid="test-container" data-interactive="@RendererInfo.IsInteractive.ToString().ToLowerInvariant()">
    <SelectRoot TValue="string"
        @bind-Open="isOpen"
        DefaultOpen="@DefaultOpen"
        DefaultValue="@DefaultValue"
        Disabled="@Disabled"
        Multiple="@Multiple"
        Modal="@(Modal ? SelectModalMode.True : SelectModalMode.False)"
        Name="@SelectName"
        OnOpenChange="HandleOpenChange"
        OnValueChange="HandleValueChange">
        <SelectTrigger data-testid="select-trigger">
            <SelectValue TValue="string" Placeholder="Select a fruit..." />
            <SelectIcon>
                <span>&#9662;</span>
            </SelectIcon>
        </SelectTrigger>
        <SelectPortal>
            <SelectPositioner data-testid="select-positioner">
                <SelectPopup data-testid="select-popup"
                             FinalFocus="ResolveFinalFocus()">
                    @if (ShowGroups)
                    {
                        <SelectScrollUpArrow KeepMounted="true" data-testid="select-scroll-up" style="height: 24px;">&#9650;</SelectScrollUpArrow>
                        <SelectList data-testid="select-list" style="max-height: 128px; overflow-y: auto;">
                            <SelectGroup style="contain: layout;">
                                <SelectGroupLabel>Fruits</SelectGroupLabel>
                                @foreach (var item in Fruits)
                                {
                                    <SelectItem TValue="string" Value="@item.Value" Label="@item.Label" data-testid="@($"select-item-{item.Value}")" style="height: 32px;">
                                        <SelectItemText>@item.Label</SelectItemText>
                                        <SelectItemIndicator KeepMounted="true">&#10003;</SelectItemIndicator>
                                    </SelectItem>
                                }
                            </SelectGroup>
                            <SelectGroup style="contain: layout;">
                                <SelectGroupLabel>Vegetables</SelectGroupLabel>
                                @foreach (var item in Vegetables)
                                {
                                    <SelectItem TValue="string" Value="@item.Value" Label="@item.Label" data-testid="@($"select-item-{item.Value}")" style="height: 32px;">
                                        <SelectItemText>@item.Label</SelectItemText>
                                        <SelectItemIndicator KeepMounted="true">&#10003;</SelectItemIndicator>
                                    </SelectItem>
                                }
                            </SelectGroup>
                            <SelectGroup style="contain: layout;">
                                <SelectGroupLabel>Herbs</SelectGroupLabel>
                                @foreach (var item in Herbs)
                                {
                                    <SelectItem TValue="string" Value="@item.Value" Label="@item.Label" data-testid="@($"select-item-{item.Value}")" style="height: 32px;">
                                        <SelectItemText>@item.Label</SelectItemText>
                                        <SelectItemIndicator KeepMounted="true">&#10003;</SelectItemIndicator>
                                    </SelectItem>
                                }
                            </SelectGroup>
                        </SelectList>
                        <SelectScrollDownArrow KeepMounted="true" data-testid="select-scroll-down" style="height: 24px;">&#9660;</SelectScrollDownArrow>
                    }
                    else
                    {
                        <SelectItem TValue="string" Value="@("apple")" Label="Apple" data-testid="select-item-apple">
                            <SelectItemText>Apple</SelectItemText>
                            <SelectItemIndicator KeepMounted="true">&#10003;</SelectItemIndicator>
                        </SelectItem>
                        <SelectItem TValue="string" Value="@("banana")" Label="Banana" data-testid="select-item-banana">
                            <SelectItemText>Banana</SelectItemText>
                            <SelectItemIndicator KeepMounted="true">&#10003;</SelectItemIndicator>
                        </SelectItem>
                        <SelectItem TValue="string" Value="@("cherry")" Label="Cherry" data-testid="select-item-cherry">
                            <SelectItemText>Cherry</SelectItemText>
                            <SelectItemIndicator KeepMounted="true">&#10003;</SelectItemIndicator>
                        </SelectItem>
                        <SelectItem TValue="string" Value="@("disabled-item")" Label="Disabled" Disabled="true" data-testid="select-item-disabled">
                            <SelectItemText>Disabled Item</SelectItemText>
                        </SelectItem>
                        <SelectItem TValue="string" Value="@("date")" Label="Date" data-testid="select-item-date">
                            <SelectItemText>Date</SelectItemText>
                            <SelectItemIndicator KeepMounted="true">&#10003;</SelectItemIndicator>
                        </SelectItem>
                    }
                </SelectPopup>
            </SelectPositioner>
        </SelectPortal>
    </SelectRoot>

    <button @ref="finalFocusTarget" data-testid="select-final-focus-target" style="margin-top: 10px;">Final Focus Target</button>

    <div data-testid="state-display" style="margin-top: 20px; padding: 10px; border: 1px solid #ccc;">
        <div>Open: <span data-testid="open-state">@isOpen.ToString().ToLowerInvariant()</span></div>
        <div>Change Count: <span data-testid="change-count">@changeCount</span></div>
        <div>Last Reason: <span data-testid="last-reason">@lastReason</span></div>
        <div>Last Final Focus Type: <span data-testid="last-final-focus-type">@lastFinalFocusType</span></div>
        <div>Selected Value: <span data-testid="selected-value">@selectedValue</span></div>
        <div>Value Change Count: <span data-testid="value-change-count">@valueChangeCount</span></div>
    </div>

    <button data-testid="outside-button" style="margin-top: 10px;">Outside Button</button>
    <button data-testid="external-open-button" @onclick="ToggleExternalOpen" style="margin-top: 10px;">
        Toggle Open Externally
    </button>
</div>

@code {
    private static readonly (string Value, string Label)[] Fruits =
    [
        ("apple", "Apple"), ("banana", "Banana"), ("cherry", "Cherry"),
        ("grape", "Grape"), ("orange", "Orange"), ("pear", "Pear")
    ];
    private static readonly (string Value, string Label)[] Vegetables =
    [
        ("carrot", "Carrot"), ("celery", "Celery"), ("corn", "Corn"),
        ("pepper", "Pepper"), ("potato", "Potato"), ("tomato", "Tomato")
    ];
    private static readonly (string Value, string Label)[] Herbs =
    [
        ("basil", "Basil"), ("dill", "Dill"), ("mint", "Mint"), ("thyme", "Thyme")
    ];

    [SupplyParameterFromQuery(Name = "defaultOpen")]
    public bool DefaultOpen { get; set; }

    [SupplyParameterFromQuery(Name = "defaultValue")]
    public string? DefaultValue { get; set; }

    [SupplyParameterFromQuery(Name = "disabled")]
    public bool Disabled { get; set; }

    [SupplyParameterFromQuery(Name = "multiple")]
    public bool Multiple { get; set; }

    [SupplyParameterFromQuery(Name = "modal")]
    public bool Modal { get; set; }

    [SupplyParameterFromQuery(Name = "selectName")]
    public string? SelectName { get; set; }

    [SupplyParameterFromQuery(Name = "showGroups")]
    public bool ShowGroups { get; set; }

    [SupplyParameterFromQuery(Name = "useFinalFocus")]
    public bool UseFinalFocus { get; set; }

    [SupplyParameterFromQuery(Name = "finalFocusMode")]
    public string? FinalFocusMode { get; set; }

    private bool isOpen;
    private int changeCount;
    private string lastReason = "";
    private string lastFinalFocusType = "";
    private string selectedValue = "";
    private int valueChangeCount;
    private ElementReference finalFocusTarget;

    protected override void OnInitialized()
    {
        isOpen = DefaultOpen;
        selectedValue = DefaultValue ?? "";
    }

    private void HandleOpenChange(SelectOpenChangeEventArgs args)
    {
        changeCount++;
        lastReason = args.Reason.ToString();
    }

    private void HandleValueChange(SelectValueChangeEventArgs<string> args)
    {
        valueChangeCount++;
        selectedValue = args.Value ?? "";
    }

    private void ToggleExternalOpen() => isOpen = !isOpen;

    private FinalFocusTarget? ResolveFinalFocus()
    {
        if (!UseFinalFocus)
        {
            return null;
        }

        return FinalFocusTarget.From(closeType =>
        {
            lastFinalFocusType = closeType.ToString();
            return FinalFocusMode switch
            {
                "mouse-target" => closeType == InteractionType.Mouse
                    ? FinalFocusResult.To(finalFocusTarget)
                    : FinalFocusResult.Default,
                "touch-target" => closeType == InteractionType.Touch
                    ? FinalFocusResult.To(finalFocusTarget)
                    : FinalFocusResult.Default,
                "pen-target" => closeType == InteractionType.Pen
                    ? FinalFocusResult.To(finalFocusTarget)
                    : FinalFocusResult.Default,
                _ => closeType == InteractionType.Keyboard
                    ? FinalFocusResult.Default
                    : FinalFocusResult.To(finalFocusTarget)
            };
        });
    }
}
