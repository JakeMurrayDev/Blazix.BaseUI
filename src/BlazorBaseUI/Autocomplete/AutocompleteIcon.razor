@implements IDisposable

<RenderElement TState="AutocompleteIconState"
               Tag="span"
               State="state"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="@(ChildContent ?? DefaultChildContent)"
               @attributes="AdditionalAttributes" />

@code {
    private AutocompleteIconState state;
    private Dictionary<string, object> componentAttributes = new();
    private bool subscribed;

    private static RenderFragment DefaultChildContent => builder => builder.AddContent(0, "▼");

    [CascadingParameter]
    private IAutocompleteRootContext? RootContext { get; set; }

    /// <summary>
    /// Allows replacing or composing the rendered element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<AutocompleteIconState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on component state.
    /// </summary>
    [Parameter]
    public Func<AutocompleteIconState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on component state.
    /// </summary>
    [Parameter]
    public Func<AutocompleteIconState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets additional element attributes.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (RootContext is not null)
        {
            RootContext.StateChanged += OnRootStateChanged;
            subscribed = true;
        }

        BuildStateAndAttributes();
    }

    /// <inheritdoc />
    public void Dispose()
    {
        if (subscribed && RootContext is not null)
        {
            RootContext.StateChanged -= OnRootStateChanged;
        }
    }

    private void OnRootStateChanged()
    {
        BuildStateAndAttributes();
        InvokeAsync(StateHasChanged);
    }

    private void BuildStateAndAttributes()
    {
        state = new AutocompleteIconState(RootContext?.Mounted == true);
        componentAttributes = new Dictionary<string, object>
        {
            ["aria-hidden"] = "true"
        };
    }
}
