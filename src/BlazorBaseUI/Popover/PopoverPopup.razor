@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using BlazorBaseUI.Toolbar
@using BlazorBaseUI.FloatingFocusManager
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="PopoverPopupState"
               Tag="div"
               Enabled="RootContext is not null"
               State="state"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference">
    <FloatingFocusManager Modal="@isModal"
                          Disabled="@(!isMounted || openedByHover)"
                          InitialFocus="@ComputeInitialFocus()"
                          ReturnFocus="@ComputeReturnFocus()"
                          FinalFocus="@ComputeFinalFocusTarget()"
                          InteractionType="@(RootContext?.InteractionType)"
                          RestoreFocus="true"
                          RestoreFocusMode="popup"
                          PreviousFocusableElement="@(RootContext?.GetTriggerElement())"
                          NextFocusableElement="@(RootContext?.GetTriggerFocusTarget())">
        @ChildContent
    </FloatingFocusManager>
</RenderElement>

@code {
    private readonly string popupId = Guid.NewGuid().ToIdString();
    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private bool hasRendered;
    private bool isModal;
    private bool isMounted;
    private bool openedByHover;
    private PopoverPopupState state;
    private RenderElement<PopoverPopupState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private ElementReference? previousElement;
    private FocusTarget? previousInitialFocus;
    private FocusTarget? previousFinalFocus;
    private bool deferredInitialFocusApplied;
    private DotNetObjectReference<PopoverPopup>? dotNetRef;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-popover.min.js").AsTask());

    [CascadingParameter]
    private PopoverRootContext? RootContext { get; set; }

    [CascadingParameter]
    private PopoverPositionerContext? PositionerContext { get; set; }

    [CascadingParameter]
    private ToolbarRootContext? ToolbarContext { get; set; }

    /// <summary>
    /// Gets or sets a custom render template for the popup element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<PopoverPopupState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the focus target when the popover is opened.
    /// Accepts <see cref="FocusTarget.None"/>, <see cref="FocusTarget.Default"/>,
    /// <see cref="FocusTarget.Element"/>, or <see cref="FocusTarget.Callback"/>.
    /// An <see cref="ElementReference"/> is implicitly converted to <see cref="FocusTarget.Element"/>.
    /// </summary>
    [Parameter]
    public FocusTarget? InitialFocus { get; set; }

    /// <summary>
    /// Gets or sets the focus target when the popover is closed.
    /// Accepts <see cref="FocusTarget.None"/>, <see cref="FocusTarget.Default"/>,
    /// <see cref="FocusTarget.Element"/>, or <see cref="FocusTarget.Callback"/>.
    /// An <see cref="ElementReference"/> is implicitly converted to <see cref="FocusTarget.Element"/>.
    /// </summary>
    [Parameter]
    public FocusTarget? FinalFocus { get; set; }

    /// <summary>
    /// Gets or sets a function that returns CSS class names based on the current state.
    /// </summary>
    [Parameter]
    public Func<PopoverPopupState, string>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns inline styles based on the current state.
    /// </summary>
    [Parameter]
    public Func<PopoverPopupState, string>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var open = RootContext?.GetOpen() ?? false;
        var side = PositionerContext?.Side ?? Side.Bottom;
        var align = PositionerContext?.Align ?? Align.Center;
        var instant = RootContext?.PopoverInstantType ?? PopoverInstantType.None;
        var transitionStatus = RootContext?.TransitionStatus ?? TransitionStatus.Undefined;

        isModal = RootContext?.Modal is not PopoverModalMode.False && (RootContext?.HasClosePart ?? false);
        isMounted = RootContext?.GetMounted() ?? false;
        openedByHover = RootContext?.PopoverOpenChangeReason == PopoverOpenChangeReason.TriggerHover;

        if (RootContext is not null)
        {
            RootContext.PopupId = popupId;
            RootContext.FocusManagerModal = isModal;
        }

        if (!open)
        {
            deferredInitialFocusApplied = false;
        }

        state = new PopoverPopupState(open, side, align, instant, transitionStatus);
        BuildComponentAttributes();

        if (hasRendered && RootContext is not null)
        {
            if (!Equals(InitialFocus, previousInitialFocus))
            {
                previousInitialFocus = InitialFocus;
                var (mode, element) = ResolveFocusTarget(InitialFocus);
                _ = SetInitialFocusElementAsync(mode, element);
            }

            if (!Equals(FinalFocus, previousFinalFocus))
            {
                previousFinalFocus = FinalFocus;
                var (mode, element) = ResolveFocusTarget(FinalFocus);
                _ = SetFinalFocusElementAsync(mode, element);
            }
        }
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            dotNetRef = DotNetObjectReference.Create(this);
        }

        var currentElement = Element;
        if (!Nullable.Equals(previousElement, currentElement))
        {
            previousElement = currentElement;
            RootContext?.SetPopupElement(currentElement);
        }

        if (firstRender)
        {
            await InitializePopupAsync();
            previousInitialFocus = InitialFocus;
            previousFinalFocus = FinalFocus;
        }

        if (!firstRender && RootContext?.GetOpen() == true && !deferredInitialFocusApplied && InitialFocus is not null)
        {
            var (mode, element) = ResolveFocusTarget(InitialFocus);
            await SetInitialFocusElementAsync(mode, element);
            deferredInitialFocusApplied = true;
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        attrs["id"] = popupId;
        attrs["role"] = "dialog";
        attrs["tabindex"] = -1;
        // lint-ignore:RULE-05 lint-ignore:RULE-06 React Base UI parity marker.
        attrs["data-base-ui-focusable"] = "";

        var titleId = RootContext?.TitleId;
        if (!string.IsNullOrEmpty(titleId))
        {
            attrs["aria-labelledby"] = titleId;
        }

        var descriptionId = RootContext?.DescriptionId;
        if (!string.IsNullOrEmpty(descriptionId))
        {
            attrs["aria-describedby"] = descriptionId;
        }

        var side = PositionerContext?.Side ?? Side.Bottom;
        var align = PositionerContext?.Align ?? Align.Center;
        attrs["data-side"] = side.ToDataAttributeString()!;
        attrs["data-align"] = align.ToDataAttributeString()!;

        var isOpen = RootContext?.GetOpen() ?? false;
        attrs["data-open"] = isOpen;
        attrs["data-closed"] = !isOpen;

        var instantType = RootContext?.PopoverInstantType ?? PopoverInstantType.None;
        var instantAttr = instantType.ToDataAttributeString();
        if (!string.IsNullOrEmpty(instantAttr))
        {
            attrs["data-instant"] = instantAttr;
        }

        var transitionStatus = RootContext?.TransitionStatus ?? TransitionStatus.Undefined;
        TransitionAttributeHelper.ApplyTransitionStyleAttributes(attrs, transitionStatus);

        if (transitionStatus == TransitionStatus.Starting)
        {
            attrs["style"] = "transition: none";
        }

        attrs["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleKeyDownAsync);

        componentAttributes = attrs;
    }

    private async Task InitializePopupAsync()
    {
        if (!Element.HasValue || RootContext is null)
        {
            return;
        }

        try
        {
            var module = await ModuleTask.Value;
            var modalString = RootContext.Modal switch
            {
                PopoverModalMode.True => "true",
                PopoverModalMode.TrapFocus => "trap-focus",
                _ => "false"
            };
            var (initialMode, initialElement) = ResolveFocusTarget(InitialFocus);
            var (finalMode, finalElement) = ResolveFocusTarget(FinalFocus);
            await module.InvokeVoidAsync("initializePopup",
                RootContext.RootId, Element.Value, dotNetRef, modalString,
                initialMode, initialElement, finalMode, finalElement,
                ToolbarContext is not null);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private (string? Mode, ElementReference? Element) ResolveFocusTarget(FocusTarget? target)
    {
        return target switch
        {
            null => (null, null),
            FocusTarget.None => ("none", null),
            FocusTarget.Default => ("default", null),
            FocusTarget.Element e => ("element", e.Ref),
            FocusTarget.Callback cb => ResolveFocusCallback(cb),
            _ => (null, null)
        };
    }

    private (string? Mode, ElementReference? Element) ResolveFocusCallback(FocusTarget.Callback cb)
    {
        var interactionType = RootContext?.InteractionType ?? "";
        var result = cb.Fn(interactionType);
        return result.HasValue ? ("element", result.Value) : ("none", null);
    }

    private async Task SetInitialFocusElementAsync(string? mode, ElementReference? element)
    {
        if (RootContext is null)
        {
            return;
        }

        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("setInitialFocusElement", RootContext.RootId, mode, element);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task SetFinalFocusElementAsync(string? mode, ElementReference? element)
    {
        if (RootContext is null)
        {
            return;
        }

        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("setFinalFocusElement", RootContext.RootId, mode, element);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private bool ComputeInitialFocus()
    {
        if (InitialFocus is FocusTarget.None) return false;
        if (InitialFocus is FocusTarget.Element or FocusTarget.Callback) return false;
        return true;
    }

    private bool ComputeReturnFocus()
    {
        if (FinalFocus is FocusTarget.None) return false;
        return true;
    }

    private FinalFocusTarget? ComputeFinalFocusTarget()
    {
        return FinalFocus switch
        {
            null => (FinalFocusTarget?)null,
            FocusTarget.Default => FinalFocusTarget.Default,
            FocusTarget.None => FinalFocusTarget.None,
            FocusTarget.Element e => FinalFocusTarget.From(e.Ref),
            FocusTarget.Callback cb => FinalFocusTarget.From(interactionType =>
            {
                var result = cb.Fn(interactionType.ToString().ToLowerInvariant());
                return result.HasValue ? FinalFocusResult.To(result.Value) : FinalFocusResult.None;
            }),
            _ => (FinalFocusTarget?)null
        };
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        await EventUtilities.InvokeOnKeyDownAsync(AdditionalAttributes, e);
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (moduleTask?.IsValueCreated == true && hasRendered && Element.HasValue)
        {
            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("disposePopup", RootContext?.RootId, Element.Value);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        dotNetRef?.Dispose();
    }
}
