@namespace BlazorBaseUI.Csp

<CascadingValue TValue="CspProviderContext" Value="context" IsFixed="false">
    @ChildContent
</CascadingValue>

@code {
    private CspProviderContext context = new(null, false);

    /// <summary>
    /// Gets or sets the nonce applied to runtime style elements.
    /// </summary>
    [Parameter]
    public string? Nonce { get; set; }

    /// <summary>
    /// Determines whether components should skip injecting runtime style elements.
    /// </summary>
    [Parameter]
    public bool DisableStyleElements { get; set; }

    /// <summary>
    /// Defines the child content receiving the CSP context.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        context = new CspProviderContext(Nonce, DisableStyleElements);
    }
}
