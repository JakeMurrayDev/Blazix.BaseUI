@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

@if (RootContext is not null && Store is not null)
{
    <RenderElement TState="ToastCloseState"
                   Tag="button"
                   State="state"
                   Render="Render"
                   ClassValue="ClassValue"
                   StyleValue="StyleValue"
                   ComponentAttributes="componentAttributes"
                   ChildContent="ChildContent"
                   @attributes="AdditionalAttributes"
                   @ref="renderElementReference" />
}

@code {
    private const string JsModulePath = "./_content/Blazix.BaseUI/blazix-baseui-button.min.js";

    private readonly Lazy<Task<IJSObjectReference>> moduleTask;
    private ToastCloseState state = new(null);
    private RenderElement<ToastCloseState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private bool hasFocus;
    private bool hasRendered;
    private bool previousDisabled;
    private bool previousNativeButton = true;
    private ElementReference? previousElement;

    [CascadingParameter]
    private ToastStore? Store { get; set; }

    [CascadingParameter]
    private ToastRootContext? RootContext { get; set; }

    /// <summary>
    /// Determines whether the close button is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether the component renders native button attributes.
    /// </summary>
    [Parameter]
    public bool NativeButton { get; set; } = true;

    /// <summary>
    /// Gets or sets a custom render template for the close element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<ToastCloseState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets a function that returns CSS class names based on the current state.
    /// </summary>
    [Parameter]
    public Func<ToastCloseState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns inline styles based on the current state.
    /// </summary>
    [Parameter]
    public Func<ToastCloseState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    public ToastClose()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(() =>
            JSRuntime.InvokeAsync<IJSObjectReference>("import", JsModulePath).AsTask());
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        state = new ToastCloseState(RootContext?.Toast.Type);
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!Element.HasValue)
        {
            return;
        }

        var elementChanged = !Nullable.Equals(previousElement, Element);
        if (firstRender || elementChanged || Disabled != previousDisabled || NativeButton != previousNativeButton)
        {
            var previousNeedsJs = !previousNativeButton || previousDisabled;
            hasRendered = true;
            previousElement = Element;
            previousDisabled = Disabled;
            previousNativeButton = NativeButton;

            if (!NativeButton || Disabled)
            {
                await SyncJsAsync(dispose: false);
            }
            else if (previousNeedsJs)
            {
                await SyncJsAsync(dispose: true);
            }
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (hasRendered && moduleTask.IsValueCreated && Element.HasValue)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.InvokeVoidAsync("sync", Element.Value, false, false, false, true);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
            {
                _ = ex;
            }
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        if (NativeButton)
        {
            AccessibilityUtilities.ApplyNativeButtonAttributes(attrs, Disabled, false, 0);
        }
        else
        {
            AccessibilityUtilities.ApplyButtonAttributes(attrs, Disabled, false, 0);
        }

        attrs["aria-hidden"] = (!(Store?.Expanded ?? false) && !hasFocus).ToString().ToLowerInvariant();
        attrs["data-type"] = state.Type ?? string.Empty;
        attrs["onclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleClickAsync);
        attrs["onfocus"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleFocusAsync);
        attrs["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleBlurAsync);

        if (string.IsNullOrWhiteSpace(state.Type))
        {
            attrs.Remove("data-type");
        }

        componentAttributes = attrs;
    }

    private async Task HandleClickAsync(MouseEventArgs e)
    {
        if (Disabled)
        {
            return;
        }

        Store?.CloseToast(RootContext?.Toast.Id);
        await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
    }

    private async Task HandleFocusAsync(FocusEventArgs e)
    {
        hasFocus = true;
        BuildComponentAttributes();
        await EventUtilities.InvokeOnFocusAsync(AdditionalAttributes, e);
    }

    private async Task HandleBlurAsync(FocusEventArgs e)
    {
        hasFocus = false;
        BuildComponentAttributes();
        await EventUtilities.InvokeOnBlurAsync(AdditionalAttributes, e);
    }

    private async Task SyncJsAsync(bool dispose)
    {
        if (!Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("sync", Element.Value, Disabled, false, NativeButton, dispose);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex;
        }
    }
}
