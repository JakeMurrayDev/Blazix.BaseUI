@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

@if (Store is not null)
{
    <CascadingValue Value="positionerContext">
        <RenderElement TState="ToastPositionerState"
                       Tag="div"
                       State="state"
                       Render="Render"
                       ClassValue="ClassValue"
                       StyleValue="ResolvedStyleValue"
                       ComponentAttributes="componentAttributes"
                       ChildContent="ChildContent"
                       @attributes="AdditionalAttributes"
                       @ref="renderElementReference" />
    </CascadingValue>
}

@code {
    private static readonly string[] PositionerParameterNames =
    [
        nameof(Anchor), nameof(Side), nameof(Align), nameof(SideOffset), nameof(AlignOffset),
        nameof(CollisionBoundary), nameof(CollisionPadding), nameof(CollisionPaddingPerSide),
        nameof(ArrowPadding), nameof(Sticky), nameof(DisableAnchorTracking), nameof(PositionMethod),
        nameof(CollisionAvoidance)
    ];

    private PositionerInterop positionerInterop = null!;
    private DotNetObjectReference<ToastPositioner>? positionerDotNetRef;
    private ToastPositionerState state = new(Side.Top, Align.Center, false);
    private ToastPositionerContext positionerContext = null!;
    private RenderElement<ToastPositionerState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private readonly HashSet<string> suppliedParameters = new(StringComparer.Ordinal);
    private ElementReference? previousElement;
    private ElementReference? previousAnchor;
    private ElementReference? previousArrowElement;
    private bool previousDisableAnchorTracking;
    private string? previousOptionsKey;
    private Side computedSide;
    private Align computedAlign;
    private bool computedAnchorHidden;
    private bool computedArrowUncentered;

    [CascadingParameter]
    private ToastStore? Store { get; set; }

    /// <summary>
    /// Gets or sets the toast object associated with the positioner.
    /// </summary>
    [Parameter, EditorRequired]
    public ToastObject Toast { get; set; } = null!;

    /// <summary>
    /// Gets or sets a custom render template for the positioner element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<ToastPositionerState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets an element to position the toast against.
    /// </summary>
    [Parameter]
    public ElementReference? Anchor { get; set; }

    /// <summary>
    /// Gets or sets the side of the anchor element to position against.
    /// </summary>
    [Parameter]
    public Side Side { get; set; } = Side.Top;

    /// <summary>
    /// Gets or sets the alignment of the toast relative to the specified side.
    /// </summary>
    [Parameter]
    public Align Align { get; set; } = Align.Center;

    /// <summary>
    /// Gets or sets the offset in pixels from the side of the anchor element.
    /// </summary>
    [Parameter]
    public double SideOffset { get; set; }

    /// <summary>
    /// Gets or sets the offset in pixels from the alignment edge of the anchor element.
    /// </summary>
    [Parameter]
    public double AlignOffset { get; set; }

    /// <summary>
    /// Gets or sets the collision boundary.
    /// </summary>
    [Parameter]
    public CollisionBoundary CollisionBoundary { get; set; } = CollisionBoundary.ClippingAncestors;

    /// <summary>
    /// Gets or sets the collision padding.
    /// </summary>
    [Parameter]
    public double CollisionPadding { get; set; } = 5;

    /// <summary>
    /// Gets or sets per-side collision padding.
    /// </summary>
    [Parameter]
    public SidePadding? CollisionPaddingPerSide { get; set; }

    /// <summary>
    /// Gets or sets the arrow padding.
    /// </summary>
    [Parameter]
    public double ArrowPadding { get; set; } = 5;

    /// <summary>
    /// Determines whether the toast stays attached to the anchor while overflowing.
    /// </summary>
    [Parameter]
    public bool Sticky { get; set; }

    /// <summary>
    /// Determines whether anchor tracking updates are disabled.
    /// </summary>
    [Parameter]
    public bool DisableAnchorTracking { get; set; }

    /// <summary>
    /// Gets or sets the CSS positioning method.
    /// </summary>
    [Parameter]
    public PositionMethod PositionMethod { get; set; } = PositionMethod.Absolute;

    /// <summary>
    /// Gets or sets the collision avoidance behavior.
    /// </summary>
    [Parameter]
    public CollisionAvoidance? CollisionAvoidance { get; set; }

    /// <summary>
    /// Gets or sets a function that returns CSS class names based on the current state.
    /// </summary>
    [Parameter]
    public Func<ToastPositionerState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns inline styles based on the current state.
    /// </summary>
    [Parameter]
    public Func<ToastPositionerState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    private Func<ToastPositionerState, string?>? ResolvedStyleValue =>
        s =>
        {
            var index = Store?.GetToastIndex(Toast.Id) ?? -1;
            var visibleIndex = Store?.GetToastVisibleIndex(Toast.Id) ?? -1;
            var cssIndex = Toast.TransitionStatus == TransitionStatus.Ending ? index : visibleIndex;
            var parts = new List<string> { $"--toast-index: {cssIndex}" };
            var userStyle = StyleValue?.Invoke(s);
            if (!string.IsNullOrWhiteSpace(userStyle))
            {
                parts.Add(userStyle);
            }

            return string.Join("; ", parts);
        };

    /// <inheritdoc />
    public override async Task SetParametersAsync(ParameterView parameters)
    {
        suppliedParameters.Clear();
        foreach (var parameter in parameters)
        {
            if (PositionerParameterNames.Contains(parameter.Name, StringComparer.Ordinal))
            {
                suppliedParameters.Add(parameter.Name);
            }
        }

        await base.SetParametersAsync(parameters);
    }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        positionerInterop = new PositionerInterop(JSRuntime, "./_content/Blazix.BaseUI/blazix-baseui-toast.min.js");
        computedSide = ResolvedOptions.Side;
        computedAlign = ResolvedOptions.Align;

        positionerContext = new ToastPositionerContext
        {
            Side = computedSide,
            Align = computedAlign,
            AnchorHidden = false,
            ArrowUncentered = false,
            SetArrowElement = SetArrowElement
        };
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        computedSide = ResolvedOptions.Side;
        computedAlign = ResolvedOptions.Align;
        state = new ToastPositionerState(computedSide, computedAlign, computedAnchorHidden);

        positionerContext.Side = computedSide;
        positionerContext.Align = computedAlign;
        positionerContext.AnchorHidden = computedAnchorHidden;
        positionerContext.ArrowUncentered = computedArrowUncentered;

        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            positionerInterop.MarkRendered();
            positionerDotNetRef = DotNetObjectReference.Create(this);
        }

        var options = ResolvedOptions;
        var currentElement = Element;
        var elementChanged = !Nullable.Equals(previousElement, currentElement);
        var anchor = options.Anchor;
        if (positionerInterop.IsInitialized &&
            (!anchor.HasValue || elementChanged || previousDisableAnchorTracking != options.DisableAnchorTracking))
        {
            await positionerInterop.ResetAsync();
        }

        previousElement = currentElement;
        previousDisableAnchorTracking = options.DisableAnchorTracking;

        if (positionerInterop.HasRendered && Element.HasValue && anchor.HasValue)
        {
            if (!positionerInterop.IsInitialized)
            {
                await InitializePositionerAsync();
                previousAnchor = anchor;
                previousArrowElement = positionerContext.ArrowElement;
                previousOptionsKey = GetOptionsKey(options);
            }
            else if (!Nullable.Equals(previousAnchor, anchor) ||
                     !Nullable.Equals(previousArrowElement, positionerContext.ArrowElement) ||
                     !string.Equals(previousOptionsKey, GetOptionsKey(options), StringComparison.Ordinal))
            {
                await UpdatePositionAsync();
                previousAnchor = anchor;
                previousArrowElement = positionerContext.ArrowElement;
                previousOptionsKey = GetOptionsKey(options);
            }
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        try
        {
            await positionerInterop.DisposeAsync();
        }
        finally
        {
            positionerDotNetRef?.Dispose();
        }
    }

    [JSInvokable]
    public void OnPositionUpdated(string side, string align, bool anchorHidden, bool arrowUncentered)
    {
        var physicalSide = Blazix.BaseUI.Extensions.ParseSide(side);
        var newAlign = Blazix.BaseUI.Extensions.ParseAlign(align);

        if (physicalSide == computedSide &&
            newAlign == computedAlign &&
            anchorHidden == computedAnchorHidden &&
            arrowUncentered == computedArrowUncentered)
        {
            return;
        }

        computedSide = physicalSide;
        computedAlign = newAlign;
        computedAnchorHidden = anchorHidden;
        computedArrowUncentered = arrowUncentered;

        positionerContext.Side = computedSide;
        positionerContext.Align = computedAlign;
        positionerContext.AnchorHidden = computedAnchorHidden;
        positionerContext.ArrowUncentered = computedArrowUncentered;

        state = new ToastPositionerState(computedSide, computedAlign, computedAnchorHidden);
        BuildComponentAttributes();
        StateHasChanged();
    }

    private ToastPositionerOptions ResolvedOptions
    {
        get
        {
            var manager = Toast.PositionerProps;
            return new ToastPositionerOptions
            {
                Anchor = Resolve(nameof(Anchor), Anchor, manager is null ? Anchor : manager.Anchor, manager),
                Side = Resolve(nameof(Side), Side, manager is null ? Side : manager.Side, manager),
                Align = Resolve(nameof(Align), Align, manager is null ? Align : manager.Align, manager),
                SideOffset = Resolve(nameof(SideOffset), SideOffset, manager is null ? SideOffset : manager.SideOffset, manager),
                AlignOffset = Resolve(nameof(AlignOffset), AlignOffset, manager is null ? AlignOffset : manager.AlignOffset, manager),
                CollisionBoundary = Resolve(nameof(CollisionBoundary), CollisionBoundary, manager is null ? CollisionBoundary : manager.CollisionBoundary, manager),
                CollisionPadding = Resolve(nameof(CollisionPadding), CollisionPadding, manager is null ? CollisionPadding : manager.CollisionPadding, manager),
                CollisionPaddingPerSide = Resolve(nameof(CollisionPaddingPerSide), CollisionPaddingPerSide, manager is null ? CollisionPaddingPerSide : manager.CollisionPaddingPerSide, manager),
                ArrowPadding = Resolve(nameof(ArrowPadding), ArrowPadding, manager is null ? ArrowPadding : manager.ArrowPadding, manager),
                Sticky = Resolve(nameof(Sticky), Sticky, manager is null ? Sticky : manager.Sticky, manager),
                DisableAnchorTracking = Resolve(nameof(DisableAnchorTracking), DisableAnchorTracking, manager is null ? DisableAnchorTracking : manager.DisableAnchorTracking, manager),
                PositionMethod = Resolve(nameof(PositionMethod), PositionMethod, manager is null ? PositionMethod : manager.PositionMethod, manager),
                CollisionAvoidance = Resolve(nameof(CollisionAvoidance), CollisionAvoidance, manager is null ? CollisionAvoidance : manager.CollisionAvoidance, manager)
            };
        }
    }

    private void BuildComponentAttributes()
    {
        componentAttributes = new Dictionary<string, object>
        {
            ["role"] = "presentation",
            ["data-blazix-base-ui-positioner"] = true,
            ["data-side"] = computedSide.ToDataAttributeString()!,
            ["data-align"] = computedAlign.ToDataAttributeString()!,
            ["data-anchor-hidden"] = computedAnchorHidden
        };
    }

    private void SetArrowElement(ElementReference? element)
    {
        if (Nullable.Equals(positionerContext.ArrowElement, element))
        {
            return;
        }

        positionerContext.ArrowElement = element;

        if (positionerInterop.HasRendered && positionerInterop.IsInitialized)
        {
            _ = UpdatePositionAsync();
        }
    }

    private object GetCollisionPaddingArg(ToastPositionerOptions options) =>
        options.CollisionPaddingPerSide is not null
            ? new { top = options.CollisionPaddingPerSide.Top, right = options.CollisionPaddingPerSide.Right, bottom = options.CollisionPaddingPerSide.Bottom, left = options.CollisionPaddingPerSide.Left }
            : (object)options.CollisionPadding;

    private string GetOptionsKey(ToastPositionerOptions options)
    {
        var collisionPadding = options.CollisionPaddingPerSide is null
            ? options.CollisionPadding.ToString(System.Globalization.CultureInfo.InvariantCulture)
            : $"{options.CollisionPaddingPerSide.Top},{options.CollisionPaddingPerSide.Right},{options.CollisionPaddingPerSide.Bottom},{options.CollisionPaddingPerSide.Left}";
        var collisionAvoidance = options.CollisionAvoidance ?? new CollisionAvoidance();
        return string.Join('|',
            options.Side, options.Align, options.SideOffset, options.AlignOffset, collisionPadding,
            options.CollisionBoundary, options.ArrowPadding, options.Sticky, options.DisableAnchorTracking,
            options.PositionMethod, collisionAvoidance.Side, collisionAvoidance.Align,
            collisionAvoidance.FallbackAxisSide);
    }

    private async Task InitializePositionerAsync()
    {
        var options = ResolvedOptions;
        var anchor = options.Anchor;
        if (!Element.HasValue || !anchor.HasValue)
        {
            return;
        }

        try
        {
            var module = await positionerInterop.GetModuleAsync();
            var ca = options.CollisionAvoidance ?? new CollisionAvoidance();
            positionerInterop.SetPositionerId(await module.InvokeAsync<string>(
                "initializePositioner",
                Element.Value,
                anchor.Value,
                options.Side.ToDataAttributeString(),
                options.Align.ToDataAttributeString(),
                options.SideOffset,
                options.AlignOffset,
                GetCollisionPaddingArg(options),
                options.CollisionBoundary.ToDataAttributeString(),
                options.ArrowPadding,
                positionerContext.ArrowElement,
                options.Sticky,
                options.PositionMethod == PositionMethod.Fixed ? "fixed" : "absolute",
                options.DisableAnchorTracking,
                ca.Side.ToJsString(),
                ca.Align.ToJsString(),
                ca.FallbackAxisSide.ToJsString(),
                positionerDotNetRef));
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex;
        }
    }

    private async Task UpdatePositionAsync()
    {
        var options = ResolvedOptions;
        var anchor = options.Anchor;
        if (!positionerInterop.IsInitialized || !anchor.HasValue)
        {
            return;
        }

        try
        {
            var module = await positionerInterop.GetModuleAsync();
            var ca = options.CollisionAvoidance ?? new CollisionAvoidance();
            await module.InvokeVoidAsync(
                "updatePosition",
                positionerInterop.PositionerId,
                anchor.Value,
                options.Side.ToDataAttributeString(),
                options.Align.ToDataAttributeString(),
                options.SideOffset,
                options.AlignOffset,
                GetCollisionPaddingArg(options),
                options.CollisionBoundary.ToDataAttributeString(),
                options.ArrowPadding,
                positionerContext.ArrowElement,
                options.Sticky,
                options.PositionMethod == PositionMethod.Fixed ? "fixed" : "absolute",
                ca.Side.ToJsString(),
                ca.Align.ToJsString(),
                ca.FallbackAxisSide.ToJsString());
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex;
        }
    }

    private T Resolve<T>(string propertyName, T directValue, T managerValue, ToastPositionerOptions? manager)
    {
        if (suppliedParameters.Contains(propertyName))
        {
            return directValue;
        }

        if (manager is not null && manager.Has(propertyName))
        {
            return managerValue!;
        }

        return directValue;
    }
}
