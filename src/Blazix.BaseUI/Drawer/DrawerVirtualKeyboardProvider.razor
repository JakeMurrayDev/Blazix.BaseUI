@using Microsoft.JSInterop

@implements IAsyncDisposable

@inject IJSRuntime JSRuntime

<CascadingValue TValue="DrawerVirtualKeyboardContext" Value="context" IsFixed="true">
    @ChildContent
</CascadingValue>

@code {
    private const string ModulePath = "./_content/Blazix.BaseUI/blazix-baseui-drawer.min.js";

    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private bool initialized;
    private DrawerVirtualKeyboardContext context = null!;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>("import", ModulePath).AsTask());

    [CascadingParameter]
    private DrawerRootContext? DrawerContext { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (DrawerContext is null)
        {
            throw new InvalidOperationException("DrawerVirtualKeyboardProvider must be used within a DrawerRoot.");
        }

        context = new DrawerVirtualKeyboardContext { RootId = DrawerContext.RootId };
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || DrawerContext is null)
        {
            return;
        }

        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("initializeVirtualKeyboardProvider", DrawerContext.RootId);
            initialized = true;
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex;
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (moduleTask?.IsValueCreated != true)
        {
            return;
        }

        try
        {
            var module = await ModuleTask.Value;
            try
            {
                if (initialized && DrawerContext is not null)
                {
                    await module.InvokeVoidAsync("disposeVirtualKeyboardProvider", DrawerContext.RootId);
                }
            }
            finally
            {
                await module.DisposeAsync();
            }
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex;
        }
    }
}
