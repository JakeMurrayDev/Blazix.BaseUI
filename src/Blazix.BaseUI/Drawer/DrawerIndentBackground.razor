@using Microsoft.JSInterop

@implements IAsyncDisposable

@inject IJSRuntime JSRuntime

<RenderElement TState="DrawerIndentBackgroundState"
               Tag="div"
               State="state"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string ModulePath = "./_content/Blazix.BaseUI/blazix-baseui-drawer.min.js";

    private readonly string indentId = Guid.NewGuid().ToIdString();

    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private DrawerIndentBackgroundState state;
    private RenderElement<DrawerIndentBackgroundState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private ElementReference? previousElement;
    private ElementReference? elementForDisposal;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>("import", ModulePath).AsTask());

    [CascadingParameter]
    private DrawerProviderContext? ProviderContext { get; set; }

    /// <summary>
    /// Gets or sets a custom render fragment that replaces the default element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<DrawerIndentBackgroundState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets a function that returns a CSS class based on the component's state.
    /// </summary>
    [Parameter]
    public Func<DrawerIndentBackgroundState, string>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns an inline style based on the component's state.
    /// </summary>
    [Parameter]
    public Func<DrawerIndentBackgroundState, string>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (ProviderContext is not null)
        {
            ProviderContext.StateChanged += OnProviderStateChanged;
        }

        state = new DrawerIndentBackgroundState(ProviderContext?.Active ?? false);
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        state = new DrawerIndentBackgroundState(ProviderContext?.Active ?? false);
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var currentElement = Element;
        if (!Nullable.Equals(previousElement, currentElement))
        {
            previousElement = currentElement;
            if (currentElement.HasValue)
            {
                elementForDisposal = currentElement;
                await RegisterIndentAsync(currentElement.Value);
            }
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (ProviderContext is not null)
        {
            ProviderContext.StateChanged -= OnProviderStateChanged;
        }

        if (moduleTask?.IsValueCreated != true)
        {
            return;
        }

        try
        {
            var module = await ModuleTask.Value;
            try
            {
                if (elementForDisposal.HasValue)
                {
                    await module.InvokeVoidAsync(
                        "unregisterIndent",
                        ProviderContext?.ProviderId,
                        indentId,
                        elementForDisposal.Value);
                }
            }
            finally
            {
                await module.DisposeAsync();
            }
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex;
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        if (ProviderContext?.Active == true)
        {
            attrs["data-active"] = true;
        }
        else
        {
            attrs["data-inactive"] = true;
        }

        componentAttributes = attrs;
    }

    private void OnProviderStateChanged()
    {
        _ = InvokeAsync(() =>
        {
            state = new DrawerIndentBackgroundState(ProviderContext?.Active ?? false);
            BuildComponentAttributes();
            StateHasChanged();
        });
    }

    private async Task RegisterIndentAsync(ElementReference element)
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("registerIndent", ProviderContext?.ProviderId, indentId, element);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex;
        }
    }
}
