@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@using Blazix.BaseUI.Toolbar
@using Blazix.BaseUI.ToggleGroup

@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject ILogger<Toggle> Logger

<RenderElement TState="ToggleState"
               Tag="@DefaultTag"
               State="state"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="forwardedAdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string DefaultTag = "button";
    private const string JsModulePath = "./_content/Blazix.BaseUI/blazix-baseui-toggle.min.js";

    private readonly Lazy<Task<IJSObjectReference>> moduleTask;
    private readonly string itemId = Guid.NewGuid().ToIdString();

    private bool hasRendered;
    private bool isDisposed;
    private bool isPressed;
    private bool previousPressed;
    private bool previousDisabled;
    private Orientation previousOrientation;
    private Direction previousDirection;
    private bool hasValueParameter;
    private bool isRegisteredWithContext;
    private bool hasLoggedMissingGroupValue;
    private string previousResolvedValue = null!;
    private string? defaultId;
    private string resolvedValue = null!;
    private RenderElement<ToggleState>? renderElementReference;
    private IToggleGroupContext? registeredGroupContext;
    private ElementReference? registeredGroupElement;
    private ElementReference? registeredGroupToggleElement;
    private ElementReference? registeredToolbarElement;
    private ToolbarRootContext? registeredToolbarContext;
    private ElementReference? initializedGroupItemElement;
    private ToggleState state = ToggleState.Default;
    private Dictionary<string, object> componentAttributes = new();
    private IReadOnlyDictionary<string, object>? forwardedAdditionalAttributes;

    private bool IsControlled => Pressed.HasValue;
    private bool IsInGroup => GroupContext is not null;
    private bool IsInToolbarGroup => GroupContext?.IsInToolbar == true && ToolbarContext is not null;

    private bool CurrentPressed
    {
        get
        {
            if (IsInGroup)
                return GroupContext!.Value.Contains(resolvedValue);

            return IsControlled ? Pressed!.Value : isPressed;
        }
    }

    private bool ResolvedDisabled => Disabled || (GroupContext?.Disabled ?? false);

    private Orientation CurrentOrientation => GroupContext?.Orientation ?? Orientation.Horizontal;

    private Direction CurrentDirection => GroupContext?.Direction ?? Direction.Ltr;

    [CascadingParameter]
    private IToggleGroupContext? GroupContext { get; set; }

    [CascadingParameter]
    private ToolbarRootContext? ToolbarContext { get; set; }

    /// <summary>
    /// Gets or sets whether the toggle button is currently pressed.
    /// This is the controlled counterpart of <see cref="DefaultPressed"/>.
    /// </summary>
    [Parameter]
    public bool? Pressed { get; set; }

    /// <summary>
    /// Gets or sets whether the toggle button is initially pressed.
    /// This is the uncontrolled counterpart of <see cref="Pressed"/>.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool DefaultPressed { get; set; }

    /// <summary>
    /// Determines whether the component should ignore user interaction.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether the component renders a native <c>&lt;button&gt;</c> element
    /// when replacing it via the <see cref="Render"/> prop.
    /// Set to <see langword="false"/> if the rendered element is not a button (e.g. <c>&lt;div&gt;</c>).
    /// Defaults to <see langword="true"/>.
    /// </summary>
    [Parameter]
    public bool NativeButton { get; set; } = true;

    /// <summary>
    /// Gets or sets a unique string that identifies the toggle when used inside a <see cref="ToggleGroup.ToggleGroup"/>.
    /// </summary>
    [Parameter]
    public string? Value { get; set; }

    /// <summary>
    /// Gets or sets a callback that is invoked when the pressed state changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> PressedChanged { get; set; }

    /// <summary>
    /// Gets or sets a cancellable callback that is invoked when the pressed state changes.
    /// </summary>
    [Parameter]
    public EventCallback<TogglePressedChangeEventArgs> OnPressedChange { get; set; }

    /// <summary>
    /// Gets or sets a custom render fragment that replaces the default element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<ToggleState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets a function that returns a CSS class based on the component's state.
    /// </summary>
    [Parameter]
    public Func<ToggleState, string>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns an inline style based on the component's state.
    /// </summary>
    [Parameter]
    public Func<ToggleState, string>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    public Toggle()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(() =>
            JSRuntime.InvokeAsync<IJSObjectReference>("import", JsModulePath).AsTask());
    }

    /// <inheritdoc />
    public override async Task SetParametersAsync(ParameterView parameters)
    {
        hasValueParameter = false;

        foreach (var parameter in parameters)
        {
            if (parameter.Name == nameof(Value))
            {
                hasValueParameter = true;
                break;
            }
        }

        await base.SetParametersAsync(parameters);
    }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        resolvedValue = ResolveValue();
        previousResolvedValue = resolvedValue;

        if (!IsInGroup && !IsControlled)
        {
            isPressed = DefaultPressed;
        }

        previousPressed = CurrentPressed;
        previousDisabled = ResolvedDisabled;
        previousOrientation = CurrentOrientation;
        previousDirection = CurrentDirection;

        state = new ToggleState(CurrentPressed, ResolvedDisabled);
        RegisterWithContext();
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var newValue = ResolveValue();
        if (newValue != resolvedValue)
        {
            resolvedValue = newValue;
        }

        var currentPressed = CurrentPressed;
        var resolvedDisabled = ResolvedDisabled;
        var currentDirection = CurrentDirection;

        RegisterWithContext();

        if (!IsInToolbarGroup)
        {
            UnregisterFromToolbar();
        }

        if (state.Pressed != currentPressed || state.Disabled != resolvedDisabled)
        {
            state = new ToggleState(currentPressed, resolvedDisabled);
        }

        if (hasRendered && !isDisposed)
        {
            if (previousPressed != currentPressed)
            {
                previousPressed = currentPressed;
            }

            if (resolvedDisabled != previousDisabled)
            {
                previousDisabled = resolvedDisabled;
                _ = UpdateJsStateAsync();
            }

            if (IsInGroup && !IsInToolbarGroup && CurrentOrientation != previousOrientation)
            {
                previousOrientation = CurrentOrientation;
                _ = UpdateGroupItemOrientationAsync();
            }

            if (IsInGroup && !IsInToolbarGroup && currentDirection != previousDirection)
            {
                previousDirection = currentDirection;
                _ = UpdateGroupTabIndexesAsync();
            }
        }

        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (isDisposed)
        {
            return;
        }

        if (firstRender)
        {
            hasRendered = true;

            if (IsInGroup && Element.HasValue)
            {
                if (IsInToolbarGroup)
                {
                    RegisterWithToolbar();
                }
                else
                {
                    await InitializeGroupItemAsync();
                    await RegisterWithGroupAsync();
                    await UpdateGroupTabIndexesAsync();
                }
            }

            if (!NativeButton)
            {
                await InitializeJsAsync();
            }
        }
        else if (!IsInGroup || IsInToolbarGroup)
        {
            await UnregisterFromGroupAsync();
            await DisposeGroupItemAsync();
        }
        else if (IsInGroup && !IsInToolbarGroup && Element.HasValue)
        {
            await InitializeGroupItemAsync();

            if (ShouldRegisterWithGroup())
            {
                await RegisterWithGroupAsync();
            }

            await UpdateGroupTabIndexesAsync();
        }

        if (isDisposed)
        {
            return;
        }

        if (!firstRender && IsInToolbarGroup)
        {
            RegisterWithToolbar();
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (isDisposed)
        {
            return;
        }

        isDisposed = true;
        UnregisterFromGroupContext();
        UnregisterFromToolbar();

        if (moduleTask.IsValueCreated)
        {
            try
            {
                await UnregisterFromGroupAsync();
                await DisposeGroupItemAsync();
                var module = await moduleTask.Value;

                if (!NativeButton && Element.HasValue)
                {
                    await module.InvokeVoidAsync("dispose", Element.Value);
                }

                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();
        var currentPressed = CurrentPressed;
        var resolvedDisabled = ResolvedDisabled;

        attrs["aria-pressed"] = currentPressed ? "true" : "false";

        if (NativeButton)
        {
            attrs["type"] = "button";

            if (IsInGroup)
            {
                attrs["aria-disabled"] = resolvedDisabled ? "true" : "false";
            }

            if (resolvedDisabled)
            {
                attrs["disabled"] = true;
            }
            else if (IsInGroup)
            {
                attrs["tabindex"] = IsInToolbarGroup ? 0 : GroupContext!.GetTabIndex(itemId);
            }
            else
            {
                attrs["tabindex"] = 0;
            }
        }
        else
        {
            attrs["role"] = "button";

            if (resolvedDisabled)
            {
                attrs["aria-disabled"] = "true";
                attrs["tabindex"] = -1;
            }
            else if (IsInGroup)
            {
                attrs["tabindex"] = IsInToolbarGroup ? 0 : GroupContext!.GetTabIndex(itemId);
            }
            else
            {
                attrs["tabindex"] = 0;
            }
        }

        attrs["onclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleClickAsync);

        if (IsInGroup && !IsInToolbarGroup)
        {
            attrs["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleKeyDownAsync);
        }

        if (currentPressed)
        {
            attrs["data-pressed"] = true;
        }

        if (resolvedDisabled)
        {
            attrs["data-disabled"] = true;
        }

        componentAttributes = attrs;
        forwardedAdditionalAttributes = BuildForwardedAdditionalAttributes();
    }

    private async Task RegisterWithGroupAsync()
    {
        if (isDisposed)
        {
            return;
        }

        if (!IsInGroup || !Element.HasValue || !GroupContext!.GroupElement.HasValue)
        {
            await UnregisterFromGroupAsync();
            return;
        }

        var groupElement = GroupContext.GroupElement.Value;
        var toggleElement = Element.Value;

        if (registeredGroupElement.HasValue != registeredGroupToggleElement.HasValue ||
            (registeredGroupElement.HasValue &&
             registeredGroupToggleElement.HasValue &&
             (!registeredGroupElement.Value.Equals(groupElement) ||
              !registeredGroupToggleElement.Value.Equals(toggleElement))))
        {
            await UnregisterFromGroupAsync();
        }

        try
        {
            var module = await moduleTask.Value;

            if (isDisposed)
            {
                return;
            }

            await module.InvokeVoidAsync("registerToggle", groupElement, toggleElement, resolvedValue);
            registeredGroupElement = groupElement;
            registeredGroupToggleElement = toggleElement;
            previousResolvedValue = resolvedValue;
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private bool ShouldRegisterWithGroup()
    {
        var groupElement = GroupContext?.GroupElement;

        if (!Element.HasValue || !groupElement.HasValue)
        {
            return false;
        }

        return !registeredGroupElement.HasValue ||
               !registeredGroupToggleElement.HasValue ||
               !registeredGroupElement.Value.Equals(groupElement.Value) ||
               !registeredGroupToggleElement.Value.Equals(Element.Value) ||
               resolvedValue != previousResolvedValue;
    }

    private void RegisterWithToolbar()
    {
        if (isDisposed || !Element.HasValue || ToolbarContext is null)
        {
            return;
        }

        if (registeredToolbarElement.HasValue &&
            (!registeredToolbarElement.Value.Equals(Element.Value) ||
             registeredToolbarContext is null ||
             !ReferenceEquals(registeredToolbarContext, ToolbarContext)))
        {
            UnregisterFromToolbar();
        }

        if (!registeredToolbarElement.HasValue || !registeredToolbarElement.Value.Equals(Element.Value))
        {
            ToolbarContext.RegisterItem(Element.Value);
            registeredToolbarElement = Element;
            registeredToolbarContext = ToolbarContext;
        }
    }

    private void UnregisterFromToolbar()
    {
        if (registeredToolbarElement.HasValue && registeredToolbarContext is not null)
        {
            registeredToolbarContext.UnregisterItem(registeredToolbarElement.Value);
        }

        registeredToolbarElement = null;
        registeredToolbarContext = null;
    }

    private async Task UpdateGroupTabIndexesAsync()
    {
        if (isDisposed || !hasRendered || !IsInGroup || !Element.HasValue || !GroupContext!.GroupElement.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;

            if (isDisposed)
            {
                return;
            }

            await module.InvokeVoidAsync("syncGroupTabIndexes", GroupContext.GroupElement.Value);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task UnregisterFromGroupAsync()
    {
        if (!registeredGroupElement.HasValue || !registeredGroupToggleElement.HasValue)
        {
            registeredGroupElement = null;
            registeredGroupToggleElement = null;
            return;
        }

        var groupElement = registeredGroupElement.Value;
        var toggleElement = registeredGroupToggleElement.Value;

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("unregisterToggle", groupElement, toggleElement);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }

        registeredGroupElement = null;
        registeredGroupToggleElement = null;
    }

    private async Task InitializeJsAsync()
    {
        if (isDisposed || !Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;

            if (isDisposed)
            {
                return;
            }

            await module.InvokeVoidAsync("initialize", Element.Value, ResolvedDisabled);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task InitializeGroupItemAsync()
    {
        if (isDisposed)
        {
            return;
        }

        if (!Element.HasValue)
        {
            await DisposeGroupItemAsync();
            return;
        }

        if (initializedGroupItemElement.HasValue && initializedGroupItemElement.Value.Equals(Element.Value))
        {
            return;
        }

        await DisposeGroupItemAsync();

        try
        {
            var module = await moduleTask.Value;

            if (isDisposed)
            {
                return;
            }

            var orientationString = CurrentOrientation.ToDataAttributeString() ?? "horizontal";
            await module.InvokeVoidAsync("initializeGroupItem", Element.Value, orientationString);
            initializedGroupItemElement = Element;
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task DisposeGroupItemAsync()
    {
        if (!initializedGroupItemElement.HasValue)
        {
            return;
        }

        var groupItemElement = initializedGroupItemElement.Value;

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("disposeGroupItem", groupItemElement);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }

        initializedGroupItemElement = null;
    }

    private async Task UpdateJsStateAsync()
    {
        if (isDisposed || !hasRendered || NativeButton || !Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;

            if (isDisposed)
            {
                return;
            }

            await module.InvokeVoidAsync("updateState", Element.Value, ResolvedDisabled);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task UpdateGroupItemOrientationAsync()
    {
        if (isDisposed || !hasRendered || !IsInGroup || !Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;

            if (isDisposed)
            {
                return;
            }

            var orientationString = CurrentOrientation.ToDataAttributeString() ?? "horizontal";
            await module.InvokeVoidAsync("updateGroupItemOrientation", Element.Value, orientationString);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task HandleClickAsync(MouseEventArgs e)
    {
        if (ResolvedDisabled)
        {
            return;
        }

        var nextPressed = !CurrentPressed;

        if (IsInGroup)
        {
            var groupEventArgs = await GroupContext!.SetGroupValueAsync(resolvedValue, nextPressed, e);
            var toggleEventArgs = new TogglePressedChangeEventArgs(
                nextPressed,
                e,
                groupEventArgs.IsCanceled,
                groupEventArgs.IsPropagationAllowed);

            if (OnPressedChange.HasDelegate)
            {
                await OnPressedChange.InvokeAsync(toggleEventArgs);
            }

            if (!toggleEventArgs.IsCanceled && PressedChanged.HasDelegate)
            {
                await PressedChanged.InvokeAsync(nextPressed);
            }

            await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
            return;
        }

        var eventArgs = new TogglePressedChangeEventArgs(
            nextPressed,
            e,
            isCanceled: false,
            isPropagationAllowed: false);

        if (OnPressedChange.HasDelegate)
        {
            await OnPressedChange.InvokeAsync(eventArgs);

            if (eventArgs.IsCanceled)
            {
                return;
            }
        }

        if (!IsControlled)
        {
            isPressed = nextPressed;
            state = new ToggleState(isPressed, ResolvedDisabled);
        }

        if (PressedChanged.HasDelegate)
        {
            await PressedChanged.InvokeAsync(nextPressed);
        }

        await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
        BuildComponentAttributes();
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (isDisposed || !IsInGroup || ResolvedDisabled || !GroupContext!.GroupElement.HasValue || !Element.HasValue)
        {
            return;
        }

        var orientation = GroupContext.Orientation;
        var isHorizontal = orientation == Orientation.Horizontal;
        var isVertical = orientation == Orientation.Vertical;
        var isRtl = GroupContext.Direction == Direction.Rtl;

        var shouldNavigatePrevious =
            (isHorizontal && e.Key == (isRtl ? "ArrowRight" : "ArrowLeft")) ||
            (isVertical && e.Key == "ArrowUp");

        var shouldNavigateNext =
            (isHorizontal && e.Key == (isRtl ? "ArrowLeft" : "ArrowRight")) ||
            (isVertical && e.Key == "ArrowDown");

        try
        {
            var module = await moduleTask.Value;

            if (isDisposed)
            {
                return;
            }

            if (shouldNavigatePrevious)
            {
                await module.InvokeVoidAsync("navigateToPrevious", GroupContext.GroupElement.Value, Element.Value);
            }
            else if (shouldNavigateNext)
            {
                await module.InvokeVoidAsync("navigateToNext", GroupContext.GroupElement.Value, Element.Value);
            }
            else if (e.Key == "Home")
            {
                await module.InvokeVoidAsync("navigateToFirst", GroupContext.GroupElement.Value);
            }
            else if (e.Key == "End")
            {
                await module.InvokeVoidAsync("navigateToLast", GroupContext.GroupElement.Value);
            }
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }

        await EventUtilities.InvokeOnKeyDownAsync(AdditionalAttributes, e);
    }

    private string ResolveValue()
    {
        if (!string.IsNullOrEmpty(Value))
        {
            return Value;
        }

        return defaultId ??= Guid.NewGuid().ToIdString();
    }

    private void RegisterWithContext()
    {
        if (!IsInGroup)
        {
            UnregisterFromGroupContext();
            return;
        }

        if (!hasValueParameter && GroupContext!.IsValueInitialized && !hasLoggedMissingGroupValue)
        {
            Logger.LogError(
                "A <Toggle> component rendered in a <ToggleGroup> has no explicit value prop. This will cause issues between the Toggle Group and Toggle values. Provide the <Toggle> with a value prop matching the <ToggleGroup> values prop type.");
            hasLoggedMissingGroupValue = true;
        }

        if (isRegisteredWithContext &&
            (registeredGroupContext is null || !ReferenceEquals(registeredGroupContext, GroupContext)))
        {
            UnregisterFromGroupContext();
        }

        if (!isRegisteredWithContext)
        {
            GroupContext!.RegisterItem(itemId, ResolvedDisabled);
            registeredGroupContext = GroupContext;
            isRegisteredWithContext = true;
        }
        else
        {
            registeredGroupContext!.UpdateItem(itemId, ResolvedDisabled);
        }
    }

    private void UnregisterFromGroupContext()
    {
        if (isRegisteredWithContext && registeredGroupContext is not null)
        {
            registeredGroupContext.UnregisterItem(itemId);
        }

        registeredGroupContext = null;
        isRegisteredWithContext = false;
    }

    private IReadOnlyDictionary<string, object>? BuildForwardedAdditionalAttributes()
    {
        if (AdditionalAttributes is null)
        {
            return null;
        }

        if (!AdditionalAttributes.Any(attribute =>
                string.Equals(attribute.Key, "form", StringComparison.OrdinalIgnoreCase)))
        {
            return AdditionalAttributes;
        }

        var attrs = new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase);
        foreach (var (key, value) in AdditionalAttributes)
        {
            if (!string.Equals(key, "form", StringComparison.OrdinalIgnoreCase))
            {
                attrs[key] = value;
            }
        }

        return attrs;
    }
}
