@typeparam TValue
@using Blazix.BaseUI.Field
@using Blazix.BaseUI.Form
@using Blazix.BaseUI.Utilities
@using Blazix.BaseUI.Utilities.LabelableProvider
@using Microsoft.JSInterop

@implements IAsyncDisposable
@implements IFieldStateSubscriber
@inject IJSRuntime JSRuntime

<CascadingValue TValue="IAutocompleteRootContext" Value="context" IsFixed="true">
    <CascadingValue TValue="AutocompleteRootContext<TValue>" Value="typedContext" IsFixed="true">
        @ChildContent
    </CascadingValue>
</CascadingValue>

@{
    var hiddenInputName = typedContext.InputOwnsFormValue ? null : ResolvedName;
    var hiddenInputId = hiddenInputName is null ? $"{rootId}-hidden-input" : null;
    var describedBy = LabelableContext?.GetAriaDescribedBy();
}

<input style="border:0;clip:rect(0 0 0 0);height:1px;margin:-1px;overflow:hidden;padding:0;position:absolute;white-space:nowrap;width:1px"
       tabindex="-1"
       aria-hidden="true"
       id="@hiddenInputId"
       name="@hiddenInputName"
       form="@Form"
       autocomplete="@AutoComplete"
       value="@CurrentTypedInputValue"
       disabled="@ResolvedDisabled"
       required="@Required"
       readonly="@ReadOnly"
       aria-invalid="@(FieldState.Valid == false ? "true" : null)"
       aria-describedby="@(string.IsNullOrEmpty(describedBy) ? null : describedBy)"
       @ref="hiddenInputElement"
       @onfocus="HandleHiddenInputFocus"
       @onchange="HandleHiddenInputChange" />

@code {
    private const string ModulePath = "./_content/Blazix.BaseUI/blazix-baseui-autocomplete.min.js";

    private string rootId = null!;
    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private bool hasRendered;
    private bool isOpen;
    private int activeIndex = -1;
    private int highlightedValueIndex = -1;
    private string internalValue = string.Empty;
    private string inlineInputValue = string.Empty;
    private ElementReference hiddenInputElement;
    private ElementReference? previousHiddenInputElement;
    private readonly TransitionLifecycleManager transition = new();
    private AutocompleteRootState state;
    private AutocompleteRootContext<TValue> typedContext = null!;
    private IAutocompleteRootContext context = null!;
    private DotNetObjectReference<AutocompleteRoot<TValue>>? dotNetRef;
    private bool hasValueParameter;
    private bool hasHighlightedValue;
    private TValue? highlightedValue;
    private AutocompleteRootActions? previousActionsRef;
    private AutocompleteChangeReason openChangeReason = AutocompleteChangeReason.None;
    private string? autoHighlightSignature;

    private Task<IJSObjectReference> ModuleTask => (moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>("import", ModulePath).AsTask())).Value;

    private bool IsOpenControlled => Open.HasValue;

    private bool CurrentOpen => IsOpenControlled ? Open!.Value : isOpen;

    private bool IsValueControlled => hasValueParameter;

    private bool EnableInline => Mode is AutocompleteMode.Inline or AutocompleteMode.Both;

    private string CurrentTypedInputValue => IsValueControlled ? Value ?? string.Empty : internalValue;

    private string CurrentInputValue => EnableInline && inlineInputValue.Length > 0
        ? inlineInputValue
        : CurrentTypedInputValue;

    private bool ResolvedDisabled => Disabled || (FieldContext?.Disabled ?? false);

    private string? ResolvedName => Name ?? FieldContext?.Name;

    private FieldRootState FieldState => FieldContext?.State ?? FieldRootState.Default;

    /// <summary>
    /// Gets or sets the current input value. Use when controlled.
    /// </summary>
    [Parameter]
    public string? Value { get; set; }

    /// <summary>
    /// Gets or sets the uncontrolled initial input value.
    /// </summary>
    [Parameter]
    public string? DefaultValue { get; set; }

    /// <summary>
    /// Gets or sets the callback for two-way binding of the input value.
    /// </summary>
    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the input value changes.
    /// </summary>
    [Parameter]
    public EventCallback<AutocompleteValueChangeEventArgs> OnValueChange { get; set; }

    /// <summary>
    /// Gets or sets whether the popup is open. Use when controlled.
    /// </summary>
    [Parameter]
    public bool? Open { get; set; }

    /// <summary>
    /// Determines whether the popup is initially open.
    /// </summary>
    [Parameter]
    public bool DefaultOpen { get; set; }

    /// <summary>
    /// Gets or sets the callback for two-way binding of the open state.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the popup opens or closes.
    /// </summary>
    [Parameter]
    public EventCallback<AutocompleteOpenChangeEventArgs> OnOpenChange { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked after open or close animations complete.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OnOpenChangeComplete { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the highlighted item changes.
    /// </summary>
    [Parameter]
    public EventCallback<AutocompleteHighlightEventArgs<TValue>> OnItemHighlighted { get; set; }

    /// <summary>
    /// Controls list filtering and inline completion behavior.
    /// </summary>
    [Parameter]
    public AutocompleteMode Mode { get; set; } = AutocompleteMode.List;

    /// <summary>
    /// Controls automatic first-item highlighting.
    /// </summary>
    [Parameter]
    public AutocompleteAutoHighlight AutoHighlight { get; set; } = AutocompleteAutoHighlight.False;

    /// <summary>
    /// Determines whether highlighted items are retained when the pointer leaves the list.
    /// </summary>
    [Parameter]
    public bool KeepHighlight { get; set; }

    /// <summary>
    /// Determines whether pointer movement highlights items.
    /// </summary>
    [Parameter]
    public bool HighlightItemOnHover { get; set; } = true;

    /// <summary>
    /// Determines whether keyboard navigation loops through the item list.
    /// </summary>
    [Parameter]
    public bool LoopFocus { get; set; } = true;

    /// <summary>
    /// Determines whether clicking the input opens the popup.
    /// </summary>
    [Parameter]
    public bool OpenOnInputClick { get; set; }

    /// <summary>
    /// Determines whether the component ignores user interaction.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether the component ignores user edits.
    /// </summary>
    [Parameter]
    public bool ReadOnly { get; set; }

    /// <summary>
    /// Determines whether a value is required.
    /// </summary>
    [Parameter]
    public bool Required { get; set; }

    /// <summary>
    /// Identifies the form field.
    /// </summary>
    [Parameter]
    public string? Name { get; set; }

    /// <summary>
    /// Identifies the form that owns the input.
    /// </summary>
    [Parameter]
    public string? Form { get; set; }

    /// <summary>
    /// Provides a browser autocomplete hint for the hidden form input.
    /// </summary>
    [Parameter]
    public string? AutoComplete { get; set; }

    /// <summary>
    /// Gets or sets the root id.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Determines whether list items are presented as a grid.
    /// </summary>
    [Parameter]
    public bool Grid { get; set; }

    /// <summary>
    /// Determines whether list items are being externally virtualized.
    /// </summary>
    [Parameter]
    public bool Virtualized { get; set; }

    /// <summary>
    /// Determines whether the list is rendered inline instead of in a popup.
    /// </summary>
    [Parameter]
    public bool Inline { get; set; }

    /// <summary>
    /// Determines whether the popup is modal.
    /// </summary>
    [Parameter]
    public bool Modal { get; set; }

    /// <summary>
    /// Gets or sets the items to display and filter.
    /// </summary>
    [Parameter]
    public IReadOnlyList<TValue>? Items { get; set; }

    /// <summary>
    /// Gets or sets grouped items to display and filter.
    /// </summary>
    [Parameter]
    public IReadOnlyList<AutocompleteOptionGroup<TValue>>? ItemGroups { get; set; }

    /// <summary>
    /// Gets or sets externally filtered items.
    /// </summary>
    [Parameter]
    public IReadOnlyList<TValue>? FilteredItems { get; set; }

    /// <summary>
    /// Gets or sets the maximum number of items to display.
    /// </summary>
    [Parameter]
    public int Limit { get; set; } = -1;

    /// <summary>
    /// Gets or sets the filter function used to match items against the query.
    /// </summary>
    [Parameter]
    public Func<TValue, string, Func<TValue, string?>?, bool>? Filter { get; set; }

    /// <summary>
    /// Disables filtering, matching React <c>filter=null</c>.
    /// </summary>
    [Parameter]
    public bool FilterDisabled { get; set; }

    /// <summary>
    /// Gets or sets a function that converts an item value to display/form text.
    /// </summary>
    [Parameter]
    public Func<TValue?, string?>? ItemToStringValue { get; set; }

    /// <summary>
    /// Gets or sets custom item equality logic.
    /// </summary>
    [Parameter]
    public Func<TValue, TValue, bool>? IsItemEqualToValue { get; set; }

    /// <summary>
    /// Determines whether item press submits the owning form.
    /// </summary>
    [Parameter]
    public bool SubmitOnItemClick { get; set; }

    /// <summary>
    /// Gets or sets imperative root actions.
    /// </summary>
    [Parameter]
    public AutocompleteRootActions? ActionsRef { get; set; }

    /// <summary>
    /// Gets or sets a callback that receives the hidden input reference.
    /// </summary>
    [Parameter]
    public Action<ElementReference?>? InputRef { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [CascadingParameter]
    private FieldRootContext? FieldContext { get; set; }

    [CascadingParameter]
    private FormContext? FormContext { get; set; }

    [CascadingParameter]
    private LabelableContext? LabelableContext { get; set; }

    /// <inheritdoc />
    public override Task SetParametersAsync(ParameterView parameters)
    {
        hasValueParameter = parameters.TryGetValue<string?>(nameof(Value), out _);
        return base.SetParametersAsync(parameters);
    }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        rootId = Id ?? Guid.NewGuid().ToIdString();
        isOpen = DefaultOpen;
        internalValue = DefaultValue ?? string.Empty;

        if (CurrentOpen)
        {
            transition.BeginOpen();
        }

        state = new AutocompleteRootState(CurrentOpen);

        typedContext = new AutocompleteRootContext<TValue>
        {
            RootId = rootId,
            GetInputValueFunc = () => CurrentInputValue,
            GetTypedInputValueFunc = () => CurrentTypedInputValue,
            GetFormValueFunc = () => CurrentTypedInputValue,
            SetOpenAsyncFunc = SetOpenInternalAsync,
            SetInputValueAsyncFunc = SetInputValueInternalAsync,
            HighlightIndexAsyncFunc = HighlightIndexInternalAsync,
            CommitItemAsyncFunc = CommitItemInternalAsync,
            ClearAsyncFunc = ClearInternalAsync,
            FocusInputAsyncFunc = FocusInputAsync
        };
        context = typedContext;

        FieldContext?.Validation.SetInitialValue(CurrentTypedInputValue);
        FieldContext?.SetFilled(CurrentTypedInputValue.Length > 0);
        FieldContext?.RegisterFocusHandler(FocusInputAsync);
        FieldContext?.Subscribe(this);

        SyncContext();
        SyncActionsRef();
        SyncAutoHighlight();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        if (state.Open != CurrentOpen)
        {
            if (CurrentOpen)
            {
                transition.BeginOpen();
            }
            else
            {
                transition.BeginClose();
                transition.HandleTransitionEnd(false, ActionsRef?.Unmount is not null);
                activeIndex = -1;
                inlineInputValue = string.Empty;
            }

            state = new AutocompleteRootState(CurrentOpen);
        }

        SyncContext();
        SyncActionsRef();
        SyncAutoHighlight();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            dotNetRef = DotNetObjectReference.Create(this);

            try
            {
                var module = await ModuleTask;
                await module.InvokeVoidAsync("initializeRoot", rootId, dotNetRef);
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }

        if (hasRendered)
        {
            try
            {
                var module = await ModuleTask;
                await module.InvokeVoidAsync("setRootOpen", rootId, CurrentOpen, activeIndex, typedContext.GetVisibleItemCount(), LoopFocus);
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }

        if (!Nullable.Equals(previousHiddenInputElement, hiddenInputElement))
        {
            previousHiddenInputElement = hiddenInputElement;
            InputRef?.Invoke(hiddenInputElement);
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        FieldContext?.Unsubscribe(this);

        if (moduleTask?.IsValueCreated == true && hasRendered)
        {
            try
            {
                var module = await ModuleTask;
                await module.InvokeVoidAsync("disposeRoot", rootId);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }

        if (previousActionsRef is not null)
        {
            previousActionsRef.Unmount = null;
        }

        InputRef?.Invoke(null);
        typedContext?.Dispose();
        dotNetRef?.Dispose();
    }

    /// <inheritdoc />
    public void NotifyStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnOutsidePress()
    {
        return SetOpenInternalAsync(false, AutocompleteChangeReason.OutsidePress);
    }

    [JSInvokable]
    public Task OnEscapeKey()
    {
        return SetOpenInternalAsync(false, AutocompleteChangeReason.EscapeKey);
    }

    [JSInvokable]
    public Task OnFocusOut()
    {
        return SetOpenInternalAsync(false, AutocompleteChangeReason.FocusOut);
    }

    [JSInvokable]
    public async Task<int> OnNavigate(int delta)
    {
        if (ResolvedDisabled || ReadOnly)
        {
            return activeIndex;
        }

        if (!CurrentOpen)
        {
            await SetOpenInternalAsync(true, AutocompleteChangeReason.ListNavigation);
        }

        await typedContext.HighlightRelativeAsync(delta, AutocompleteHighlightReason.Keyboard);
        return activeIndex;
    }

    [JSInvokable]
    public Task OnCommitActive()
    {
        return typedContext.CommitActiveItemAsync();
    }

    [JSInvokable]
    public void OnKeyboardActiveChange(bool active)
    {
        typedContext.KeyboardActive = active;
    }

    private void SyncContext()
    {
        typedContext.Name = ResolvedName;
        typedContext.Form = Form;
        typedContext.Disabled = ResolvedDisabled;
        typedContext.ReadOnly = ReadOnly;
        typedContext.Required = Required;
        typedContext.Grid = Grid;
        typedContext.Virtualized = Virtualized;
        typedContext.Inline = Inline;
        typedContext.Modal = Modal;
        typedContext.OpenOnInputClick = OpenOnInputClick;
        typedContext.HighlightItemOnHover = HighlightItemOnHover;
        typedContext.KeepHighlight = KeepHighlight;
        typedContext.LoopFocus = LoopFocus;
        typedContext.Mounted = CurrentOpen || transition.IsMounted || Inline || typedContext.ForceMounted;
        typedContext.TransitionStatus = transition.TransitionStatus;
        typedContext.Mode = Mode;
        typedContext.AutoHighlight = AutoHighlight;
        typedContext.ActiveIndex = activeIndex;
        typedContext.OpenChangeReason = openChangeReason;
        typedContext.FieldState = FieldState;
        typedContext.Items = Items;
        typedContext.ItemGroups = ItemGroups;
        typedContext.FilteredItems = FilteredItems;
        typedContext.Limit = Limit;
        typedContext.Filter = Filter;
        typedContext.FilterDisabled = FilterDisabled;
        typedContext.ItemToStringValue = ItemToStringValue;
        typedContext.IsItemEqualToValue = IsItemEqualToValue;
        typedContext.HasInputValue = IsValueControlled || DefaultValue is not null;
    }

    private void SyncActionsRef()
    {
        if (previousActionsRef == ActionsRef)
        {
            return;
        }

        if (previousActionsRef is not null)
        {
            previousActionsRef.Unmount = null;
        }

        previousActionsRef = ActionsRef;
        if (ActionsRef is not null)
        {
            ActionsRef.Unmount = async () =>
            {
                transition.ForceUnmount();
                typedContext.ForceMounted = false;
                await OnOpenChangeComplete.InvokeAsync(false);
                typedContext.NotifyStateChanged();
                await InvokeAsync(StateHasChanged);
            };
        }
    }

    private void SyncAutoHighlight()
    {
        var count = typedContext.GetVisibleItemCount();
        if (count == 0)
        {
            if (activeIndex != -1)
            {
                activeIndex = -1;
            }
            inlineInputValue = string.Empty;
            autoHighlightSignature = null;
            return;
        }

        var query = CurrentTypedInputValue.Trim();
        var shouldAutoHighlight = AutoHighlight == AutocompleteAutoHighlight.Always ||
            AutoHighlight == AutocompleteAutoHighlight.True && query.Length > 0;

        if (!shouldAutoHighlight)
        {
            autoHighlightSignature = null;
            return;
        }

        var nextIndex = activeIndex >= 0 && activeIndex < count ? activeIndex : 0;
        var result = typedContext.GetValueAtVisibleIndex(nextIndex);
        var displayValue = result.Value is TValue typedValue ? typedContext.Stringify(typedValue) : string.Empty;
        var signature = BuildAutoHighlightSignature(query, nextIndex, displayValue);

        if (signature == autoHighlightSignature && activeIndex == nextIndex &&
            (!EnableInline || inlineInputValue == displayValue))
        {
            return;
        }

        autoHighlightSignature = signature;
        _ = HighlightIndexInternalAsync(nextIndex, AutocompleteHighlightReason.None);
    }

    private async Task SetOpenInternalAsync(bool open, AutocompleteChangeReason reason)
    {
        if (CurrentOpen == open)
        {
            return;
        }

        var args = new AutocompleteOpenChangeEventArgs(open, reason);
        await OnOpenChange.InvokeAsync(args);
        if (args.IsCanceled)
        {
            return;
        }

        if (!IsOpenControlled)
        {
            isOpen = open;
        }

        await OpenChanged.InvokeAsync(open);
        openChangeReason = reason;

        if (open)
        {
            transition.BeginOpen();
            if (AutoHighlight == AutocompleteAutoHighlight.Always)
            {
                await HighlightIndexInternalAsync(0, AutocompleteHighlightReason.None);
            }
        }
        else
        {
            transition.BeginClose();
            transition.HandleTransitionEnd(false, ActionsRef?.Unmount is not null);
            activeIndex = -1;
            inlineInputValue = string.Empty;
            await OnOpenChangeComplete.InvokeAsync(false);
        }

        state = new AutocompleteRootState(CurrentOpen);
        SyncContext();
        typedContext.NotifyStateChanged();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SetInputValueInternalAsync(string value, AutocompleteChangeReason reason)
    {
        value = NormalizeInlineInputChangeValue(value, reason);

        var args = new AutocompleteValueChangeEventArgs(value, reason);
        await OnValueChange.InvokeAsync(args);
        if (args.IsCanceled)
        {
            return;
        }

        inlineInputValue = string.Empty;
        autoHighlightSignature = null;

        if (!IsValueControlled)
        {
            internalValue = value;
        }

        await ValueChanged.InvokeAsync(value);
        FieldContext?.SetFilled(value.Length > 0);
        if (FieldContext is not null)
        {
            FieldContext.SetDirty(value != FieldContext.ValidityData.InitialValue?.ToString());
        }

        if (reason == AutocompleteChangeReason.InputChange)
        {
            if (!ResolvedDisabled && !ReadOnly && value.Trim().Length > 0)
            {
                await SetOpenInternalAsync(true, AutocompleteChangeReason.InputChange);
            }
            else if (value.Length == 0 && !OpenOnInputClick)
            {
                await SetOpenInternalAsync(false, AutocompleteChangeReason.InputClear);
            }

            if (AutoHighlight != AutocompleteAutoHighlight.False && value.Trim().Length > 0)
            {
                await HighlightIndexInternalAsync(0, AutocompleteHighlightReason.Keyboard);
            }
            else
            {
                await HighlightIndexInternalAsync(-1, AutocompleteHighlightReason.Keyboard);
            }
        }

        SyncContext();
        typedContext.NotifyStateChanged();
        await InvokeAsync(StateHasChanged);
    }

    private string NormalizeInlineInputChangeValue(string value, AutocompleteChangeReason reason)
    {
        if (reason != AutocompleteChangeReason.InputChange ||
            !EnableInline ||
            inlineInputValue.Length == 0)
        {
            return value;
        }

        var typedValue = CurrentTypedInputValue;
        if (typedValue.Length == 0 ||
            !inlineInputValue.StartsWith(typedValue, StringComparison.CurrentCultureIgnoreCase))
        {
            return value;
        }

        if (value.StartsWith(inlineInputValue, StringComparison.CurrentCultureIgnoreCase))
        {
            return string.Concat(typedValue, value.AsSpan(inlineInputValue.Length));
        }

        return value;
    }

    private async Task HighlightIndexInternalAsync(int index, AutocompleteHighlightReason reason)
    {
        var count = typedContext.GetVisibleItemCount();
        var nextIndex = count == 0 ? -1 : Math.Clamp(index, -1, count - 1);
        var hasNextHighlightedValue = false;
        TValue? nextHighlightedValue = default;
        var nextDisplayValue = string.Empty;

        if (nextIndex >= 0)
        {
            var result = typedContext.GetValueAtVisibleIndex(nextIndex);
            if (result.Value is TValue typedValue)
            {
                hasNextHighlightedValue = true;
                nextHighlightedValue = typedValue;
                nextDisplayValue = typedContext.Stringify(typedValue);
            }
        }

        var sameHighlightedValue = IsSameHighlightedValue(nextIndex, hasNextHighlightedValue, nextHighlightedValue);
        activeIndex = nextIndex;
        typedContext.ActiveIndex = activeIndex;
        if (reason != AutocompleteHighlightReason.None)
        {
            autoHighlightSignature = null;
        }

        if (hasNextHighlightedValue)
        {
            if (EnableInline && reason != AutocompleteHighlightReason.Pointer && !sameHighlightedValue)
            {
                inlineInputValue = nextDisplayValue;
            }
        }
        else
        {
            inlineInputValue = string.Empty;
        }

        if (!sameHighlightedValue)
        {
            await OnItemHighlighted.InvokeAsync(new AutocompleteHighlightEventArgs<TValue>(
                nextHighlightedValue,
                activeIndex,
                reason));
        }

        TrackHighlightedValue(nextIndex, hasNextHighlightedValue, nextHighlightedValue);
        typedContext.NotifyStateChanged();
        await InvokeAsync(StateHasChanged);
    }

    private string BuildAutoHighlightSignature(string query, int index, string displayValue)
    {
        return $"{Mode}|{AutoHighlight}|{query}|{index}|{displayValue}";
    }

    private bool IsSameHighlightedValue(int index, bool hasValue, TValue? value)
    {
        if (index != highlightedValueIndex || hasValue != hasHighlightedValue)
        {
            return false;
        }

        if (!hasValue)
        {
            return true;
        }

        return AreHighlightedValuesEqual(highlightedValue, value);
    }

    private bool AreHighlightedValuesEqual(TValue? left, TValue? right)
    {
        if (left is null || right is null)
        {
            return left is null && right is null;
        }

        return IsItemEqualToValue?.Invoke(left, right) ?? EqualityComparer<TValue>.Default.Equals(left, right);
    }

    private void TrackHighlightedValue(int index, bool hasValue, TValue? value)
    {
        highlightedValueIndex = index;
        hasHighlightedValue = hasValue;
        highlightedValue = value;
    }

    private async Task CommitItemInternalAsync(object? value, AutocompleteChangeReason reason)
    {
        if (ResolvedDisabled || ReadOnly)
        {
            return;
        }

        var nextValue = value is TValue typedValue
            ? typedContext.Stringify(typedValue)
            : value?.ToString() ?? string.Empty;

        await SetInputValueInternalAsync(nextValue, reason);
        await SetOpenInternalAsync(false, reason);

        if (SubmitOnItemClick)
        {
            await RequestSubmitAsync();
        }
    }

    private Task ClearInternalAsync(AutocompleteChangeReason reason)
    {
        activeIndex = -1;
        return SetInputValueInternalAsync(string.Empty, reason);
    }

    private async Task HandleHiddenInputFocus()
    {
        await FocusInputAsync();
    }

    private async Task HandleHiddenInputChange(ChangeEventArgs e)
    {
        if (ResolvedDisabled || ReadOnly)
        {
            return;
        }

        await SetInputValueInternalAsync(Convert.ToString(e.Value) ?? string.Empty, AutocompleteChangeReason.None);
    }

    private async ValueTask FocusInputAsync()
    {
        if (typedContext.InputElement.HasValue)
        {
            try
            {
                var module = await ModuleTask;
                await module.InvokeVoidAsync("focusElement", typedContext.InputElement.Value);
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }
    }

    private async Task RequestSubmitAsync()
    {
        if (!typedContext.InputElement.HasValue && !previousHiddenInputElement.HasValue)
        {
            return;
        }

        try
        {
            var module = await ModuleTask;
            var element = typedContext.InputElement ?? previousHiddenInputElement;
            if (element.HasValue)
            {
                await module.InvokeVoidAsync("requestSubmit", element.Value);
            }
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }
}
