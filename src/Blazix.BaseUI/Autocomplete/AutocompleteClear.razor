@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop

@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="AutocompleteClearState"
               Tag="@(NativeButton ? "button" : "div")"
               State="state"
               Enabled="RootContext is not null && (KeepMounted || state.Visible)"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="@(ChildContent ?? DefaultChildContent)"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string ModulePath = "./_content/Blazix.BaseUI/blazix-baseui-autocomplete.min.js";

    private AutocompleteClearState state;
    private RenderElement<AutocompleteClearState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private ElementReference? previousElement;
    private bool subscribed;

    private static RenderFragment DefaultChildContent => builder => builder.AddContent(0, "x");

    private Task<IJSObjectReference> ModuleTask => (moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>("import", ModulePath).AsTask())).Value;

    [CascadingParameter]
    private IAutocompleteRootContext? RootContext { get; set; }

    /// <summary>
    /// Determines whether the component should ignore user interaction.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether the component remains mounted when not visible.
    /// </summary>
    [Parameter]
    public bool KeepMounted { get; set; }

    /// <summary>
    /// Determines whether the rendered element is a native button.
    /// </summary>
    [Parameter]
    public bool NativeButton { get; set; } = true;

    /// <summary>
    /// Allows replacing or composing the rendered element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<AutocompleteClearState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on component state.
    /// </summary>
    [Parameter]
    public Func<AutocompleteClearState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on component state.
    /// </summary>
    [Parameter]
    public Func<AutocompleteClearState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets additional element attributes.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets the associated element reference.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (RootContext is not null)
        {
            RootContext.StateChanged += OnRootStateChanged;
            subscribed = true;
        }

        BuildStateAndAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        BuildStateAndAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (RootContext is null)
        {
            return;
        }

        var current = KeepMounted || state.Visible ? Element : null;
        if (Nullable.Equals(previousElement, current))
        {
            return;
        }

        previousElement = current;

        try
        {
            var module = await ModuleTask;
            await module.InvokeVoidAsync("setClearElement", RootContext.RootId, current.HasValue ? current.Value : null);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (subscribed && RootContext is not null)
        {
            RootContext.StateChanged -= OnRootStateChanged;
        }

        if (moduleTask?.IsValueCreated == true)
        {
            try
            {
                var module = await ModuleTask;
                if (RootContext is not null)
                {
                    await module.InvokeVoidAsync("setClearElement", RootContext.RootId, null);
                }

                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }
    }

    private void OnRootStateChanged()
    {
        BuildStateAndAttributes();
        InvokeAsync(StateHasChanged);
    }

    private void BuildStateAndAttributes()
    {
        var disabled = Disabled || RootContext?.Disabled == true;
        var visible = !string.IsNullOrEmpty(RootContext?.GetTypedInputValue());
        state = new AutocompleteClearState(
            RootContext?.Mounted == true,
            disabled,
            visible,
            TransitionStatus.Undefined);

        var attrs = new Dictionary<string, object>
        {
            ["tabindex"] = -1,
            ["onclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleClickAsync)
        };

        if (RootContext?.Mounted == true)
        {
            attrs["data-popup-open"] = true;
        }

        if (NativeButton)
        {
            attrs["type"] = "button";
        }
        else
        {
            attrs["role"] = "button";
        }

        if (disabled)
        {
            if (NativeButton)
            {
                attrs["disabled"] = true;
            }
            else
            {
                attrs["aria-disabled"] = "true";
            }

            attrs["data-disabled"] = true;
        }

        if (visible)
        {
            attrs["data-visible"] = true;
        }

        componentAttributes = attrs;
    }

    private async Task HandleClickAsync(MouseEventArgs e)
    {
        if (RootContext is null || state.Disabled || RootContext.ReadOnly)
        {
            return;
        }

        await RootContext.ClearAsync(AutocompleteChangeReason.ClearPress);
        await RootContext.FocusInputAsync();
        await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
    }
}
