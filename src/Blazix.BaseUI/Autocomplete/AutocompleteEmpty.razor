@implements IDisposable

<RenderElement TState="AutocompleteEmptyState"
               Tag="div"
               State="state"
               Enabled="RootContext is not null"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="@(RootContext?.ListEmpty == true ? ChildContent : null)"
               @attributes="AdditionalAttributes" />

@code {
    private static readonly AutocompleteEmptyState state = new();
    private Dictionary<string, object> componentAttributes = new();
    private bool subscribed;

    [CascadingParameter]
    private IAutocompleteRootContext? RootContext { get; set; }

    /// <summary>
    /// Allows replacing or composing the rendered element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<AutocompleteEmptyState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on component state.
    /// </summary>
    [Parameter]
    public Func<AutocompleteEmptyState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on component state.
    /// </summary>
    [Parameter]
    public Func<AutocompleteEmptyState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets additional element attributes.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (RootContext is not null)
        {
            RootContext.StateChanged += OnRootStateChanged;
            subscribed = true;
        }

        BuildComponentAttributes();
    }

    /// <inheritdoc />
    public void Dispose()
    {
        if (subscribed && RootContext is not null)
        {
            RootContext.StateChanged -= OnRootStateChanged;
        }
    }

    private void OnRootStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void BuildComponentAttributes()
    {
        componentAttributes = new Dictionary<string, object>
        {
            ["role"] = "status",
            ["aria-live"] = "polite",
            ["aria-atomic"] = "true"
        };
    }
}
