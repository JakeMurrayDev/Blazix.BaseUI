@typeparam TValue
@implements IDisposable

<RenderElement TState="SelectValueState"
               Tag="span"
               State="state"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ResolveContent()"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private SelectValueState state;
    private RenderElement<SelectValueState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private bool valueElementRegistered;

    [CascadingParameter]
    private ISelectRootContext? RootContext { get; set; }

    [CascadingParameter]
    private SelectRootContext<TValue>? TypedRootContext { get; set; }

    /// <summary>
    /// Gets or sets the plain-text placeholder displayed when no value is selected.
    /// Overridden by <see cref="PlaceholderContent"/> when both are provided, and
    /// suppressed when a null-valued item with a label is present in the root's
    /// <c>Items</c>/<c>ItemGroups</c>.
    /// </summary>
    [Parameter]
    public string? Placeholder { get; set; }

    /// <summary>
    /// Gets or sets rich placeholder content displayed when no value is selected.
    /// Takes priority over <see cref="Placeholder"/>. Suppressed when a null-valued
    /// item with a label is present in the root's <c>Items</c>/<c>ItemGroups</c>.
    /// </summary>
    [Parameter]
    public RenderFragment? PlaceholderContent { get; set; }

    /// <summary>
    /// Gets or sets a child content function that receives the current value.
    /// </summary>
    [Parameter]
    public RenderFragment<TValue?>? ValueContent { get; set; }

    /// <summary>
    /// Gets or sets a child content function that receives the current values in multi-select mode.
    /// </summary>
    [Parameter]
    public RenderFragment<IReadOnlyList<TValue>>? ValuesContent { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<SelectValueState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<SelectValueState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<SelectValueState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// Takes precedence over every computed fallback (placeholder, null-item label,
    /// resolved single- or multi-value label). Mirrors React Base UI's static
    /// <c>children</c> branch in <c>SelectValue</c>.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (RootContext is not null)
        {
            RootContext.StateChanged += OnRootStateChanged;
        }
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        state = BuildState();
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && !valueElementRegistered && RootContext is not null && Element.HasValue)
        {
            RootContext.SetValueElement(Element);
            valueElementRegistered = true;
        }
    }

    /// <inheritdoc />
    public void Dispose()
    {
        if (RootContext is not null)
        {
            RootContext.StateChanged -= OnRootStateChanged;
            if (valueElementRegistered)
            {
                RootContext.SetValueElement(null);
            }
        }
    }

    private void OnRootStateChanged()
    {
        state = BuildState();
        BuildComponentAttributes();
        InvokeAsync(StateHasChanged);
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        if (state.Placeholder)
        {
            attrs["data-placeholder"] = true;
        }

        componentAttributes = attrs;
    }

    private SelectValueState BuildState()
    {
        var placeholder = RootContext?.IsPlaceholder ?? true;
        var isMultiple = RootContext?.Multiple ?? false;

        if (TypedRootContext is null)
        {
            return new SelectValueState(placeholder, null, null);
        }

        if (isMultiple)
        {
            var values = TypedRootContext.GetValues();
            var boxed = new List<object>(values.Count);
            foreach (var v in values)
            {
                if (v is not null) boxed.Add(v);
            }
            return new SelectValueState(placeholder, null, boxed);
        }

        return new SelectValueState(placeholder, (object?)TypedRootContext.GetValue(), null);
    }

    private RenderFragment? ResolveContent()
    {
        // ChildContent wins unconditionally — mirrors React's static `childrenProp != null` branch.
        if (ChildContent is not null && ValueContent is null && ValuesContent is null)
        {
            return ChildContent;
        }

        if (TypedRootContext is null)
        {
            return ChildContent;
        }

        var isMultiple = RootContext?.Multiple ?? false;

        if (isMultiple)
        {
            var values = TypedRootContext.GetValues();

            if (ValuesContent is not null)
            {
                return ValuesContent(values);
            }

            if (ChildContent is not null)
            {
                return ChildContent;
            }

            if (values.Count == 0)
            {
                return ResolvePlaceholderFragment();
            }

            return CreateMultipleLabelsFragment(values);
        }

        var value = TypedRootContext.GetValue();

        if (ValueContent is not null)
        {
            return ValueContent(value);
        }

        if (ChildContent is not null)
        {
            return ChildContent;
        }

        if (value is null)
        {
            // When a null-valued item carries a label (e.g. "None"), React's
            // resolveSelectedLabel wins over the placeholder. Consult it first.
            if (RootContext?.HasNullItemLabel == true)
            {
                var nullLabel = TypedRootContext.GetLabel(default);
                if (!string.IsNullOrEmpty(nullLabel))
                {
                    return CreateTextFragment(nullLabel);
                }
            }

            return ResolvePlaceholderFragment();
        }

        var label = TypedRootContext.GetLabel(value);
        return TypedRootContext.GetLabelContent(value) ?? CreateTextFragment(label ?? value?.ToString());
    }

    private RenderFragment? ResolvePlaceholderFragment()
    {
        if (PlaceholderContent is not null)
        {
            return PlaceholderContent;
        }
        return CreateTextFragment(Placeholder);
    }

    private static RenderFragment? CreateTextFragment(string? text)
    {
        if (string.IsNullOrEmpty(text))
        {
            return null;
        }

        return builder => builder.AddContent(0, text);
    }

    private RenderFragment CreateMultipleLabelsFragment(IReadOnlyList<TValue> values) => builder =>
    {
        for (var index = 0; index < values.Count; index++)
        {
            builder.OpenRegion(0);
            if (index > 0)
            {
                builder.AddContent(0, ", ");
            }

            var value = values[index];
            var content = TypedRootContext?.GetLabelContent(value);
            if (content is not null)
            {
                builder.AddContent(1, content);
            }
            else
            {
                builder.AddContent(2, TypedRootContext?.GetLabel(value) ?? value?.ToString() ?? string.Empty);
            }
            builder.CloseRegion();
        }
    };
}
