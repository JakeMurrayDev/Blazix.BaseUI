@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="SelectItemIndicatorState"
               Tag="span"
               State="state"
               Enabled="IsPresent"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="effectiveChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private static readonly RenderFragment defaultChildContent = builder => builder.AddContent(0, "✔️");

    private bool isMounted;
    private TransitionStatus transitionStatus = TransitionStatus.Undefined;
    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private DotNetObjectReference<SelectItemIndicator>? dotNetRef;
    private bool transitionPending;
    private SelectItemIndicatorState state;
    private RenderElement<SelectItemIndicatorState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private bool previousSelected;
    private TransitionStatus previousTransitionStatus = TransitionStatus.Undefined;
    private bool hasInitializedTransition;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./_content/Blazix.BaseUI/blazix-baseui-select.min.js").AsTask());

    private bool Rendered => ItemContext?.Selected ?? false;

    // Mirror React's `useTransitionStatus(selected)` mounting rule: keep the
    // element rendered while the exit transition is still in flight (Ending),
    // so consumers can apply `[data-ending]` exit styles without the node
    // disappearing first. `isMounted` flips false only after `ScheduleUnmount`
    // completes, which is exactly the lifetime we want here.
    private bool IsPresent =>
        KeepMounted || Rendered || isMounted || transitionStatus == TransitionStatus.Ending;

    private RenderFragment effectiveChildContent => ChildContent ?? defaultChildContent;

    [CascadingParameter]
    private SelectItemContext? ItemContext { get; set; }

    /// <summary>
    /// Determines whether the indicator should remain in the DOM when the item is not selected.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool KeepMounted { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<SelectItemIndicatorState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<SelectItemIndicatorState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<SelectItemIndicatorState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        UpdateTransitionStatus();

        var selected = ItemContext?.Selected ?? false;

        var stateChanged = previousSelected != selected ||
                           previousTransitionStatus != transitionStatus;

        if (stateChanged)
        {
            state = new SelectItemIndicatorState(selected, transitionStatus);
        }

        BuildComponentAttributes();

        previousSelected = selected;
        previousTransitionStatus = transitionStatus;
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!transitionPending || !Element.HasValue)
        {
            return;
        }

        transitionPending = false;
        dotNetRef ??= DotNetObjectReference.Create(this);
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("beginPartTransition", Element.Value, dotNetRef, Rendered);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (moduleTask?.IsValueCreated == true && Element.HasValue)
        {
            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("disposePartTransition", Element.Value);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }

        dotNetRef?.Dispose();
    }

    /// <summary>
    /// Completes the current entry or exit transition after the DOM reports its
    /// actual animation lifetime.
    /// </summary>
    [JSInvokable]
    public async Task OnTransitionEnd(bool open)
    {
        if (open != Rendered)
        {
            return;
        }

        if (!open)
        {
            isMounted = false;
        }
        transitionStatus = TransitionStatus.Undefined;
        state = new SelectItemIndicatorState(Rendered, transitionStatus);
        BuildComponentAttributes();
        await InvokeAsync(StateHasChanged);
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        attrs["aria-hidden"] = "true";
        TransitionAttributeHelper.ApplyTransitionStyleAttributes(attrs, state.TransitionStatus);

        componentAttributes = attrs;
    }

    private void UpdateTransitionStatus()
    {
        var wasRendered = isMounted;
        var isRendered = Rendered;

        if (!hasInitializedTransition)
        {
            isMounted = isRendered;
            transitionStatus = TransitionStatus.Undefined;
            hasInitializedTransition = true;
            return;
        }

        if (isRendered && !wasRendered)
        {
            isMounted = true;
            transitionStatus = TransitionStatus.Starting;
            transitionPending = true;
        }
        else if (!isRendered && wasRendered)
        {
            transitionStatus = TransitionStatus.Ending;
            transitionPending = true;
        }
        else if (isRendered && wasRendered && transitionStatus == TransitionStatus.Ending)
        {
            // Re-selected mid-exit: cancel pending unmount, restart entry.
            transitionStatus = TransitionStatus.Starting;
            transitionPending = true;
        }
    }
}
