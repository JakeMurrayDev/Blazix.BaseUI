@typeparam TValue
@foreach (var item in ItemsToRender)
{
    @ChildContent(item)
}

@code {
    private IReadOnlyList<ComboboxCollectionItem<TValue>> ItemsToRender =>
        TypedRootContext?.GetFlatFilteredItems()
            .Select((item, index) => new ComboboxCollectionItem<TValue>(item, index))
            .ToList()
        ?? [];

    [CascadingParameter]
    private ComboboxRootContext<TValue>? TypedRootContext { get; set; }

    /// <summary>
    /// Renders a filtered item.
    /// </summary>
    [Parameter, EditorRequired]
    public RenderFragment<ComboboxCollectionItem<TValue>> ChildContent { get; set; } = null!;
}
