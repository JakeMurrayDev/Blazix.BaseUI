@page "/components/drawer"

<PageTitle>Drawer · Blazix.BaseUI</PageTitle>

<DocsPageIntro Eyebrow="Components"
               Title="Drawer"
               Subtitle="A dialog that slides in from the edge of the screen."
               MarkdownHref="/components/drawer.md" />

<div class="mt-8">
    <Demo Variants="@HeroVariants">
        <DrawerHeroCss />
    </Demo>
</div>

<DocsHeading Title="Anatomy" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Import the component namespace and assemble the trigger, portal, backdrop, viewport, popup, content, title, description, and close button. Drawer uses Dialog semantics and adds swipe direction, snap points, and drawer-specific visual state.
</p>
<CodeBlock Code="@AnatomyCode" />

<DocsHeading Title="Examples" />
<DocsHeading Level="3" Title="Snap points" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Provide <code class="@LiquidGlassClasses.CodeInline">SnapPoints</code> to let a bottom drawer rest at preset heights. Bind <code class="@LiquidGlassClasses.CodeInline">SnapPoint</code> when app state needs to know which point is active.
</p>
<div class="mb-2">
    <Demo Variants="@SnapPointVariants">
        <DrawerSnapPointsCss />
    </Demo>
</div>

<DocsHeading Title="API reference" />
@foreach (var part in DrawerApi.Parts)
{
    <ApiPartReference Part="part" />
}

@code {
    private const string AnatomyCode =
        """
        @using Blazix.BaseUI.Drawer

        <DrawerRoot>
            <DrawerTrigger />
            <DrawerPortal>
                <DrawerBackdrop />
                <DrawerViewport>
                    <DrawerPopup>
                        <DrawerContent>
                            <DrawerTitle />
                            <DrawerDescription />
                            <DrawerClose />
                        </DrawerContent>
                    </DrawerPopup>
                </DrawerViewport>
            </DrawerPortal>
        </DrawerRoot>
        """;

    private static readonly IReadOnlyList<DemoVariant> HeroVariants =
    [
        new("CSS",
        [
            new DemoFile("Drawer.razor", "xml", "Components.Demos.Drawer.Hero.Css.DrawerHeroCss.razor"),
            new DemoFile("drawer.css", "css", "wwwroot.demos.drawer.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("Drawer.razor", "xml", "Components.Demos.Drawer.Hero.Tailwind.DrawerHeroTailwind.razor"),
        ]),
    ];

    private static readonly IReadOnlyList<DemoVariant> SnapPointVariants =
    [
        new("CSS",
        [
            new DemoFile("Drawer.razor", "xml", "Components.Demos.Drawer.SnapPoints.Css.DrawerSnapPointsCss.razor"),
            new DemoFile("drawer.css", "css", "wwwroot.demos.drawer.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("Drawer.razor", "xml", "Components.Demos.Drawer.SnapPoints.Tailwind.DrawerSnapPointsTailwind.razor"),
        ]),
    ];
}
