@page "/components/checkbox-group"

<PageTitle>Checkbox Group · Blazix.BaseUI</PageTitle>

<DocsPageIntro Eyebrow="Components"
               Title="Checkbox Group"
               Subtitle="Provides shared state to a series of checkboxes."
               MarkdownHref="/components/checkbox-group.md" />

<div class="mt-8">
    <Demo Variants="@HeroVariants">
        <CheckboxGroupHeroCss />
    </Demo>
</div>

<DocsHeading Title="Usage guidelines" />
<ul class="mb-3 max-w-3xl list-disc space-y-2 pl-5 text-sm leading-6 text-slate-700 dark:text-slate-200">
    <li>
        Label the group with <code class="@LiquidGlassClasses.CodeInline">aria-labelledby</code>, Fieldset, or another visible grouping label.
    </li>
    <li>
        Child checkboxes should provide <code class="@LiquidGlassClasses.CodeInline">Value</code> so the group can track selected values.
    </li>
</ul>

<DocsHeading Title="Anatomy" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Import Checkbox and CheckboxGroup, then place CheckboxRoot children inside the group:
</p>
<CodeBlock Code="@AnatomyCode" />

<DocsHeading Title="Examples" />
<DocsHeading Level="3" Title="Labeling a checkbox group" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Use a visible label id and point the group at it with <code class="@LiquidGlassClasses.CodeInline">aria-labelledby</code>.
</p>
<CodeBlock Code="@LabelingCode" />

<DocsHeading Level="3" Title="Parent checkbox" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Make the group controlled, pass <code class="@LiquidGlassClasses.CodeInline">AllValues</code>, and add <code class="@LiquidGlassClasses.CodeInline">Parent="true"</code> to the controlling checkbox.
</p>
<div class="mb-2">
    <Demo Variants="@ParentVariants">
        <CheckboxGroupParentCss />
    </Demo>
</div>

<DocsHeading Level="3" Title="Nested parent checkbox" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Nested groups can coordinate parent state by updating the outer group when the inner group becomes fully selected or partially selected.
</p>
<div class="mb-2">
    <Demo Variants="@NestedVariants">
        <CheckboxGroupNestedCss />
    </Demo>
</div>

<DocsHeading Title="API reference" />
@foreach (var part in CheckboxGroupApi.Parts)
{
    <ApiPartReference Part="part" />
}

@code {
    private const string AnatomyCode =
        """
        @using Blazix.BaseUI.Checkbox
        @using Blazix.BaseUI.CheckboxGroup

        <CheckboxGroup>
            <CheckboxRoot Value="http">
                <CheckboxIndicator />
            </CheckboxRoot>
        </CheckboxGroup>
        """;

    private const string LabelingCode =
        """
        @using Blazix.BaseUI.Checkbox
        @using Blazix.BaseUI.CheckboxGroup

        <div id="protocols-label">Allowed network protocols</div>
        <CheckboxGroup aria-labelledby="protocols-label">
            <label>
                <CheckboxRoot Value="http" />
                HTTP
            </label>
        </CheckboxGroup>
        """;

    private static readonly IReadOnlyList<DemoVariant> HeroVariants =
    [
        new("CSS",
        [
            new DemoFile("CheckboxGroup.razor", "xml", "Components.Demos.CheckboxGroup.Hero.Css.CheckboxGroupHeroCss.razor"),
            new DemoFile("checkbox-group.css", "css", "wwwroot.demos.checkbox-group.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("CheckboxGroup.razor", "xml", "Components.Demos.CheckboxGroup.Hero.Tailwind.CheckboxGroupHeroTailwind.razor"),
        ]),
    ];

    private static readonly IReadOnlyList<DemoVariant> ParentVariants =
    [
        new("CSS",
        [
            new DemoFile("CheckboxGroup.razor", "xml", "Components.Demos.CheckboxGroup.Parent.Css.CheckboxGroupParentCss.razor"),
            new DemoFile("checkbox-group.css", "css", "wwwroot.demos.checkbox-group.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("CheckboxGroup.razor", "xml", "Components.Demos.CheckboxGroup.Parent.Tailwind.CheckboxGroupParentTailwind.razor"),
        ]),
    ];

    private static readonly IReadOnlyList<DemoVariant> NestedVariants =
    [
        new("CSS",
        [
            new DemoFile("CheckboxGroup.razor", "xml", "Components.Demos.CheckboxGroup.Nested.Css.CheckboxGroupNestedCss.razor"),
            new DemoFile("checkbox-group.css", "css", "wwwroot.demos.checkbox-group.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("CheckboxGroup.razor", "xml", "Components.Demos.CheckboxGroup.Nested.Tailwind.CheckboxGroupNestedTailwind.razor"),
        ]),
    ];
}
