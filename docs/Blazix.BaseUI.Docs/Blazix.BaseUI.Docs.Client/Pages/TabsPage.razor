@page "/components/tabs"

<PageTitle>Tabs · Blazix.BaseUI</PageTitle>

<DocsPageIntro Eyebrow="Components"
               Title="Tabs"
               Subtitle="Organizes related content into panels with keyboard-accessible tab navigation."
               MarkdownHref="/components/tabs.md" />

<div class="mt-8">
    <Demo Variants="@HeroVariants">
        <TabsHeroCss />
    </Demo>
</div>

<DocsHeading Title="Anatomy" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Import the component namespace and pair each tab with a panel that uses the same value.
</p>
<CodeBlock Code="@AnatomyCode" />

<DocsHeading Title="Examples" />

<DocsHeading Level="3" Title="Links" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Render tabs as anchors when the tab selection should also update the URL or behave like navigation.
</p>
<div class="mb-8">
    <Demo Variants="@LinksVariants">
        <TabsLinksCss />
    </Demo>
</div>

<DocsHeading Title="API reference" />
@foreach (var part in TabsApi.Parts)
{
    <ApiPartReference Part="part" />
}

@code {
    private const string AnatomyCode =
        """
        @using Blazix.BaseUI.Tabs

        <TabsRoot TValue="string" DefaultValue="@("overview")">
            <TabsList TValue="string">
                <TabsTab TValue="string" Value="@("overview")">Overview</TabsTab>
                <TabsIndicator TValue="string" />
            </TabsList>
            <TabsPanel TValue="string" Value="@("overview")">
                Overview content
            </TabsPanel>
        </TabsRoot>
        """;

    private static readonly IReadOnlyList<DemoVariant> HeroVariants =
    [
        new("CSS",
        [
            new DemoFile("Tabs.razor", "xml", "Components.Demos.Tabs.Hero.Css.TabsHeroCss.razor"),
            new DemoFile("tabs.css", "css", "wwwroot.demos.tabs.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("Tabs.razor", "xml", "Components.Demos.Tabs.Hero.Tailwind.TabsHeroTailwind.razor"),
        ]),
    ];

    private static readonly IReadOnlyList<DemoVariant> LinksVariants =
    [
        new("CSS",
        [
            new DemoFile("Tabs.razor", "xml", "Components.Demos.Tabs.Links.Css.TabsLinksCss.razor"),
            new DemoFile("tabs.css", "css", "wwwroot.demos.tabs.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("Tabs.razor", "xml", "Components.Demos.Tabs.Links.Tailwind.TabsLinksTailwind.razor"),
        ]),
    ];
}
