@page "/components/form"

<PageTitle>Form · Blazix.BaseUI</PageTitle>

<DocsPageIntro Eyebrow="Components"
               Title="Form"
               Subtitle="A native form element with consolidated field validation and error handling."
               MarkdownHref="/components/form.md" />

<div class="mt-8">
    <Demo Variants="@HeroVariants">
        <FormHeroCss />
    </Demo>
</div>

<DocsHeading Title="Usage guidelines" />
<ul class="mb-3 max-w-3xl list-disc space-y-2 pl-5 text-sm leading-6 text-slate-700 dark:text-slate-200">
    <li>Use Field parts inside Form so validation state, focus targeting, and submitted values share the same registry.</li>
    <li>Provide <code class="@LiquidGlassClasses.CodeInline">Errors</code> when server validation returns field-level messages.</li>
    <li>Use <code class="@LiquidGlassClasses.CodeInline">OnFormSubmit</code> when you want values collected by field name instead of reading the model directly.</li>
</ul>

<DocsHeading Title="Anatomy" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Import Form and Field, then place named fields inside the form:
</p>
<CodeBlock Code="@AnatomyCode" />

<DocsHeading Title="Examples" />
<DocsHeading Level="3" Title="Submit form values as a dictionary" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    <code class="@LiquidGlassClasses.CodeInline">OnFormSubmit</code> receives values collected from registered fields with names.
</p>
<div class="mb-2">
    <Demo Variants="@ValuesVariants">
        <FormValuesCss />
    </Demo>
</div>

<DocsHeading Level="3" Title="External errors" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Pass an <code class="@LiquidGlassClasses.CodeInline">Errors</code> dictionary keyed by field name to surface server-style validation.
</p>
<div class="mb-2">
    <Demo Variants="@ExternalErrorsVariants">
        <FormExternalErrorsCss />
    </Demo>
</div>

<DocsHeading Title="API reference" />
@foreach (var part in FormApi.Parts)
{
    <ApiPartReference Part="part" />
}

@code {
    private const string AnatomyCode =
        """
        @using Blazix.BaseUI.Field
        @using Blazix.BaseUI.Form

        <Form Model="@model">
            <FieldRoot Name="email">
                <FieldLabel>Email</FieldLabel>
                <FieldControl TValue="string" @bind-Value="model.Email" />
                <FieldError />
            </FieldRoot>
        </Form>

        @code {
            private readonly EmailModel model = new();

            private sealed class EmailModel
            {
                public string Email { get; set; } = "";
            }
        }
        """;

    private static readonly IReadOnlyList<DemoVariant> HeroVariants =
    [
        new("CSS",
        [
            new DemoFile("Form.razor", "xml", "Components.Demos.Form.Hero.Css.FormHeroCss.razor"),
            new DemoFile("form.css", "css", "wwwroot.demos.form.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("Form.razor", "xml", "Components.Demos.Form.Hero.Tailwind.FormHeroTailwind.razor"),
        ]),
    ];

    private static readonly IReadOnlyList<DemoVariant> ValuesVariants =
    [
        new("CSS",
        [
            new DemoFile("Form.razor", "xml", "Components.Demos.Form.Values.Css.FormValuesCss.razor"),
            new DemoFile("form.css", "css", "wwwroot.demos.form.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("Form.razor", "xml", "Components.Demos.Form.Values.Tailwind.FormValuesTailwind.razor"),
        ]),
    ];

    private static readonly IReadOnlyList<DemoVariant> ExternalErrorsVariants =
    [
        new("CSS",
        [
            new DemoFile("Form.razor", "xml", "Components.Demos.Form.ExternalErrors.Css.FormExternalErrorsCss.razor"),
            new DemoFile("form.css", "css", "wwwroot.demos.form.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("Form.razor", "xml", "Components.Demos.Form.ExternalErrors.Tailwind.FormExternalErrorsTailwind.razor"),
        ]),
    ];
}
