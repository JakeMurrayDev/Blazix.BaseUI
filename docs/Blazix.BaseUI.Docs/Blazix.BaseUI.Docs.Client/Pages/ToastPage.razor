@page "/components/toast"

<PageTitle>Toast · Blazix.BaseUI</PageTitle>

<DocsPageIntro Eyebrow="Components"
               Title="Toast"
               Subtitle="Brief status messages with stacking, actions, promises, and anchored positioning."
               MarkdownHref="/components/toast.md" />

<div class="mt-8">
    <Demo Variants="@HeroVariants">
        <ToastHeroCss />
    </Demo>
</div>

<DocsHeading Title="Anatomy" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Put <code class="@LiquidGlassClasses.CodeInline">ToastProvider</code> around a portal and viewport, then render each visible manager item as a root.
</p>
<CodeBlock Code="@AnatomyCode" />

<DocsHeading Title="Examples" />

<DocsHeading Level="3" Title="Anchored toasts" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Use <code class="@LiquidGlassClasses.CodeInline">ToastPositioner</code> when a toast should be placed relative to a specific element.
</p>
<div class="mb-8">
    <Demo Variants="@AnchoredVariants">
        <ToastAnchoredCss />
    </Demo>
</div>

<DocsHeading Level="3" Title="Custom position" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Change the viewport and root styles to place the stack somewhere else; this source sample shows a top-center position.
</p>
<div class="mb-8">
    <Demo Variants="@PositionVariants">
        <ToastPositionCss />
    </Demo>
</div>

<DocsHeading Level="3" Title="Undo action" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Add an action button through the toast options when the notification can reverse an operation.
</p>
<div class="mb-8">
    <Demo Variants="@UndoVariants">
        <ToastUndoCss />
    </Demo>
</div>

<DocsHeading Level="3" Title="Promise" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Let the manager update loading, success, and error states around an asynchronous operation.
</p>
<div class="mb-8">
    <Demo Variants="@PromiseVariants">
        <ToastPromiseCss />
    </Demo>
</div>

<DocsHeading Level="3" Title="Custom" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Pass custom data to the manager and read it from each toast while rendering.
</p>
<div class="mb-8">
    <Demo Variants="@CustomVariants">
        <ToastCustomCss />
    </Demo>
</div>

<DocsHeading Level="3" Title="Deduplicated toast" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Upsert the same toast id so repeated events update one toast and replay attention styles through <code class="@LiquidGlassClasses.CodeInline">UpdateKey</code>.
</p>
<div class="mb-8">
    <Demo Variants="@DeduplicateVariants">
        <ToastDeduplicateCss />
    </Demo>
</div>

<DocsHeading Level="3" Title="Varying heights" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Toasts measure their own height so stacked transitions keep working as content size changes.
</p>
<div class="mb-8">
    <Demo Variants="@VaryingHeightsVariants">
        <ToastVaryingHeightsCss />
    </Demo>
</div>

<DocsHeading Title="API reference" />
@foreach (var part in ToastApi.Parts)
{
    <ApiPartReference Part="part" />
}

@code {
    private const string AnatomyCode =
        """
        @using Blazix.BaseUI.Toast

        <ToastProvider ToastManager="@toastManager" Context="toasts">
            <ToastPortal>
                <ToastViewport>
                    @foreach (var toast in toasts.Toasts)
                    {
                        <ToastRoot Toast="toast">
                            <ToastTitle>@toast.Title</ToastTitle>
                            <ToastDescription>@toast.Description</ToastDescription>
                            <ToastClose />
                        </ToastRoot>
                    }
                </ToastViewport>
            </ToastPortal>
        </ToastProvider>

        @code {
            private readonly ToastManager toastManager = new();
        }
        """;

