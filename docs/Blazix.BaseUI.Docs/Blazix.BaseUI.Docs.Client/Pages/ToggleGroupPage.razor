@page "/components/toggle-group"

<PageTitle>Toggle Group · Blazix.BaseUI</PageTitle>

<DocsPageIntro Eyebrow="Components"
               Title="Toggle Group"
               Subtitle="Manages shared selection state for a group of toggle buttons."
               MarkdownHref="/components/toggle-group.md" />

<div class="mt-8">
    <Demo Variants="@HeroVariants">
        <ToggleGroupHeroCss />
    </Demo>
</div>

<DocsHeading Title="Anatomy" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Import the group and toggle namespaces, then give every child toggle a value.
</p>
<CodeBlock Code="@AnatomyCode" />

<DocsHeading Title="Examples" />

<DocsHeading Level="3" Title="Multiple" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Set <code class="@LiquidGlassClasses.CodeInline">Multiple</code> when users can press several toggles at the same time.
</p>
<div class="mb-8">
    <Demo Variants="@MultipleVariants">
        <ToggleGroupMultipleCss />
    </Demo>
</div>

<DocsHeading Title="API reference" />
@foreach (var part in ToggleGroupApi.Parts)
{
    <ApiPartReference Part="part" />
}

@code {
    private const string AnatomyCode =
        """
        @using Blazix.BaseUI.Toggle
        @using Blazix.BaseUI.ToggleGroup

        <ToggleGroup>
            <Toggle Value="bold">Bold</Toggle>
            <Toggle Value="italic">Italic</Toggle>
            <Toggle Value="underline">Underline</Toggle>
        </ToggleGroup>
        """;

    private static readonly IReadOnlyList<DemoVariant> HeroVariants =
    [
        new("CSS",
        [
            new DemoFile("ToggleGroup.razor", "xml", "Components.Demos.ToggleGroup.Hero.Css.ToggleGroupHeroCss.razor"),
            new DemoFile("toggle-group.css", "css", "wwwroot.demos.toggle-group.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("ToggleGroup.razor", "xml", "Components.Demos.ToggleGroup.Hero.Tailwind.ToggleGroupHeroTailwind.razor"),
        ]),
    ];

    private static readonly IReadOnlyList<DemoVariant> MultipleVariants =
    [
        new("CSS",
        [
            new DemoFile("ToggleGroup.razor", "xml", "Components.Demos.ToggleGroup.Multiple.Css.ToggleGroupMultipleCss.razor"),
            new DemoFile("toggle-group.css", "css", "wwwroot.demos.toggle-group.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("ToggleGroup.razor", "xml", "Components.Demos.ToggleGroup.Multiple.Tailwind.ToggleGroupMultipleTailwind.razor"),
        ]),
    ];
}
