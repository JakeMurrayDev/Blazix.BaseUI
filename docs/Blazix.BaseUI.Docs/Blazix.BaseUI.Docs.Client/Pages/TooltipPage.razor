        ]),
        new("Tailwind",
        [
            new DemoFile("Tooltip.razor", "xml", "Components.Demos.Tooltip.DetachedTriggersSimple.Tailwind.TooltipDetachedTriggersSimpleTailwind.razor"),
        ]),
