@page "/components/button"

<PageTitle>Button · Blazix.BaseUI</PageTitle>

<DocsPageIntro Eyebrow="Components"
               Title="Button"
               Subtitle="A button component that can be rendered as another tag or focusable when disabled."
               MarkdownHref="/components/button.md" />

<div class="mt-8">
    <Demo Variants="@HeroVariants">
        <ButtonHeroCss />
    </Demo>
</div>

<DocsHeading Title="Usage guidelines" />
<ul class="mb-3 max-w-3xl list-disc space-y-2 pl-5 text-sm leading-6 text-slate-700 dark:text-slate-200">
    <li>
        Unlike the native button element, <code class="@LiquidGlassClasses.CodeInline">type="submit"</code> must be specified on <code class="@LiquidGlassClasses.CodeInline">Button</code> for it to act as a submit button.
    </li>
    <li>
        The Button component enforces button semantics. Style links directly when navigation needs to look like a button.
    </li>
</ul>

<DocsHeading Title="Anatomy" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Import the component namespace and render the button:
</p>
<CodeBlock Code="@AnatomyCode" />

<DocsHeading Title="Examples" />
<DocsHeading Level="3" Title="Rendering as another tag" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Set <code class="@LiquidGlassClasses.CodeInline">NativeButton="false"</code> when the rendered element is not a native <code class="@LiquidGlassClasses.CodeInline">&lt;button&gt;</code>. The component will add button semantics and keyboard activation.
</p>
<CodeBlock Code="@CustomTagCode" />

<DocsHeading Level="3" Title="Rendering links as buttons" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Links already have their own navigation semantics. If a link needs button styling, style the <code class="@LiquidGlassClasses.CodeInline">&lt;a&gt;</code> element directly instead of rendering it through Button.
</p>

<DocsHeading Level="3" Title="Loading states" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Use <code class="@LiquidGlassClasses.CodeInline">FocusableWhenDisabled="true"</code> when a button disables itself after activation. Focus remains on the control while the operation runs.
</p>
<div class="mb-2">
    <Demo Variants="@LoadingVariants">
        <ButtonLoadingCss />
    </Demo>
</div>

<DocsHeading Title="API reference" />
@foreach (var part in ButtonApi.Parts)
{
    <ApiPartReference Part="part" />
}

@code {
    private const string AnatomyCode =
        """
        @using Blazix.BaseUI.Button

        <Button>Submit</Button>
        """;

    private const string CustomTagCode =
        """
        @using Blazix.BaseUI
        @using Blazix.BaseUI.Button

        <Button NativeButton="false" Render="@RenderAsDiv">
            Button that can contain complex children
        </Button>

        @code {
            private RenderFragment<RenderProps<ButtonState>> RenderAsDiv => props =>
                RenderUtilities.CreateElement("div", props);
        }
        """;

    private static readonly IReadOnlyList<DemoVariant> HeroVariants =
    [
        new("CSS",
        [
            new DemoFile("Button.razor", "xml", "Components.Demos.Button.Hero.Css.ButtonHeroCss.razor"),
            new DemoFile("button.css", "css", "wwwroot.demos.button.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("Button.razor", "xml", "Components.Demos.Button.Hero.Tailwind.ButtonHeroTailwind.razor"),
        ]),
    ];

    private static readonly IReadOnlyList<DemoVariant> LoadingVariants =
    [
        new("CSS",
        [
            new DemoFile("Button.razor", "xml", "Components.Demos.Button.Loading.Css.ButtonLoadingCss.razor"),
            new DemoFile("button.css", "css", "wwwroot.demos.button.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("Button.razor", "xml", "Components.Demos.Button.Loading.Tailwind.ButtonLoadingTailwind.razor"),
        ]),
    ];
}
