@page "/components/switch"

<PageTitle>Switch · Blazix.BaseUI</PageTitle>

<DocsPageIntro Eyebrow="Components"
               Title="Switch"
               Subtitle="A control that indicates whether a setting is on or off."
               MarkdownHref="/components/switch.md" />

<div class="mt-8">
    <Demo Variants="@HeroVariants">
        <SwitchHeroCss />
    </Demo>
</div>

<DocsHeading Title="Usage guidelines" />
<ul class="mb-6 max-w-3xl list-disc space-y-2 pl-5 text-sm leading-6 text-slate-700 dark:text-slate-200">
    <li>Switch controls need an accessible name. Use a wrapping <code class="@LiquidGlassClasses.CodeInline">label</code>, sibling label with <code class="@LiquidGlassClasses.CodeInline">NativeButton</code>, or Field integration.</li>
</ul>

<DocsHeading Title="Anatomy" />
<CodeBlock Code="@AnatomyCode" />

<DocsHeading Title="Examples" />

<DocsHeading Level="3" Title="Labeling a switch" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    An enclosing label is the simplest pattern when the root renders as its default span.
</p>
<CodeBlock Code="@WrappingLabelCode" />

<DocsHeading Level="3" Title="Rendering as a native button" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Prefer a native button for sibling labels that use <code class="@LiquidGlassClasses.CodeInline">for</code> and <code class="@LiquidGlassClasses.CodeInline">id</code>.
</p>
<CodeBlock Code="@NativeButtonCode" />
<p class="mt-3 mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Use a render callback for native buttons inside wrapping labels so the hidden input remains outside invalid label/button nesting.
</p>
<CodeBlock Code="@RenderCallbackCode" />

<DocsHeading Level="3" Title="Form integration" />
<p class="mb-3 max-w-3xl text-sm leading-6 text-slate-700 dark:text-slate-200">
    Field and Form provide labels, names, validation, and submitted values.
</p>
<CodeBlock Code="@FormIntegrationCode" />

<DocsHeading Title="API reference" />
@foreach (var part in SwitchApi.Parts)
{
    <ApiPartReference Part="part" />
}

@code {
    private const string AnatomyCode =
        """
        @using Blazix.BaseUI.Switch

        <SwitchRoot>
            <SwitchThumb />
        </SwitchRoot>
        """;

    private const string WrappingLabelCode =
        """
        <label>
            <SwitchRoot />
            Notifications
        </label>
        """;

    private const string NativeButtonCode =
        """
        <div>
            <label for="notifications-switch">Notifications</label>
            <SwitchRoot id="notifications-switch" NativeButton="true">
                <SwitchThumb />
            </SwitchRoot>
        </div>
        """;

    private const string RenderCallbackCode =
        """
        @using Blazix.BaseUI
        @using Blazix.BaseUI.Switch
        @using Microsoft.AspNetCore.Components.Rendering

        <SwitchRoot NativeButton="true" Render="@RenderWrappedButton" />

        @code {
            private RenderFragment<RenderProps<SwitchRootState>> RenderWrappedButton => props => builder =>
            {
                builder.OpenElement(0, "label");
                builder.OpenElement(1, "button");
                builder.AddMultipleAttributes(2, props.Attributes);
                if (props.ElementReferenceCallback is not null)
                {
                    builder.AddElementReferenceCapture(3, props.ElementReferenceCallback);
                }
                builder.CloseElement();
                builder.AddContent(4, "Notifications");
                builder.CloseElement();
            };
        }
        """;

    private const string FormIntegrationCode =
        """
        @using Blazix.BaseUI.Field
        @using Blazix.BaseUI.Form
        @using Blazix.BaseUI.Switch

        <Form Model="@model">
            <FieldRoot Name="notifications">
                <FieldLabel>
                    <SwitchRoot />
                    Notifications
                </FieldLabel>
            </FieldRoot>
        </Form>

        @code {
            private readonly object model = new();
        }
        """;

    private static readonly IReadOnlyList<DemoVariant> HeroVariants =
    [
        new("CSS",
        [
            new DemoFile("Switch.razor", "xml", "Components.Demos.Switch.Hero.Css.SwitchHeroCss.razor"),
            new DemoFile("switch.css", "css", "wwwroot.demos.switch.css"),
        ]),
        new("Tailwind",
        [
            new DemoFile("Switch.razor", "xml", "Components.Demos.Switch.Hero.Tailwind.SwitchHeroTailwind.razor"),
        ]),
    ];
}
