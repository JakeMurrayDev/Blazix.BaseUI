<CheckboxGroup aria-labelledby="permissions-tailwind-label"
               Value="@selectedPermissions"
               ValueChanged="@(value => selectedPermissions = value)"
               AllValues="@AllPermissions"
               class="ml-4 flex flex-col items-start gap-1 text-slate-950 dark:text-white">
    <label class="-ml-4 flex items-center gap-2 text-sm font-normal" id="permissions-tailwind-label">
        <CheckboxRoot Parent="true"
                      class="flex size-4 shrink-0 items-center justify-center rounded-none border border-slate-950 bg-white p-0 text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-950 data-[checked]:bg-slate-950 data-[indeterminate]:bg-slate-950 dark:border-white dark:bg-slate-950 dark:text-slate-950 dark:focus-visible:outline-white dark:data-[checked]:bg-white dark:data-[indeterminate]:bg-white">
            <CheckboxIndicator class="flex data-[unchecked]:hidden">
                @if (IsParentIndeterminate)
                {
                    <svg class="block size-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" aria-hidden="true">
                        <path d="M3 8H13" />
                    </svg>
                }
                else
                {
                    <svg class="block size-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" aria-hidden="true">
                        <path d="M2.5 8.5 6.5 12.5 13.5 3.5" />
                    </svg>
                }
            </CheckboxIndicator>
        </CheckboxRoot>
        Release readiness
    </label>

    @foreach (var option in Options)
    {
        <label class="flex items-center gap-2 text-sm font-normal">
            <CheckboxRoot Value="@option.Value"
                          class="flex size-4 shrink-0 items-center justify-center rounded-none border border-slate-950 bg-white p-0 text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-950 data-[checked]:bg-slate-950 data-[indeterminate]:bg-slate-950 dark:border-white dark:bg-slate-950 dark:text-slate-950 dark:focus-visible:outline-white dark:data-[checked]:bg-white dark:data-[indeterminate]:bg-white">
                <CheckboxIndicator class="flex data-[unchecked]:hidden">
                    <svg class="block size-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" aria-hidden="true">
                        <path d="M2.5 8.5 6.5 12.5 13.5 3.5" />
                    </svg>
                </CheckboxIndicator>
            </CheckboxRoot>
            @option.Label
        </label>
    }
</CheckboxGroup>

@code {
    private static readonly string[] AllPermissions = ["api", "docs", "tests"];

    private static readonly (string Value, string Label)[] Options =
    [
        ("api", "API reviewed"),
        ("docs", "Docs updated"),
        ("tests", "Tests passing"),
    ];

    private string[] selectedPermissions = ["api"];

    private bool IsParentIndeterminate =>
        selectedPermissions.Length > 0 && selectedPermissions.Length < AllPermissions.Length;
}
