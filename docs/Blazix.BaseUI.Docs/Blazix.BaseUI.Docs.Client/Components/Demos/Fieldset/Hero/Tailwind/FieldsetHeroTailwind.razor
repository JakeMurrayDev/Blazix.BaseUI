<FieldsetRoot class="m-0 flex w-full max-w-64 flex-col gap-4 border-0 p-0">
    <FieldsetLegend class="border-b border-slate-950 text-base font-bold text-slate-950 dark:border-white dark:text-white">
        Billing details
    </FieldsetLegend>

    <FieldRoot class="flex flex-col items-start gap-1">
        <FieldLabel class="text-sm font-bold text-slate-950 dark:text-white">
            Company
        </FieldLabel>
        <FieldControl TValue="string"
                      placeholder="Enter company name"
                      class="h-8 w-full border border-slate-950 bg-white px-2 text-sm font-normal text-slate-950 placeholder:text-slate-500 focus:outline focus:outline-2 focus:-outline-offset-1 focus:outline-slate-950 dark:border-white dark:bg-slate-950 dark:text-white dark:placeholder:text-slate-400 dark:focus:outline-white" />
    </FieldRoot>

    <FieldRoot class="flex flex-col items-start gap-1">
        <FieldLabel class="text-sm font-bold text-slate-950 dark:text-white">
            Tax ID
        </FieldLabel>
        <FieldControl TValue="string"
                      placeholder="Enter fiscal number"
                      class="h-8 w-full border border-slate-950 bg-white px-2 text-sm font-normal text-slate-950 placeholder:text-slate-500 focus:outline focus:outline-2 focus:-outline-offset-1 focus:outline-slate-950 dark:border-white dark:bg-slate-950 dark:text-white dark:placeholder:text-slate-400 dark:focus:outline-white" />
    </FieldRoot>
</FieldsetRoot>
