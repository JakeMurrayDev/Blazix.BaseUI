<FieldsetRoot class="blx-fieldset">
    <FieldsetLegend class="blx-fieldset-legend">
        Billing details
    </FieldsetLegend>

    <FieldRoot class="blx-fieldset-field">
        <FieldLabel class="blx-fieldset-label">Company</FieldLabel>
        <FieldControl TValue="string"
                      placeholder="Enter company name"
                      class="blx-fieldset-input" />
    </FieldRoot>

    <FieldRoot class="blx-fieldset-field">
        <FieldLabel class="blx-fieldset-label">Tax ID</FieldLabel>
        <FieldControl TValue="string"
                      placeholder="Enter fiscal number"
                      class="blx-fieldset-input" />
    </FieldRoot>
</FieldsetRoot>
