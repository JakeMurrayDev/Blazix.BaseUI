@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<NavigationMenuRoot class="blx-nav-menu-root">
    <NavigationMenuList class="blx-nav-menu-list">
        <NavigationMenuItem>
            <NavigationMenuTrigger class="blx-nav-menu-trigger">
                Product
                <NavigationMenuIcon class="blx-nav-menu-icon">
                    @CaretDownIcon
                </NavigationMenuIcon>
            </NavigationMenuTrigger>
            <NavigationMenuContent class="blx-nav-menu-content blx-nav-menu-product-content">
                <NavigationMenuRoot class="blx-nav-menu-submenu-root"
                                    Orientation="@NestedOrientation"
                                    DefaultValue="developers">
                    <div class="blx-nav-menu-submenu-layout">
                        <NavigationMenuList class="blx-nav-menu-submenu-list">
                            @foreach (var menu in AudienceMenus)
                            {
                                <NavigationMenuItem Value="@menu.Value" @key="menu.Value">
                                    <NavigationMenuTrigger class="blx-nav-menu-submenu-trigger">
                                        <span class="blx-nav-menu-submenu-label">@menu.Label</span>
                                        <span class="blx-nav-menu-submenu-hint">@menu.Hint</span>
                                    </NavigationMenuTrigger>
                                    <NavigationMenuContent class="blx-nav-menu-submenu-content">
                                        <div>
                                            <h4 class="blx-nav-menu-submenu-title">@menu.Title</h4>
                                            <p class="blx-nav-menu-submenu-description">@menu.Description</p>
                                        </div>
                                        <ul class="blx-nav-menu-link-list">
                                            @foreach (var link in menu.Links)
                                            {
                                                <li @key="link.Href">
                                                    <NavigationMenuLink class="blx-nav-menu-link-card" Href="@link.Href">
                                                        <h5 class="blx-nav-menu-link-title">@link.Title</h5>
                                                        <p class="blx-nav-menu-link-description">@link.Description</p>
                                                    </NavigationMenuLink>
                                                </li>
                                            }
                                        </ul>
                                    </NavigationMenuContent>
                                </NavigationMenuItem>
                            }
                        </NavigationMenuList>

                        <NavigationMenuViewport class="blx-nav-menu-submenu-viewport" />
                    </div>
                </NavigationMenuRoot>
            </NavigationMenuContent>
        </NavigationMenuItem>

        <NavigationMenuItem>
            <NavigationMenuTrigger class="blx-nav-menu-trigger">
                Learn
                <NavigationMenuIcon class="blx-nav-menu-icon">
                    @CaretDownIcon
                </NavigationMenuIcon>
            </NavigationMenuTrigger>
            <NavigationMenuContent class="blx-nav-menu-content blx-nav-menu-guides-content">
                <div class="blx-nav-menu-guides-panel">
                    <div>
                        <h4 class="blx-nav-menu-submenu-title">@GuidesPanel.Title</h4>
                        <p class="blx-nav-menu-submenu-description">@GuidesPanel.Description</p>
                    </div>
                    <ul class="blx-nav-menu-link-list">
                        @foreach (var link in GuideLinks)
                        {
                            <li @key="link.Href">
                                <NavigationMenuLink class="blx-nav-menu-link-card" Href="@link.Href">
                                    <h5 class="blx-nav-menu-link-title">@link.Title</h5>
                                    <p class="blx-nav-menu-link-description">@link.Description</p>
                                </NavigationMenuLink>
                            </li>
                        }
                    </ul>
                </div>
            </NavigationMenuContent>
        </NavigationMenuItem>

        <NavigationMenuItem>
            <NavigationMenuLink class="blx-nav-menu-trigger" Href="/overview/releases">
                Releases
            </NavigationMenuLink>
        </NavigationMenuItem>

        <NavigationMenuItem>
            <NavigationMenuLink class="blx-nav-menu-trigger" Href="https://github.com/JakeMurrayDev/Blazix.BaseUI">
                GitHub
            </NavigationMenuLink>
        </NavigationMenuItem>
    </NavigationMenuList>

    <NavigationMenuPortal>
        <NavigationMenuPositioner class="blx-nav-menu-positioner"
                                  SideOffset="10"
                                  CollisionPadding="20"
                                  CollisionAvoidance="@NoSideCollision">
            <NavigationMenuPopup class="blx-nav-menu-popup">
                <NavigationMenuArrow class="blx-nav-menu-arrow blx-nav-menu-arrow-nested-inline" />
                <NavigationMenuViewport class="blx-nav-menu-viewport" />
            </NavigationMenuPopup>
        </NavigationMenuPositioner>
    </NavigationMenuPortal>
</NavigationMenuRoot>

@code {
    private bool isDesktop = true;
    private readonly string mediaQuerySubscriptionId = Guid.NewGuid().ToString("N");
    private DotNetObjectReference<NavigationMenuNestedInlineCss>? dotNetReference;

    private NavigationMenuOrientation NestedOrientation => isDesktop
        ? NavigationMenuOrientation.Vertical
        : NavigationMenuOrientation.Horizontal;

    private static readonly CollisionAvoidance NoSideCollision = new()
    {
        Side = CollisionAvoidanceSideMode.None
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        dotNetReference = DotNetObjectReference.Create(this);
        var matches = await JSRuntime.InvokeAsync<bool>(
            "blazixDocs.watchMediaQuery",
            mediaQuerySubscriptionId,
            "(min-width: 700px)",
            dotNetReference);

        ApplyMediaQueryMatch(matches);
    }

    public async ValueTask DisposeAsync()
    {
        if (dotNetReference is null)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("blazixDocs.unwatchMediaQuery", mediaQuerySubscriptionId);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
        finally
        {
            dotNetReference.Dispose();
        }
    }

    [JSInvokable]
    public Task OnMediaQueryChanged(bool matches)
    {
        ApplyMediaQueryMatch(matches);
        return Task.CompletedTask;
    }

    private void ApplyMediaQueryMatch(bool matches)
    {
        if (matches == isDesktop)
        {
            return;
        }

        isDesktop = matches;
        StateHasChanged();
    }

    private static readonly IReadOnlyList<AudienceMenu> AudienceMenus =
    [
        new("developers", "Developers", "Go from idea to UI faster.", "Build product UI without giving up control",
        "Start with accessible parts and shape them to your app instead of working around a preset design system.",
        [
            new("/overview/quick-start", "Quick start", "Install Base UI and get your first interactive primitive on screen fast."),
            new("/handbook/composition", "Composition", "Wrap and combine parts to match your product structure without hacks."),
        ]),
        new("systems", "Design Systems", "Keep patterns aligned across teams.", "Turn shared standards into working components",
        "Connect tokens, states, and accessibility rules once, then give every product team the same solid starting point.",
        [
            new("/handbook/styling", "Styling", "Map tokens and component states to your own CSS or utility setup."),
            new("/overview/accessibility", "Accessibility", "Review keyboard support and semantic defaults before anything ships."),
            new("/components/tooltip", "Tooltip", "Set one clear pattern for lightweight help, hints, and field guidance."),
            new("/components/popover", "Popover", "Handle richer anchored panels like menus, inspectors, and onboarding."),
        ]),
        new("managers", "Engineering Leads", "Roll out shared UI without drag.", "Give squads clear defaults and room to move",
        "Use the docs to align on quality bars, upgrades, and extension points while still leaving teams space to customize.",
        [
            new("/overview/releases", "Releases", "Track version changes and migration notes before upgrades surprise teams."),
            new("/handbook/typescript", "TypeScript", "See how the primitives type custom wrappers and shared abstractions."),
            new("/handbook/forms", "Forms", "Standardize validation and field patterns teams reach for constantly."),
        ]),
        new("startups", "Startups", "Ship polished basics while things change.", "Get sturdy UI foundations in place early",
        "Cover the hard interaction details now so your team can spend more time on the product ideas that actually differentiate you.",
        [
            new("/overview/quick-start", "Quick start", "Get the package installed and your first component working in minutes."),
            new("/components/menu", "Menu", "Add action menus with keyboard support and focus handling already done."),
            new("/components/dialog", "Dialog", "Launch settings or upgrade flows without rebuilding focus management."),
        ]),
    ];

    private static readonly PanelCopy GuidesPanel = new(
        "Where teams usually start",
        "These are the docs people reach for first when they are turning a prototype into shared UI.");

    private static readonly IReadOnlyList<NavigationLink> GuideLinks =
    [
        new("/overview/accessibility", "Accessibility handbook", "Take a practical pass over focus order, semantics, and keyboard support."),
        new("/handbook/composition", "Composition handbook", "Learn when to wrap parts, share behavior, and expose flexible APIs."),
        new("/handbook/styling", "Styling handbook", "Apply tokens and state styles without fighting the underlying markup."),
    ];

    private readonly record struct AudienceMenu(
        string Value,
        string Label,
        string Hint,
        string Title,
        string Description,
        IReadOnlyList<NavigationLink> Links);

    private readonly record struct NavigationLink(string Href, string Title, string Description);

    private readonly record struct PanelCopy(string Title, string Description);
}

@code {
    private static RenderFragment CaretDownIcon => builder =>
    {
        builder.OpenElement(0, "svg");
        builder.AddAttribute(1, "width", "16");
        builder.AddAttribute(2, "height", "16");
        builder.AddAttribute(3, "viewBox", "0 0 16 16");
        builder.AddAttribute(4, "fill", "currentColor");
        builder.AddAttribute(5, "style", "display:block");
        builder.AddAttribute(6, "aria-hidden", "true");
        builder.AddAttribute(7, "focusable", "false");
        builder.OpenElement(8, "path");
        builder.AddAttribute(9, "d", "M12 6H4l4 4.5z");
        builder.CloseElement();
        builder.CloseElement();
    };
}
