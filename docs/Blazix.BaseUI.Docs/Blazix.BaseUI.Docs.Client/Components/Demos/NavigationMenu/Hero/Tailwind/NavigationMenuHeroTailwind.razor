<NavigationMenuRoot class="min-w-max text-neutral-950 dark:text-white">
    <NavigationMenuList class="relative flex gap-px">
        <NavigationMenuItem>
            <NavigationMenuTrigger class="@TriggerClassName">
                Overview
                <NavigationMenuIcon class="flex items-center justify-center transition-transform duration-200 ease-[ease] data-popup-open:rotate-180">
                    @CaretDownIcon
                </NavigationMenuIcon>
            </NavigationMenuTrigger>
            <NavigationMenuContent class="@ContentClassName">
                <ul class="m-0 grid list-none grid-cols-2 p-0 max-[500px]:grid-cols-1">
                    @foreach (var item in OverviewLinks)
                    {
                        <li @key="item.Href">
                            <NavigationMenuLink Href="@item.Href" class="@LinkCardClassName">
                                <h3 class="m-0 mb-1 text-sm font-normal leading-4">@item.Title</h3>
                                <p class="m-0 text-sm leading-5 text-neutral-500 dark:text-neutral-400">@item.Description</p>
                            </NavigationMenuLink>
                        </li>
                    }
                </ul>
            </NavigationMenuContent>
        </NavigationMenuItem>

        <NavigationMenuItem Value="handbook">
            <NavigationMenuTrigger class="@TriggerClassName">
                Handbook
                <NavigationMenuIcon class="flex items-center justify-center transition-transform duration-200 ease-[ease] data-popup-open:rotate-180">
                    @CaretDownIcon
                </NavigationMenuIcon>
            </NavigationMenuTrigger>
            <NavigationMenuContent class="@ContentClassName">
                <ul class="m-0 flex max-w-[400px] list-none flex-col justify-center p-0">
                    @foreach (var item in HandbookLinks)
                    {
                        <li @key="item.Href">
                            <NavigationMenuLink Href="@item.Href" class="@LinkCardClassName">
                                <h3 class="m-0 mb-1 text-sm font-normal leading-4">@item.Title</h3>
                                <p class="m-0 text-sm leading-5 text-neutral-500 dark:text-neutral-400">@item.Description</p>
                            </NavigationMenuLink>
                        </li>
                    }
                </ul>
            </NavigationMenuContent>
        </NavigationMenuItem>

        <NavigationMenuItem>
            <NavigationMenuLink class="@TriggerClassName" Href="https://github.com/JakeMurrayDev/Blazix.BaseUI">
                GitHub
            </NavigationMenuLink>
        </NavigationMenuItem>
    </NavigationMenuList>

    <NavigationMenuPortal>
        <NavigationMenuPositioner SideOffset="10"
                                  CollisionPadding="20"
                                  CollisionAvoidance="@NoSideCollision"
                                  class="@PositionerClassName"
                                  style="--duration: 0.35s; --easing: cubic-bezier(0.22, 1, 0.36, 1)">
            <NavigationMenuPopup class="@PopupClassName">
                <NavigationMenuArrow class="@ArrowClassName" />
                <NavigationMenuViewport class="relative h-full w-full overflow-hidden" />
            </NavigationMenuPopup>
        </NavigationMenuPositioner>
    </NavigationMenuPortal>
</NavigationMenuRoot>

@code {
    private const string TriggerClassName =
        "flex h-8 items-center justify-center gap-1.5 bg-transparent px-2 text-sm font-normal text-neutral-950 no-underline select-none min-[501px]:px-3 hover:bg-neutral-100 data-popup-open:bg-neutral-100 focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-neutral-950 dark:text-white dark:hover:bg-neutral-800 dark:data-popup-open:bg-neutral-800 dark:focus-visible:outline-white";

    private const string ContentClassName =
        "h-full w-[calc(100vw_-_40px)] p-2 min-[500px]:w-max min-[500px]:max-w-[400px] transition-[opacity,transform,translate] duration-[var(--duration)] ease-[var(--easing)] data-starting-style:opacity-0 data-ending-style:opacity-0 data-starting-style:data-[activation-direction=left]:translate-x-[-50%] data-starting-style:data-[activation-direction=right]:translate-x-[50%] data-ending-style:data-[activation-direction=left]:translate-x-[50%] data-ending-style:data-[activation-direction=right]:translate-x-[-50%]";

    private const string LinkCardClassName =
        "relative block h-full w-full border-0 bg-transparent p-2 text-left text-inherit no-underline hover:bg-neutral-100 data-popup-open:bg-neutral-100 focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-neutral-950 dark:hover:bg-neutral-800 dark:data-popup-open:bg-neutral-800 dark:focus-visible:outline-white";

    private const string PositionerClassName =
        "h-[var(--positioner-height)] w-[var(--positioner-width)] max-w-[var(--available-width)] transition-[top,left,right,bottom] duration-[var(--duration)] ease-[var(--easing)] before:absolute before:content-[''] data-instant:transition-none data-[side=bottom]:before:left-0 data-[side=bottom]:before:right-0 data-[side=bottom]:before:top-[-10px] data-[side=bottom]:before:h-2.5 data-[side=top]:before:left-0 data-[side=top]:before:right-0 data-[side=top]:before:bottom-[-10px] data-[side=top]:before:h-2.5 data-[side=left]:before:bottom-0 data-[side=left]:before:right-[-10px] data-[side=left]:before:top-0 data-[side=left]:before:w-2.5 data-[side=right]:before:bottom-0 data-[side=right]:before:left-[-10px] data-[side=right]:before:top-0 data-[side=right]:before:w-2.5";

    private const string PopupClassName =
        "relative h-[var(--popup-height)] w-[var(--popup-width)] origin-[var(--transform-origin)] border border-neutral-950 bg-white text-neutral-950 shadow-[0.25rem_0.25rem_0] shadow-black/10 outline-none transition-[opacity,transform,width,height,scale] duration-[var(--duration)] ease-[var(--easing)] data-starting-style:scale-90 data-starting-style:opacity-0 data-ending-style:scale-90 data-ending-style:opacity-0 data-ending-style:duration-150 data-ending-style:ease-[ease] dark:border-white dark:bg-neutral-950 dark:text-white dark:shadow-none";

    private const string ArrowClassName =
        "relative block h-1.5 w-3 overflow-clip transition-[left,right] duration-[var(--duration)] ease-[var(--easing)] before:absolute before:bottom-0 before:left-1/2 before:block before:h-[8.485px] before:w-[8.485px] before:-translate-x-1/2 before:translate-y-1/2 before:rotate-45 before:border before:border-neutral-950 before:bg-white before:content-[''] data-[side=bottom]:top-[-6px] data-[side=top]:bottom-[-6px] data-[side=top]:rotate-180 data-[side=left]:right-[-9px] data-[side=left]:rotate-90 data-[side=right]:left-[-9px] data-[side=right]:-rotate-90 dark:before:border-white dark:before:bg-neutral-950";

    private static readonly CollisionAvoidance NoSideCollision = new()
    {
        Side = CollisionAvoidanceSideMode.None
    };

    private static readonly IReadOnlyList<NavigationLink> OverviewLinks =
    [
        new("/overview/quick-start", "Quick Start", "Install and assemble your first component."),
        new("/overview/accessibility", "Accessibility", "Learn how Blazix.BaseUI builds accessible components."),
        new("/overview/releases", "Releases", "See what is new in the latest Base UI versions."),
        new("/overview/about", "About", "Learn more about Base UI and its mission."),
    ];

    private static readonly IReadOnlyList<NavigationLink> HandbookLinks =
    [
        new("/handbook/styling", "Styling", "Base UI components can be styled with plain CSS, Tailwind CSS, CSS-in-JS, or CSS Modules."),
        new("/handbook/animation", "Animation", "Base UI components can be animated with CSS transitions, CSS animations, or JavaScript libraries."),
        new("/handbook/composition", "Composition", "Base UI components can be replaced and composed with your own existing components."),
    ];

    private readonly record struct NavigationLink(string Href, string Title, string Description);
}

@code {
    private static RenderFragment CaretDownIcon => builder =>
    {
        builder.OpenElement(0, "svg");
        builder.AddAttribute(1, "width", "16");
        builder.AddAttribute(2, "height", "16");
        builder.AddAttribute(3, "viewBox", "0 0 16 16");
        builder.AddAttribute(4, "fill", "currentColor");
        builder.AddAttribute(5, "style", "display:block");
        builder.AddAttribute(6, "aria-hidden", "true");
        builder.AddAttribute(7, "focusable", "false");
        builder.OpenElement(8, "path");
        builder.AddAttribute(9, "d", "M12 6H4l4 4.5z");
        builder.CloseElement();
        builder.CloseElement();
    };
}
