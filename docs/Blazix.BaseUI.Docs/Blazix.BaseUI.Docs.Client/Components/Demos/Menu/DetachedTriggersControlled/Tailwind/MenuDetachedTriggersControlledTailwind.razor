<div class="flex flex-wrap items-center gap-2">
    <MenuTypedTrigger TPayload="string" id="menu-tailwind-controlled-library" Handle="controlledMenu" Payload="@("library")" class="box-border inline-flex h-8 items-center justify-center gap-1.5 border border-slate-950 bg-white px-3 text-sm leading-none text-slate-950 outline-0 select-none hover:bg-slate-100 active:bg-slate-200 data-[popup-open]:bg-slate-100 focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-slate-950 dark:border-white dark:bg-slate-950 dark:text-white dark:hover:bg-slate-800 dark:active:bg-slate-700 dark:data-[popup-open]:bg-slate-800 dark:focus-visible:outline-white">Library</MenuTypedTrigger>
    <MenuTypedTrigger TPayload="string" id="menu-tailwind-controlled-playback" Handle="controlledMenu" Payload="@("playback")" class="box-border inline-flex h-8 items-center justify-center gap-1.5 border border-slate-950 bg-white px-3 text-sm leading-none text-slate-950 outline-0 select-none hover:bg-slate-100 active:bg-slate-200 data-[popup-open]:bg-slate-100 focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-slate-950 dark:border-white dark:bg-slate-950 dark:text-white dark:hover:bg-slate-800 dark:active:bg-slate-700 dark:data-[popup-open]:bg-slate-800 dark:focus-visible:outline-white">Playback</MenuTypedTrigger>
    <MenuTypedTrigger TPayload="string" id="menu-tailwind-controlled-share" Handle="controlledMenu" Payload="@("share")" class="box-border inline-flex h-8 items-center justify-center gap-1.5 border border-slate-950 bg-white px-3 text-sm leading-none text-slate-950 outline-0 select-none hover:bg-slate-100 active:bg-slate-200 data-[popup-open]:bg-slate-100 focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-slate-950 dark:border-white dark:bg-slate-950 dark:text-white dark:hover:bg-slate-800 dark:active:bg-slate-700 dark:data-[popup-open]:bg-slate-800 dark:focus-visible:outline-white">Share</MenuTypedTrigger>
    <button type="button" class="box-border inline-flex h-8 items-center justify-center gap-1.5 border border-slate-950 bg-white px-3 text-sm leading-none text-slate-950 outline-0 select-none hover:bg-slate-100 active:bg-slate-200 focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-slate-950 dark:border-white dark:bg-slate-950 dark:text-white dark:hover:bg-slate-800 dark:active:bg-slate-700 dark:focus-visible:outline-white" @onclick="OpenPlayback">Open playback (controlled)</button>
</div>

<MenuRoot Handle="controlledMenu" Open="@isOpen" OpenChanged="SetOpen" TriggerId="@activeTriggerId" OnOpenChange="HandleOpenChange" Context="menu">
    <MenuPortal>
        <MenuPositioner SideOffset="8" class="outline-0">
            <MenuPopup class="relative box-border border border-slate-950 bg-white py-1 text-slate-950 shadow-[0.25rem_0.25rem_0_rgba(0,0,0,0.12)] outline-0 transition-[transform,opacity] duration-100 ease-out [transform-origin:var(--transform-origin)] data-[ending-style]:scale-[0.98] data-[ending-style]:opacity-0 data-[starting-style]:scale-[0.98] data-[starting-style]:opacity-0 dark:border-white dark:bg-slate-950 dark:text-white dark:shadow-none">
                @foreach (var item in GetControlledItems(menu.Payload as string))
                {
                    <MenuItem class="relative z-0 flex cursor-default select-none px-4 py-2 pr-8 text-sm leading-4 outline-none data-[highlighted]:text-white data-[disabled]:text-slate-500 data-[highlighted]:before:absolute data-[highlighted]:before:inset-x-1 data-[highlighted]:before:inset-y-0 data-[highlighted]:before:-z-10 data-[highlighted]:before:bg-slate-950 dark:data-[highlighted]:text-slate-950 dark:data-[disabled]:text-slate-400 dark:data-[highlighted]:before:bg-white">@item</MenuItem>
                }
            </MenuPopup>
        </MenuPositioner>
    </MenuPortal>
</MenuRoot>

@code {
    private static readonly IReadOnlyDictionary<string, string[]> ItemGroups = new Dictionary<string, string[]>
    {
        ["library"] = ["Add to library", "Add to favorites"],
        ["playback"] = ["Play", "Add to queue"],
        ["share"] = ["Share", "Copy link"],
    };

    private readonly MenuHandle<string> controlledMenu = MenuHandleFactory.CreateHandle<string>();
    private bool isOpen;
    private string? activeTriggerId;

    private void SetOpen(bool open) => isOpen = open;

    private Task HandleOpenChange(MenuOpenChangeEventArgs args)
    {
        isOpen = args.Open;
        if (args.Open && args.Payload is string payload)
        {
            activeTriggerId = $"menu-tailwind-controlled-{payload}";
        }

        return Task.CompletedTask;
    }

    private void OpenPlayback()
    {
        activeTriggerId = "menu-tailwind-controlled-playback";
        isOpen = true;
    }

    private static IReadOnlyList<string> GetControlledItems(string? key)
    {
        return key is not null && ItemGroups.TryGetValue(key, out var items)
            ? items
            : ItemGroups["library"];
    }
}
