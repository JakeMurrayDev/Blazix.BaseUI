<MenuRoot Context="_">
    <MenuTrigger class="@ButtonClass">
        Song
        <svg class="block h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M12 6H4l4 4.5z" />
        </svg>
    </MenuTrigger>
    <MenuPortal>
        <MenuPositioner SideOffset="8"
                        class="outline-none">
            <MenuPopup class="@PopupClass">
                <MenuItem class="@ItemClass">Add to Library</MenuItem>
                <MenuSubmenuRoot>
                    <MenuSubmenuTrigger class="@SubmenuTriggerClass">
                        Add to Playlist
                        <svg class="block h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                            <path d="M6 12V4l4.5 4z" />
                        </svg>
                    </MenuSubmenuTrigger>
                    <MenuPortal>
                        <MenuPositioner SideOffset="-4"
                                        AlignOffset="-4"
                                        class="outline-none">
                            <MenuPopup class="@PopupClass">
                                <MenuItem class="@ItemClass">Get Up!</MenuItem>
                                <MenuItem class="@ItemClass">Inside Out</MenuItem>
                                <MenuItem class="@ItemClass">Night Beats</MenuItem>
                                <Blazix.BaseUI.Separator.Separator class="mx-1 my-1 h-px bg-slate-950 dark:bg-white" />
                                <MenuItem class="@ItemClass">New playlist...</MenuItem>
                            </MenuPopup>
                        </MenuPositioner>
                    </MenuPortal>
                </MenuSubmenuRoot>
                <Blazix.BaseUI.Separator.Separator class="mx-1 my-1 h-px bg-slate-950 dark:bg-white" />
                <MenuItem class="@ItemClass">Play Next</MenuItem>
                <MenuItem class="@ItemClass">Play Last</MenuItem>
                <Blazix.BaseUI.Separator.Separator class="mx-1 my-1 h-px bg-slate-950 dark:bg-white" />
                <MenuItem class="@ItemClass">Favorite</MenuItem>
                <MenuItem class="@ItemClass">Share</MenuItem>
            </MenuPopup>
        </MenuPositioner>
    </MenuPortal>
</MenuRoot>

@code {
    private const string ButtonClass =
        "box-border flex h-8 items-center justify-center gap-1.5 rounded-none border border-slate-950 bg-white py-0 pl-3 pr-2 text-sm font-normal leading-none text-slate-950 whitespace-nowrap outline-none select-none hover:bg-slate-100 active:bg-slate-200 focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-slate-950 disabled:border-slate-500 disabled:text-slate-500 data-[disabled]:border-slate-500 data-[disabled]:text-slate-500 data-[popup-open]:bg-slate-100 dark:border-white dark:bg-slate-950 dark:text-white dark:hover:bg-slate-800 dark:active:bg-slate-700 dark:focus-visible:outline-white dark:disabled:border-slate-400 dark:disabled:text-slate-400 dark:data-[disabled]:border-slate-400 dark:data-[disabled]:text-slate-400 dark:data-[popup-open]:bg-slate-800";

    private const string PopupClass =
        "relative origin-[var(--transform-origin)] rounded-none border border-slate-950 bg-white py-1 text-slate-950 shadow-[0.25rem_0.25rem_0] shadow-black/10 outline-none transition-[scale,opacity] duration-100 ease-out data-[ending-style]:scale-[0.98] data-[ending-style]:opacity-0 data-[starting-style]:scale-[0.98] data-[starting-style]:opacity-0 dark:border-white dark:bg-slate-950 dark:text-white dark:shadow-none";

    private const string ItemClass =
        "relative z-0 flex cursor-default py-2 pl-4 pr-8 text-sm leading-4 outline-none select-none data-[disabled]:text-slate-500 data-[highlighted]:text-white data-[highlighted]:before:absolute data-[highlighted]:before:inset-x-1 data-[highlighted]:before:inset-y-0 data-[highlighted]:before:z-[-1] data-[highlighted]:before:bg-slate-950 data-[highlighted]:before:content-[''] dark:data-[disabled]:text-slate-400 dark:data-[highlighted]:text-slate-950 dark:data-[highlighted]:before:bg-white";

    private const string SubmenuTriggerClass =
        "relative z-0 flex cursor-default items-center justify-between gap-4 py-2 pl-4 pr-2 text-sm leading-4 outline-none select-none data-[disabled]:text-slate-500 data-[highlighted]:text-white data-[highlighted]:before:absolute data-[highlighted]:before:inset-x-1 data-[highlighted]:before:inset-y-0 data-[highlighted]:before:z-[-1] data-[highlighted]:before:bg-slate-950 data-[highlighted]:before:content-[''] data-[popup-open]:before:absolute data-[popup-open]:before:inset-x-1 data-[popup-open]:before:inset-y-0 data-[popup-open]:before:z-[-1] data-[popup-open]:before:bg-slate-100 data-[popup-open]:before:content-[''] dark:data-[disabled]:text-slate-400 dark:data-[highlighted]:text-slate-950 dark:data-[highlighted]:before:bg-white dark:data-[popup-open]:before:bg-slate-800 dark:data-[highlighted]:data-[popup-open]:before:bg-white";
}
