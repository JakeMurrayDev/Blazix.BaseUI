            <path d="M12 6H4l4 4.5z" />
        </svg>
    </MenuTrigger>
    <MenuPortal>
        <MenuPositioner SideOffset="8"
                        class="blx-menu-positioner">
            <MenuPopup class="blx-menu-popup">
                <MenuItem class="blx-menu-item">Add to Library</MenuItem>
                <MenuSubmenuRoot>
                    <MenuSubmenuTrigger class="blx-menu-submenu-trigger">
