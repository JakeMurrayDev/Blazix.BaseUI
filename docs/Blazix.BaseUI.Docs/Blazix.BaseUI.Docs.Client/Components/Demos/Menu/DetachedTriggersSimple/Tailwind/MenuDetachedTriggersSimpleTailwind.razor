<MenuTrigger Handle="projectMenu"
             aria-label="Project actions"
             class="box-border flex h-8 w-8 items-center justify-center border border-slate-950 bg-white p-0 text-slate-950 outline-0 select-none hover:bg-slate-100 active:bg-slate-200 data-[popup-open]:bg-slate-100 disabled:border-slate-500 disabled:text-slate-500 data-[disabled]:border-slate-500 data-[disabled]:text-slate-500 focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-slate-950 dark:border-white dark:bg-slate-950 dark:text-white dark:hover:bg-slate-800 dark:active:bg-slate-700 dark:data-[popup-open]:bg-slate-800 dark:disabled:border-slate-400 dark:disabled:text-slate-400 dark:data-[disabled]:border-slate-400 dark:data-[disabled]:text-slate-400 dark:focus-visible:outline-white">
    <svg class="block h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <circle cx="3" cy="8" r="1" />
        <circle cx="8" cy="8" r="1" />
        <circle cx="13" cy="8" r="1" />
    </svg>
</MenuTrigger>

<MenuRoot Handle="projectMenu" Context="_">
    <MenuPortal>
        <MenuPositioner SideOffset="8" class="outline-0">
            <MenuPopup class="relative box-border border border-slate-950 bg-white py-1 text-slate-950 shadow-[0.25rem_0.25rem_0_rgba(0,0,0,0.12)] outline-0 transition-[transform,opacity] duration-100 ease-out [transform-origin:var(--transform-origin)] data-[ending-style]:scale-[0.98] data-[ending-style]:opacity-0 data-[starting-style]:scale-[0.98] data-[starting-style]:opacity-0 dark:border-white dark:bg-slate-950 dark:text-white dark:shadow-none">
                @foreach (var item in Items)
                {
                    if (item is null)
                    {
                        <Blazix.BaseUI.Separator.Separator class="m-1 h-px bg-slate-950 dark:bg-white" />
                    }
                    else
                    {
                        <MenuItem class="relative z-0 flex cursor-default select-none px-4 py-2 pr-8 text-sm leading-4 outline-none data-[highlighted]:text-white data-[disabled]:text-slate-500 data-[highlighted]:before:absolute data-[highlighted]:before:inset-x-1 data-[highlighted]:before:inset-y-0 data-[highlighted]:before:-z-10 data-[highlighted]:before:bg-slate-950 dark:data-[highlighted]:text-slate-950 dark:data-[disabled]:text-slate-400 dark:data-[highlighted]:before:bg-white">@item</MenuItem>
                    }
                }
            </MenuPopup>
        </MenuPositioner>
    </MenuPortal>
</MenuRoot>

@code {
    private static readonly IReadOnlyList<string?> Items =
    [
        "Rename",
        "Duplicate",
        "Move to folder",
        null,
        "Archive",
        "Delete",
    ];

    private readonly MenuHandle projectMenu = MenuHandleFactory.CreateHandle();
}
