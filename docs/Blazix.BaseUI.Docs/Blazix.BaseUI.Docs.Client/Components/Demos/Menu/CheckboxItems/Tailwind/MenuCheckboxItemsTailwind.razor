<MenuRoot Context="_">
    <MenuTrigger class="box-border flex h-8 items-center justify-center gap-1.5 border border-slate-950 bg-white py-0 pl-3 pr-2 text-sm leading-none text-slate-950 outline-0 select-none hover:bg-slate-100 active:bg-slate-200 data-[popup-open]:bg-slate-100 disabled:border-slate-500 disabled:text-slate-500 data-[disabled]:border-slate-500 data-[disabled]:text-slate-500 focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-slate-950 dark:border-white dark:bg-slate-950 dark:text-white dark:hover:bg-slate-800 dark:active:bg-slate-700 dark:data-[popup-open]:bg-slate-800 dark:disabled:border-slate-400 dark:disabled:text-slate-400 dark:data-[disabled]:border-slate-400 dark:data-[disabled]:text-slate-400 dark:focus-visible:outline-white">
        Workspace
        <svg class="block h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M12 6H4l4 4.5z" />
        </svg>
    </MenuTrigger>
    <MenuPortal>
        <MenuPositioner SideOffset="8"
                        class="outline-0">
            <MenuPopup class="relative box-border border border-slate-950 bg-white py-1 text-slate-950 shadow-[0.25rem_0.25rem_0_rgba(0,0,0,0.12)] outline-0 transition-[transform,opacity] duration-100 ease-out [transform-origin:var(--transform-origin)] data-[ending-style]:scale-[0.98] data-[ending-style]:opacity-0 data-[starting-style]:scale-[0.98] data-[starting-style]:opacity-0 dark:border-white dark:bg-slate-950 dark:text-white dark:shadow-none">
                <MenuCheckboxItem @bind-Checked="showMinimap"
                                  class="relative z-0 grid cursor-default select-none grid-cols-[1rem_1fr] items-center gap-2 py-2 pl-2.5 pr-8 text-sm leading-4 outline-none data-[highlighted]:text-white data-[disabled]:text-slate-500 data-[highlighted]:before:absolute data-[highlighted]:before:inset-x-1 data-[highlighted]:before:inset-y-0 data-[highlighted]:before:-z-10 data-[highlighted]:before:bg-slate-950 dark:data-[highlighted]:text-slate-950 dark:data-[disabled]:text-slate-400 dark:data-[highlighted]:before:bg-white">
                    <MenuCheckboxItemIndicator class="col-start-1">
                        <svg class="block h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" aria-hidden="true">
                            <path d="m2.5 8.5 4 4 7-9" />
                        </svg>
                    </MenuCheckboxItemIndicator>
                    <span class="col-start-2">Minimap</span>
                </MenuCheckboxItem>
                <MenuCheckboxItem @bind-Checked="showSearch"
                                  class="relative z-0 grid cursor-default select-none grid-cols-[1rem_1fr] items-center gap-2 py-2 pl-2.5 pr-8 text-sm leading-4 outline-none data-[highlighted]:text-white data-[disabled]:text-slate-500 data-[highlighted]:before:absolute data-[highlighted]:before:inset-x-1 data-[highlighted]:before:inset-y-0 data-[highlighted]:before:-z-10 data-[highlighted]:before:bg-slate-950 dark:data-[highlighted]:text-slate-950 dark:data-[disabled]:text-slate-400 dark:data-[highlighted]:before:bg-white">
                    <MenuCheckboxItemIndicator class="col-start-1">
                        <svg class="block h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" aria-hidden="true">
                            <path d="m2.5 8.5 4 4 7-9" />
                        </svg>
                    </MenuCheckboxItemIndicator>
                    <span class="col-start-2">Search</span>
                </MenuCheckboxItem>
                <MenuCheckboxItem @bind-Checked="showSidebar"
                                  class="relative z-0 grid cursor-default select-none grid-cols-[1rem_1fr] items-center gap-2 py-2 pl-2.5 pr-8 text-sm leading-4 outline-none data-[highlighted]:text-white data-[disabled]:text-slate-500 data-[highlighted]:before:absolute data-[highlighted]:before:inset-x-1 data-[highlighted]:before:inset-y-0 data-[highlighted]:before:-z-10 data-[highlighted]:before:bg-slate-950 dark:data-[highlighted]:text-slate-950 dark:data-[disabled]:text-slate-400 dark:data-[highlighted]:before:bg-white">
                    <MenuCheckboxItemIndicator class="col-start-1">
                        <svg class="block h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" aria-hidden="true">
                            <path d="m2.5 8.5 4 4 7-9" />
                        </svg>
                    </MenuCheckboxItemIndicator>
                    <span class="col-start-2">Sidebar</span>
                </MenuCheckboxItem>
            </MenuPopup>
        </MenuPositioner>
    </MenuPortal>
</MenuRoot>

@code {
    private bool showMinimap = true;
    private bool showSearch = true;
    private bool showSidebar;
}
