<DialogRoot>
    <DialogTrigger class="blx-dialog-trigger">Edit profile</DialogTrigger>
    <DialogPortal>
        <DialogBackdrop class="blx-dialog-backdrop" />
        <DialogPopup class="blx-dialog-popup">
            <div class="blx-dialog-header">
                <DialogTitle class="blx-dialog-title">Edit profile</DialogTitle>
                <DialogDescription class="blx-dialog-description">
                    Update the details shown on your public team card.
                </DialogDescription>
            </div>

            <div class="blx-dialog-fields">
                <label class="blx-dialog-field">
                    <span>Name</span>
                    <input class="blx-dialog-input" value="Maya Chen" />
                </label>
                <label class="blx-dialog-field">
                    <span>Role</span>
                    <input class="blx-dialog-input" value="Design systems lead" />
                </label>
            </div>

            <div class="blx-dialog-actions">
                <DialogClose class="blx-dialog-button">Cancel</DialogClose>
                <DialogClose class="blx-dialog-button blx-dialog-button-primary">Save changes</DialogClose>
            </div>
        </DialogPopup>
    </DialogPortal>
</DialogRoot>
