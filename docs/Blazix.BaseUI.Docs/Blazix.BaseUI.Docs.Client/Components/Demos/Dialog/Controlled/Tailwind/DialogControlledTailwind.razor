<div class="grid gap-4">
    <div class="flex flex-wrap items-center gap-3">
        <button type="button" class="inline-flex h-10 items-center justify-center rounded-lg border border-cyan-400/45 bg-cyan-500/15 px-4 text-sm font-semibold text-cyan-950 shadow-[0_12px_30px_rgba(8,145,178,0.16)] transition-colors hover:bg-cyan-500/25 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500 dark:border-cyan-300/30 dark:bg-cyan-300/10 dark:text-cyan-50 dark:hover:bg-cyan-300/15" @onclick="@(() => open = true)">Open from state</button>
        <span data-open="@open" class="inline-flex h-7 items-center rounded-full border border-slate-300 bg-slate-100 px-3 text-xs font-semibold text-slate-700 data-[open=True]:border-emerald-300 data-[open=True]:bg-emerald-100 data-[open=True]:text-emerald-800 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:data-[open=True]:border-emerald-500/30 dark:data-[open=True]:bg-emerald-400/15 dark:data-[open=True]:text-emerald-200">@(open ? "Open" : "Closed")</span>
    </div>

    <DialogRoot Open="open" OpenChanged="@(value => open = value)" OnOpenChange="HandleOpenChange">
        <DialogPortal>
            <DialogBackdrop class="fixed inset-0 z-50 bg-slate-950/50 opacity-100 transition-opacity duration-150 ease-out data-[starting-style]:opacity-0 data-[ending-style]:opacity-0" />
            <DialogPopup class="fixed left-1/2 top-1/2 z-50 box-border flex w-[24rem] max-w-[calc(100vw-3rem)] -translate-x-1/2 -translate-y-1/2 flex-col gap-5 rounded-2xl border border-white/70 bg-white p-6 text-slate-950 shadow-[0_24px_70px_rgba(15,23,42,0.24)] transition-[opacity,transform] duration-150 ease-out focus-visible:outline-none data-[starting-style]:scale-95 data-[starting-style]:opacity-0 data-[ending-style]:scale-95 data-[ending-style]:opacity-0 dark:border-white/10 dark:bg-slate-950 dark:text-slate-100 dark:shadow-[0_24px_70px_rgba(0,0,0,0.55)]">
                <div>
                    <DialogTitle class="m-0 text-lg font-semibold">Controlled dialog</DialogTitle>
                    <DialogDescription class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-400">
                        This dialog is opened and closed by Blazor state.
                    </DialogDescription>
                </div>

                <div class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 font-mono text-xs text-slate-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300">
                    Last reason: <strong>@lastReason</strong>
                </div>

                <div class="flex flex-wrap justify-end gap-2">
                    <DialogClose class="inline-flex h-10 items-center justify-center rounded-lg border border-slate-300 bg-white px-4 text-sm font-medium text-slate-800 transition-colors hover:bg-slate-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:hover:bg-slate-800">Close</DialogClose>
                    <button type="button" class="inline-flex h-10 items-center justify-center rounded-lg border border-transparent bg-slate-950 px-4 text-sm font-semibold text-white transition-colors hover:bg-slate-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500 dark:bg-cyan-300 dark:text-slate-950 dark:hover:bg-cyan-200" @onclick="@(() => open = false)">Close externally</button>
                </div>
            </DialogPopup>
        </DialogPortal>
    </DialogRoot>
</div>

@code {
    private bool open;
    private DialogOpenChangeReason lastReason = DialogOpenChangeReason.None;

    private void HandleOpenChange(DialogOpenChangeEventArgs args)
    {
        lastReason = args.Reason;
    }
}
