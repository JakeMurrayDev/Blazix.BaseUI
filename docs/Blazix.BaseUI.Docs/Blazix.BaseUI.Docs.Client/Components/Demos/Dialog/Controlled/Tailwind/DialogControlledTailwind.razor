<div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-3">
        <button type="button" class="flex h-8 cursor-pointer items-center justify-center gap-2 whitespace-nowrap border border-neutral-950 bg-white px-3 text-sm font-normal leading-none text-neutral-950 select-none hover:bg-neutral-100 active:bg-neutral-200 focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-neutral-950 dark:border-white dark:bg-neutral-950 dark:text-white dark:hover:bg-neutral-800 dark:active:bg-neutral-700 dark:focus-visible:outline-white" @onclick="@(() => open = true)">Open from state</button>
        <span data-open="@open" class="inline-flex h-7 items-center border border-neutral-950 px-2.5 text-xs font-semibold text-neutral-950 data-[open]:bg-neutral-950 data-[open]:text-white dark:border-white dark:text-white dark:data-[open]:bg-white dark:data-[open]:text-neutral-950">@(open ? "Open" : "Closed")</span>
    </div>

    <DialogRoot Open="open" OpenChanged="@(value => open = value)" OnOpenChange="HandleOpenChange">
        <DialogPortal>
            <DialogBackdrop class="fixed inset-0 z-50 min-h-dvh bg-black opacity-20 transition-opacity duration-150 data-[starting-style]:opacity-0 data-[ending-style]:opacity-0 dark:opacity-50" />
            <DialogPopup class="fixed left-1/2 top-1/2 z-50 -mt-8 flex w-96 max-w-[calc(100vw-3rem)] -translate-x-1/2 -translate-y-1/2 flex-col gap-4 border border-neutral-950 bg-white p-4 text-neutral-950 shadow-[0.25rem_0.25rem_0_rgba(0,0,0,0.12)] transition-[transform,opacity] duration-100 ease-out focus-visible:outline-none data-[starting-style]:scale-[0.98] data-[starting-style]:opacity-0 data-[ending-style]:scale-[0.98] data-[ending-style]:opacity-0 dark:border-white dark:bg-neutral-950 dark:text-white dark:shadow-none">
                <div class="flex flex-col gap-1">
                    <DialogTitle class="m-0 text-base font-bold">Controlled dialog</DialogTitle>
                    <DialogDescription class="m-0 text-sm text-neutral-600 dark:text-neutral-400">
                        This dialog is opened and closed by Blazor state.
                    </DialogDescription>
                </div>

                <div class="border border-neutral-950 bg-neutral-100 px-3 py-2.5 font-mono text-xs text-neutral-600 dark:border-white dark:bg-neutral-800 dark:text-neutral-400">
                    Last reason: <strong>@lastReason</strong>
                </div>

                <div class="flex flex-wrap justify-end gap-3">
                    <DialogClose class="flex h-8 cursor-pointer items-center justify-center gap-2 whitespace-nowrap border border-neutral-950 bg-white px-3 text-sm font-normal leading-none text-neutral-950 select-none hover:bg-neutral-100 active:bg-neutral-200 focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-neutral-950 dark:border-white dark:bg-neutral-950 dark:text-white dark:hover:bg-neutral-800 dark:active:bg-neutral-700 dark:focus-visible:outline-white">Close</DialogClose>
                    <button type="button" class="flex h-8 cursor-pointer items-center justify-center gap-2 whitespace-nowrap border border-neutral-950 bg-neutral-950 px-3 text-sm font-normal leading-none text-white select-none hover:bg-neutral-800 focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-neutral-950 dark:border-white dark:bg-white dark:text-neutral-950 dark:hover:bg-neutral-200 dark:focus-visible:outline-white" @onclick="@(() => open = false)">Close externally</button>
                </div>
            </DialogPopup>
        </DialogPortal>
    </DialogRoot>
</div>

@code {
    private bool open;
    private DialogOpenChangeReason lastReason = DialogOpenChangeReason.None;

    private void HandleOpenChange(DialogOpenChangeEventArgs args)
    {
        lastReason = args.Reason;
    }
}
