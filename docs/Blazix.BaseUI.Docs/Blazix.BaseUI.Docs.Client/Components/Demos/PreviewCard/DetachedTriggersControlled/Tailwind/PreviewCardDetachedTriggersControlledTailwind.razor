<div class="flex flex-wrap items-baseline justify-center gap-2">
    <p class="m-0 text-base text-neutral-950 text-balance dark:text-white">
        Discover
        @foreach (var card in Cards)
        {
            <PreviewCardTypedTrigger TPayload="PreviewCardContent"
                                     Handle="@demoPreviewCard"
                                     href="@card.Href"
                                     Id="@card.ControlledId"
                                     Payload="@card"
                                     class="@LinkClasses">
                @card.Label
            </PreviewCardTypedTrigger>
            @if (card == Cards[0])
            {
                <text>, </text>
            }
            else if (card == Cards[1])
            {
                <text>, or </text>
            }
        }
        .
    </p>
    <button type="button" class="@ButtonClasses" @onclick="OpenProgrammatically">
        Open programmatically
    </button>
</div>

<PreviewCardRoot Handle="@demoPreviewCard"
                 Open="@open"
                 OpenChanged="HandleOpenChanged"
                 OnOpenChange="HandleOpenChange"
                 TriggerId="@triggerId">
    <ChildContentWithPayload Context="payloadContext">
        <PreviewCardPortal>
            <PreviewCardPositioner SideOffset="8"
                                   class="h-[var(--positioner-height)] w-[var(--positioner-width)] max-w-[var(--available-width)]">
                <PreviewCardPopup class="@PopupClasses">
                    <PreviewCardArrow class="@ArrowClasses" />
                    @RenderCard(ResolveCard(payloadContext.Payload), useControlledDimensions: true)
                </PreviewCardPopup>
            </PreviewCardPositioner>
        </PreviewCardPortal>
    </ChildContentWithPayload>
</PreviewCardRoot>

@code {
    private const string LinkClasses =
        "text-neutral-950 underline decoration-neutral-950/60 decoration-1 underline-offset-2 outline-0 hover:decoration-neutral-950 data-[popup-open]:decoration-neutral-950 focus-visible:no-underline focus-visible:outline-2 focus-visible:outline-neutral-950 dark:text-white dark:decoration-white/60 dark:hover:decoration-white dark:data-[popup-open]:decoration-white dark:focus-visible:outline-white";

    private const string ButtonClasses =
        "flex h-8 items-center justify-center gap-2 border border-neutral-950 bg-white px-3 text-sm font-normal leading-none text-neutral-950 whitespace-nowrap select-none hover:bg-neutral-100 active:bg-neutral-200 focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-neutral-950 dark:border-white dark:bg-neutral-950 dark:text-white dark:hover:bg-neutral-800 dark:active:bg-neutral-700 dark:focus-visible:outline-white";

    private const string PopupClasses =
        "relative h-[var(--popup-height,auto)] w-[var(--popup-width,auto)] origin-[var(--transform-origin)] border border-neutral-950 bg-white text-neutral-950 shadow-[0.25rem_0.25rem_0] shadow-black/15 outline-none transition-[transform,opacity] duration-100 ease-out data-[ending-style]:scale-[0.98] data-[ending-style]:opacity-0 data-[starting-style]:scale-[0.98] data-[starting-style]:opacity-0 dark:border-white dark:bg-neutral-950 dark:text-white dark:shadow-none";

    private const string ArrowClasses =
        "relative block h-1.5 w-3 overflow-clip data-[side=bottom]:top-[-6px] data-[side=left]:right-[-9px] data-[side=left]:rotate-90 data-[side=right]:left-[-9px] data-[side=right]:-rotate-90 data-[side=top]:bottom-[-6px] data-[side=top]:rotate-180 before:absolute before:bottom-0 before:left-1/2 before:h-[calc(6px*sqrt(2))] before:w-[calc(6px*sqrt(2))] before:border before:border-neutral-950 before:bg-white before:content-[''] before:[transform:translate(-50%,50%)_rotate(45deg)] dark:before:border-white dark:before:bg-neutral-950";

    private readonly PreviewCardHandle<PreviewCardContent> demoPreviewCard = PreviewCardHandleFactory.CreateHandle<PreviewCardContent>();
    private bool open;
    private string? triggerId;

    private static readonly PreviewCardContent[] Cards =
    [
        new("trigger-1", "typography", "typography", "https://en.wikipedia.org/wiki/Typography", "https://images.unsplash.com/photo-1619615391095-dfa29e1672ef?q=80&w=448&h=300", "Station Hofplein signage in Rotterdam, Netherlands", "Typography", "is the art and science of arranging type.", 224, 150, 224, 150),
        new("trigger-2", "design", "design", "https://en.wikipedia.org/wiki/Industrial_design", "https://upload.wikimedia.org/wikipedia/commons/thumb/b/b7/Braun_ABW30_%28schwarz%29.jpg/250px-Braun_ABW30_%28schwarz%29.jpg", "Braun ABW30", "design", "is the concept or proposal for an object, process, or system.", 241, 240, 250, 249),
        new("trigger-3", "art", "art", "https://en.wikipedia.org/wiki/Art", "https://upload.wikimedia.org/wikipedia/commons/thumb/5/5f/MonaLisa_sfumato.jpeg/250px-MonaLisa_sfumato.jpeg", "Mona Lisa", "Art", "is a diverse range of cultural activity centered around works utilizing creative or imaginative talents, which are expected to evoke a worthwhile experience, generally through an expression of emotional power, conceptual ideas, technical proficiency, or beauty.", 206, 240, 250, 290),
    ];

    private void HandleOpenChanged(bool value)
    {
        open = value;
    }

    private void HandleOpenChange(PreviewCardOpenChangeEventArgs args)
    {
        open = args.Open;

        if (!string.IsNullOrEmpty(args.TriggerId))
        {
            triggerId = args.TriggerId;
        }
    }

    private void OpenProgrammatically()
    {
        triggerId = Cards[1].ControlledId;
        open = true;
    }

    private static PreviewCardContent ResolveCard(object? payload)
    {
        return payload as PreviewCardContent ?? Cards[0];
    }

    private static RenderFragment RenderCard(PreviewCardContent card, bool useControlledDimensions) => builder =>
    {
        var width = useControlledDimensions ? card.ControlledWidth : card.FullWidth;
        var height = useControlledDimensions ? card.ControlledHeight : card.FullHeight;

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "flex w-min flex-col gap-2 p-2");
        builder.OpenElement(2, "img");
        builder.AddAttribute(3, "width", width);
        builder.AddAttribute(4, "height", height);
        builder.AddAttribute(5, "class", "block max-w-none");
        builder.AddAttribute(6, "src", card.ImageUrl);
        builder.AddAttribute(7, "alt", card.ImageAlt);
        builder.CloseElement();
        builder.OpenElement(8, "p");
        builder.AddAttribute(9, "class", "m-0 text-sm text-pretty");
        builder.OpenElement(10, "strong");
        builder.AddContent(11, card.Title);
        builder.CloseElement();
        builder.AddContent(12, $" {card.Summary}");
        builder.CloseElement();
        builder.CloseElement();
    };

    private sealed record PreviewCardContent(
        string ControlledId,
        string Id,
        string Label,
        string Href,
        string ImageUrl,
        string ImageAlt,
        string Title,
        string Summary,
        int ControlledWidth,
        int ControlledHeight,
        int FullWidth,
        int FullHeight);
}
