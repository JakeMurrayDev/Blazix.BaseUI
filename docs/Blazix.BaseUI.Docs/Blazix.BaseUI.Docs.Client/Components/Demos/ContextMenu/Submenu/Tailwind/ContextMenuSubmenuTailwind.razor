<ContextMenuRoot>
    <ContextMenuTrigger class="flex h-48 w-60 items-center justify-center rounded-none border border-slate-950 bg-white font-normal text-slate-950 select-none dark:border-white dark:bg-slate-950 dark:text-white">
        Right click here
    </ContextMenuTrigger>
    <ContextMenuPortal>
        <ContextMenuPositioner class="outline-none">
            <ContextMenuPopup class="@PopupClass">
                <ContextMenuItem class="@ItemClass">Add to Library</ContextMenuItem>

                <ContextMenuSubmenuRoot>
                    <ContextMenuSubmenuTrigger class="@SubmenuTriggerClass">
                        Add to Playlist
                        <svg class="block size-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                            <path d="M6 12V4L10.5 8L6 12Z" />
                        </svg>
                    </ContextMenuSubmenuTrigger>
                    <ContextMenuPortal>
                        <ContextMenuPositioner AlignOffset="-4" SideOffset="-4" class="outline-none">
                            <ContextMenuPopup class="@PopupClass">
                                <ContextMenuItem class="@ItemClass">Get Up!</ContextMenuItem>
                                <ContextMenuItem class="@ItemClass">Inside Out</ContextMenuItem>
                                <ContextMenuItem class="@ItemClass">Night Beats</ContextMenuItem>
                                <ContextMenuSeparator class="mx-1 my-1 h-px bg-slate-950 dark:bg-white" />
                                <ContextMenuItem class="@ItemClass">New playlist...</ContextMenuItem>
                            </ContextMenuPopup>
                        </ContextMenuPositioner>
                    </ContextMenuPortal>
                </ContextMenuSubmenuRoot>

                <ContextMenuSeparator class="mx-1 my-1 h-px bg-slate-950 dark:bg-white" />
                <ContextMenuItem class="@ItemClass">Play Next</ContextMenuItem>
                <ContextMenuItem class="@ItemClass">Play Last</ContextMenuItem>
                <ContextMenuSeparator class="mx-1 my-1 h-px bg-slate-950 dark:bg-white" />
                <ContextMenuItem class="@ItemClass">Favorite</ContextMenuItem>
                <ContextMenuItem class="@ItemClass">Share</ContextMenuItem>
            </ContextMenuPopup>
        </ContextMenuPositioner>
    </ContextMenuPortal>
</ContextMenuRoot>

@code {
    private const string PopupClass =
        "origin-[var(--transform-origin)] border border-slate-950 bg-white py-1 text-slate-950 shadow-[0.25rem_0.25rem_0] shadow-black/10 outline-none transition-[scale,opacity] duration-100 ease-out data-[ending-style]:scale-[0.98] data-[ending-style]:opacity-0 data-[starting-style]:scale-[0.98] data-[starting-style]:opacity-0 dark:border-white dark:bg-slate-950 dark:text-white dark:shadow-none";

    private const string ItemClass =
        "relative z-0 flex cursor-default py-2 pr-8 pl-4 text-sm leading-4 outline-none select-none data-[highlighted]:text-white data-[highlighted]:before:absolute data-[highlighted]:before:inset-x-1 data-[highlighted]:before:inset-y-0 data-[highlighted]:before:z-[-1] data-[highlighted]:before:bg-slate-950 data-[highlighted]:before:content-[''] data-[disabled]:text-slate-500 dark:data-[highlighted]:text-slate-950 dark:data-[highlighted]:before:bg-white dark:data-[disabled]:text-slate-400";

    private const string SubmenuTriggerClass =
        "relative z-0 flex cursor-default items-center justify-between gap-4 py-2 pr-2 pl-4 text-sm leading-4 outline-none select-none data-[popup-open]:before:absolute data-[popup-open]:before:inset-x-1 data-[popup-open]:before:inset-y-0 data-[popup-open]:before:z-[-1] data-[popup-open]:before:bg-slate-100 data-[popup-open]:before:content-[''] data-[highlighted]:text-white data-[highlighted]:before:absolute data-[highlighted]:before:inset-x-1 data-[highlighted]:before:inset-y-0 data-[highlighted]:before:z-[-1] data-[highlighted]:before:bg-slate-950 data-[highlighted]:before:content-[''] data-[disabled]:text-slate-500 dark:data-[popup-open]:before:bg-slate-800 dark:data-[highlighted]:text-slate-950 dark:data-[highlighted]:before:bg-white dark:data-[disabled]:text-slate-400";
}
