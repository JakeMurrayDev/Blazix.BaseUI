        <AlertDialogPopup class="fixed left-1/2 top-1/2 z-50 box-border flex w-96 max-w-[calc(100vw-3rem)] -translate-x-1/2 -translate-y-1/2 flex-col gap-5 rounded-2xl bg-white p-6 text-slate-900 shadow-[0_24px_60px_rgba(15,23,42,0.22)] transition-[opacity,transform] duration-150 ease-out focus-visible:outline-none data-[starting-style]:scale-95 data-[starting-style]:opacity-0 data-[ending-style]:scale-95 data-[ending-style]:opacity-0 dark:bg-slate-900 dark:text-slate-100 dark:shadow-[0_24px_60px_rgba(0,0,0,0.55)]">
            <div class="flex flex-col gap-1.5">
                <AlertDialogTitle class="m-0 text-lg font-semibold">Delete your account?</AlertDialogTitle>
