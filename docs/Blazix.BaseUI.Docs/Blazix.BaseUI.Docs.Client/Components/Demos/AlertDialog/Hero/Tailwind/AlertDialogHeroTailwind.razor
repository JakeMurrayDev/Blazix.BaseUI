<AlertDialogRoot>
    <AlertDialogTrigger class="box-border inline-flex h-10 cursor-pointer items-center justify-center whitespace-nowrap rounded-lg border border-slate-500/40 px-4 text-sm font-medium text-red-700 transition-colors hover:bg-slate-400/15 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-400 dark:border-slate-400/30 dark:text-red-400">Delete account</AlertDialogTrigger>
    <AlertDialogPortal>
