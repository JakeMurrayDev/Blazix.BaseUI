<div class="blx-otp-field">
    <label for="otp-password" class="blx-otp-field-label">Access code</label>
    <OtpFieldRoot Id="otp-password"
                  Length="6"
                  Mask="true"
                  aria-describedby="otp-password-description"
                  class="blx-otp-field-root">
        @for (var index = 0; index < 6; index++)
        {
            var slot = index;
            <OtpFieldInput class="blx-otp-field-input"
                           aria-label="@(slot == 0 ? null : $"Character {slot + 1} of 6")" />
        }
    </OtpFieldRoot>
    <p id="otp-password-description" class="blx-otp-field-description">
        Use <span class="blx-otp-field-code">Mask</span> to obscure the code on shared screens.
    </p>
</div>
