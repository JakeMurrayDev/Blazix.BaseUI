<div class="blx-otp-field">
    <label for="otp-grouped" class="blx-otp-field-label">Verification code</label>
    <OtpFieldRoot Id="otp-grouped"
                  Length="6"
                  class="blx-otp-field-root">
        <div class="blx-otp-field-group">
            @for (var index = 0; index < 3; index++)
            {
                var slot = index;
                <OtpFieldInput class="blx-otp-field-input"
                               aria-label="@(slot == 0 ? null : $"Character {slot + 1} of 6")" />
            }
        </div>
        <Separator class="blx-otp-field-separator" />
        <div class="blx-otp-field-group">
            @for (var index = 0; index < 3; index++)
            {
                var slot = index;
                <OtpFieldInput class="blx-otp-field-input"
                               aria-label="@($"Character {slot + 4} of 6")" />
            }
        </div>
    </OtpFieldRoot>
</div>
