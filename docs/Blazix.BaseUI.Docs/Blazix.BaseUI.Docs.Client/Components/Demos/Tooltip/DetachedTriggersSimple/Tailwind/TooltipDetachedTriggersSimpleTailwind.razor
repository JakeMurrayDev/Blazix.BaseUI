<TooltipProvider>
    <TooltipTrigger Handle="@demoTooltip" aria-label="Delete" class="@ButtonClasses">@TrashIcon</TooltipTrigger>

    <TooltipRoot Handle="@demoTooltip">
        <TooltipPortal>
            <TooltipPositioner SideOffset="11">
                <TooltipPopup class="@PopupClasses">
                    <TooltipArrow class="@ArrowClasses" />
                    Delete
                </TooltipPopup>
            </TooltipPositioner>
        </TooltipPortal>
    </TooltipRoot>
</TooltipProvider>

@code {
    private const string ButtonClasses = "box-border flex h-8 w-8 items-center justify-center border border-neutral-950 bg-white p-0 text-neutral-950 outline-0 hover:bg-neutral-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-neutral-950 data-[popup-open]:bg-neutral-100 dark:border-white dark:bg-neutral-950 dark:text-white dark:hover:bg-neutral-800 dark:focus-visible:outline-white";
    private const string PopupClasses = "relative flex flex-col border border-neutral-950 bg-white px-2 py-1 text-sm leading-5 text-neutral-950 shadow-[0.25rem_0.25rem_0_rgb(0_0_0_/_12%)] transition data-[ending-style]:scale-95 data-[ending-style]:opacity-0 data-[starting-style]:scale-95 data-[starting-style]:opacity-0 dark:border-white dark:bg-neutral-950 dark:text-white dark:shadow-none";
    private const string ArrowClasses = "block h-1.5 w-3 overflow-hidden";

    private readonly TooltipHandle demoTooltip = TooltipHandleFactory.CreateHandle();
    private static readonly RenderFragment TrashIcon = @<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-linejoin="round" aria-hidden="true"><path stroke-linecap="square" d="M2.5 4h11" /><path stroke-linecap="round" d="M6.5 4V3c0-.828.672-1.5 1.5-1.5S9.5 2.172 9.5 3v1" /><path stroke-linecap="square" d="m3.5 4 .871 9.142A1.5 1.5 0 0 0 5.864 14.5h4.272a1.5 1.5 0 0 0 1.493-1.358L12.5 4" /></svg>;
}
