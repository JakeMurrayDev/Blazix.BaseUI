<TooltipProvider>
    <div class="flex border border-neutral-950 bg-white dark:border-white dark:bg-neutral-950">
        @foreach (var tool in Tools)
        {
            <TooltipRoot @key="tool.Label">
                <TooltipTrigger aria-label="@tool.Label" class="@ButtonClasses">
                    @tool.Icon
                </TooltipTrigger>
                <TooltipPortal>
                    <TooltipPositioner SideOffset="11">
                        <TooltipPopup class="@PopupClasses">
                            <TooltipArrow class="@ArrowClasses" />
                            @tool.Label
                        </TooltipPopup>
                    </TooltipPositioner>
                </TooltipPortal>
            </TooltipRoot>
        }
    </div>
</TooltipProvider>

@code {
    private const string ButtonClasses = "box-border flex h-8 w-8 items-center justify-center border-0 bg-transparent p-0 text-neutral-950 outline-0 hover:bg-neutral-100 active:bg-neutral-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-neutral-950 data-[popup-open]:bg-neutral-100 dark:text-white dark:hover:bg-neutral-800 dark:active:bg-neutral-700 dark:focus-visible:outline-white dark:data-[popup-open]:bg-neutral-800";
    private const string PopupClasses = "relative flex flex-col border border-neutral-950 bg-white px-2 py-1 text-sm leading-5 text-neutral-950 shadow-[0.25rem_0.25rem_0_rgb(0_0_0_/_12%)] transition data-[ending-style]:scale-95 data-[ending-style]:opacity-0 data-[instant]:transition-none data-[starting-style]:scale-95 data-[starting-style]:opacity-0 dark:border-white dark:bg-neutral-950 dark:text-white dark:shadow-none";
    private const string ArrowClasses = "block h-1.5 w-3 overflow-hidden";

    private static readonly IReadOnlyList<TooltipTool> Tools =
    [
        new("Bold", @<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" aria-hidden="true"><path d="M5 3.25h3.2a2.1 2.1 0 0 1 0 4.2H5z" /><path d="M5 7.45h3.85a2.4 2.4 0 0 1 0 4.8H5z" /><path d="M5 3.25v9" /></svg>),
        new("Italic", @<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" aria-hidden="true"><path d="M10.5 3.25H7.25" /><path d="M8.75 12.75H5.5" /><path d="M9.5 3.25 6.5 12.75" /></svg>),
        new("Underline", @<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" aria-hidden="true"><path d="M5 3.25v4.5a3 3 0 0 0 6 0v-4.5" /><path d="M4.25 12.75h7.5" /></svg>),
    ];

    private sealed record TooltipTool(string Label, RenderFragment Icon);
}
