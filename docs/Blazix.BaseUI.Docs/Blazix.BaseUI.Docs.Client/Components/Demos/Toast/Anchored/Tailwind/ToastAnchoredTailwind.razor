nslateY(var(--offset-y))] data-ending-style:data-[swipe-direction=up]:[transform:translateY(calc(var(--toast-swipe-movement-y)-150%))] data-expanded:data-ending-style:data-[swipe-direction=up]:[transform:translateY(calc(var(--toast-swipe-movement-y)-150%))] h-[var(--height)] data-expanded:h-[var(--toast-height)] [transition:transform_0.5s_cubic-bezier(0.22,1,0.36,1),opacity_0.5s,height_0.15s]";
    private const string ContentClasses = "flex h-full items-center gap-4 overflow-hidden p-3 transition-opacity duration-[250ms] ease-[cubic-bezier(0.22,1,0.36,1)] data-behind:opacity-0 data-expanded:opacity-100";
    private const string CloseClasses = "flex h-8 shrink-0 items-center justify-center gap-2 rounded-none border border-neutral-950 bg-white px-3 py-0 font-[inherit] text-sm font-normal leading-none text-neutral-950 hover:not-data-disabled:bg-neutral-100 active:not-data-disabled:bg-neutral-200 focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-neutral-950 data-disabled:border-neutral-500 data-disabled:text-neutral-500 disabled:border-neutral-500 disabled:text-neutral-500 dark:border-white dark:bg-neutral-950 dark:text-white dark:hover:not-data-disabled:bg-neutral-800 dark:active:not-data-disabled:bg-neutral-700 dark:data-disabled:border-neutral-400 dark:data-disabled:text-neutral-400 dark:focus-visible:outline-white";
    private const string AnchoredToastClasses = "relative flex w-max flex-col border border-neutral-950 bg-white px-2 py-1 text-sm text-neutral-950 origin-[var(--transform-origin)] shadow-[0.25rem_0.25rem_0] shadow-black/12 transition-[scale,opacity] duration-100 ease-out data-ending-style:opacity-0 data-ending-style:scale-[0.98] data-instant:transition-none data-starting-style:opacity-0 data-starting-style:scale-[0.98] focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-neutral-950 dark:border-white dark:bg-neutral-950 dark:text-white dark:shadow-none dark:focus-visible:outline-white";

    private TooltipTrigger? copyTrigger;
    private int stackedViewportLayer = ToastDemoViewportLayer.Next();
    private bool copied;

    private string StackedViewportStyle => ToastDemoViewportLayer.Style(stackedViewportLayer);

    private void CreateStackedToast(ToastManagerContext toastManager)
    {
        BringStackedViewportToFront();
        toastManager.Add(new ToastManagerAddOptions
        {
            Description = "Copied"
        });
    }

    private void BringStackedViewportToFront() => stackedViewportLayer = ToastDemoViewportLayer.Next();

    private void HandleCopy(ToastManagerContext toastManager)
    {
        var anchor = copyTrigger?.Element;
        if (anchor is null)
        {
            return;
        }

        copied = true;
        toastManager.Add(new ToastManagerAddOptions
        {
            Description = "Copied",
            Timeout = 1500,
            PositionerProps = new ToastPositionerOptions
            {
                Anchor = anchor,
                SideOffset = 10
            },
            OnCloseCallback = EventCallback.Factory.Create(this, () => copied = false)
        });
    }
}
