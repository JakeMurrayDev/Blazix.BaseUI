<TooltipProvider>
    <ToastProvider Context="anchoredToastManager">
        <ToastProvider Context="stackedToastManager">
            <div class="flex min-h-28 items-center justify-center gap-2">
                <TooltipRoot Disabled="copied">
                    <TooltipTrigger @ref="copyTrigger"
                                    CloseOnClick="false"
                                    Disabled="copied"
                                    class="@CopyButtonClasses"
                                    aria-label="Copy to clipboard"
                                    @onclick="@(() => HandleCopy(anchoredToastManager))">
                        @if (copied)
                        {
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" aria-hidden="true">
                                <path d="m2.5 8.5 4 4 7-9" />
                            </svg>
                        }
                        else
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                <rect width="8" height="4" x="8" y="2" rx="1" ry="1" />
                                <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
                            </svg>
                        }
                    </TooltipTrigger>
                    <TooltipPortal>
                        <TooltipPositioner SideOffset="10">
                            <TooltipPopup class="@TooltipPopupClasses">
                                <TooltipArrow class="@ArrowClasses" />
                                Copy
                            </TooltipPopup>
                        </TooltipPositioner>
                    </TooltipPortal>
                </TooltipRoot>

                <button type="button" class="@ButtonClasses" @onclick="@(() => CreateStackedToast(stackedToastManager))">
                    Stacked toast
                </button>
            </div>

            <ToastPortal>
                <ToastViewport class="@BottomViewportClasses" StyleValue="@(_ => StackedViewportStyle)">
                    @foreach (var item in stackedToastManager.Toasts)
                    {
                        <ToastRoot @key="item.Id" Toast="item" class="@StackedToastClasses">
                            <ToastContent class="@ContentClasses">
                                <div class="flex min-w-0 flex-1 flex-col gap-1">
                                    <ToastTitle class="text-sm font-bold" />
                                    <ToastDescription class="text-sm" />
                                </div>
                                <ToastClose class="@CloseClasses">Dismiss</ToastClose>
                            </ToastContent>
                        </ToastRoot>
                    }
                </ToastViewport>
            </ToastPortal>
        </ToastProvider>

        <ToastPortal>
            <ToastViewport class="outline-0">
                @foreach (var item in anchoredToastManager.Toasts)
                {
                    <ToastPositioner @key="item.Id" Toast="item" class="z-[calc(1000-var(--toast-index))]">
                        <ToastRoot @key="item.Id" Toast="item" class="@AnchoredToastClasses">
                            <ToastArrow class="@ArrowClasses" />
                            <ToastContent>
                                <ToastDescription />
                            </ToastContent>
                        </ToastRoot>
                    </ToastPositioner>
                }
            </ToastViewport>
        </ToastPortal>
    </ToastProvider>
</TooltipProvider>

@code {
