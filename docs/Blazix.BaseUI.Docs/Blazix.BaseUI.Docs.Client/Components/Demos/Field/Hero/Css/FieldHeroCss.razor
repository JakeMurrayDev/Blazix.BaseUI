<FieldRoot ValidationMode="ValidationMode.OnBlur" class="blx-field">
    <FieldLabel class="blx-field-label">Name</FieldLabel>
    <FieldControl TValue="string"
                  required="true"
                  placeholder="Required"
                  class="blx-field-input" />
    <FieldError MatchValidity="valueMissing" class="blx-field-error">
        Please enter your name.
    </FieldError>
    <FieldDescription class="blx-field-description">
        Visible on your profile.
    </FieldDescription>
</FieldRoot>
