<SliderRoot DefaultValues="@(new double[] { 25, 45 })">
    <SliderControl class="blx-slider-control">
        <SliderTrack class="blx-slider-track">
            <SliderIndicator class="blx-slider-indicator" />
            <SliderThumb Index="0" AriaLabel="Minimum value" class="blx-slider-thumb" />
            <SliderThumb Index="1" AriaLabel="Maximum value" class="blx-slider-thumb" />
        </SliderTrack>
    </SliderControl>
</SliderRoot>
