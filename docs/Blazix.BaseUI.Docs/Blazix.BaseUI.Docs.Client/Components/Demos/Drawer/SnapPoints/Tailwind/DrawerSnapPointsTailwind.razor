<div class="grid gap-4">
    <DrawerRoot SnapPoints="snapPoints"
                @bind-SnapPoint="snapPoint"
                DefaultSnapPoint="defaultSnapPoint">
        <DrawerTrigger class="inline-flex h-10 items-center justify-center rounded-lg border border-teal-400/45 bg-teal-500/15 px-4 text-sm font-semibold text-teal-950 shadow-[0_12px_30px_rgba(13,148,136,0.16)] transition-colors hover:bg-teal-500/25 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-500 dark:border-teal-300/30 dark:bg-teal-300/10 dark:text-teal-50 dark:hover:bg-teal-300/15">Open snap drawer</DrawerTrigger>
        <DrawerPortal>
            <DrawerBackdrop class="fixed inset-0 z-50 bg-slate-950/50 opacity-100 transition-opacity duration-200 ease-out data-[starting-style]:opacity-0 data-[ending-style]:opacity-0" />
            <DrawerViewport class="pointer-events-none fixed inset-0 z-50 flex touch-none items-end justify-center">
                <DrawerPopup class="pointer-events-auto mx-3 box-border flex h-[min(34rem,calc(100dvh-1rem))] w-[min(42rem,calc(100vw-1.5rem))] translate-y-[calc(var(--drawer-snap-point-offset,0px)+var(--drawer-swipe-movement-y,0px))] flex-col overflow-hidden rounded-t-2xl border border-white/70 bg-white pb-[max(0px,calc(var(--drawer-snap-point-offset,0px)+var(--drawer-swipe-movement-y,0px)))] text-slate-950 shadow-[0_24px_70px_rgba(15,23,42,0.24)] transition-[opacity,transform,padding-bottom] duration-200 ease-out focus-visible:outline-none data-[starting-style]:translate-y-full data-[starting-style]:opacity-0 data-[ending-style]:translate-y-full data-[ending-style]:opacity-0 data-[swiping]:transition-none dark:border-white/10 dark:bg-slate-950 dark:text-slate-100 dark:shadow-[0_24px_70px_rgba(0,0,0,0.55)]">
                    <div class="mx-auto mb-4 mt-3 h-1 w-12 rounded-full bg-slate-300 dark:bg-slate-700" aria-hidden="true"></div>
                    <DrawerContent class="flex min-h-0 flex-1 flex-col gap-4 overflow-y-auto px-6 pb-6">
                        <div>
                            <DrawerTitle class="m-0 text-lg font-semibold">Release checklist</DrawerTitle>
                            <DrawerDescription class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-400">
                                Drag the sheet between snap points, or close it when the review is complete.
                            </DrawerDescription>
                        </div>

                        <div class="grid gap-2">
                            <label class="flex min-h-12 items-center justify-between gap-4 rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm font-medium text-slate-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300">
                                <span>Run accessibility smoke tests</span>
                                <input type="checkbox" checked />
                            </label>
                            <label class="flex min-h-12 items-center justify-between gap-4 rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm font-medium text-slate-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300">
                                <span>Confirm dark-mode contrast</span>
                                <input type="checkbox" checked />
                            </label>
                            <label class="flex min-h-12 items-center justify-between gap-4 rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm font-medium text-slate-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300">
                                <span>Capture mobile viewport screenshots</span>
                                <input type="checkbox" />
                            </label>
                            <label class="flex min-h-12 items-center justify-between gap-4 rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm font-medium text-slate-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300">
                                <span>Publish API reference updates</span>
                                <input type="checkbox" />
                            </label>
                        </div>

                        <div class="mt-auto flex flex-wrap items-center justify-between gap-2">
                            <span class="inline-flex min-h-8 items-center rounded-full border border-slate-300 bg-slate-100 px-3 font-mono text-xs font-semibold text-slate-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300">Active snap: @ActiveSnapLabel</span>
                            <DrawerClose class="inline-flex h-10 items-center justify-center rounded-lg border border-transparent bg-slate-950 px-4 text-sm font-semibold text-white transition-colors hover:bg-slate-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-500 dark:bg-teal-300 dark:text-slate-950 dark:hover:bg-teal-200">Done</DrawerClose>
                        </div>
                    </DrawerContent>
                </DrawerPopup>
            </DrawerViewport>
        </DrawerPortal>
    </DrawerRoot>
</div>

@code {
    private readonly IReadOnlyList<DrawerSnapPoint> snapPoints = [(DrawerSnapPoint)"18rem", (DrawerSnapPoint)1];
    private readonly DrawerSnapPoint defaultSnapPoint = (DrawerSnapPoint)"18rem";
    private DrawerSnapPoint? snapPoint = (DrawerSnapPoint)"18rem";

    private string ActiveSnapLabel => snapPoint?.ToString() ?? "none";
}
