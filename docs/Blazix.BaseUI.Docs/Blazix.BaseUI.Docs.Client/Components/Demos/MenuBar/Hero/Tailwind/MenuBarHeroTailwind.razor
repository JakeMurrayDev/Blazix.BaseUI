<MenuBarRoot class="flex items-center">
    <MenuRoot Context="_">
        <MenuTrigger class="@TriggerClass">File</MenuTrigger>
        <MenuPortal>
            <MenuPositioner SideOffset="4"
                            class="outline-none">
                <MenuPopup class="@PopupClass">
                    <MenuItem class="@ItemClass">New</MenuItem>
                    <MenuItem class="@ItemClass">Open</MenuItem>
                    <MenuItem class="@ItemClass">Save</MenuItem>
                    <MenuSubmenuRoot>
                        <MenuSubmenuTrigger class="@SubmenuTriggerClass">
                            Export
                            <svg class="block size-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                                <path d="M6 12V4l4.5 4z" />
                            </svg>
                        </MenuSubmenuTrigger>
                        <MenuPortal>
                            <MenuPositioner SideOffset="-4"
                                            AlignOffset="-4"
                                            class="outline-none">
                                <MenuPopup class="@PopupClass">
                                    <MenuItem class="@ItemClass">PDF</MenuItem>
                                    <MenuItem class="@ItemClass">PNG</MenuItem>
                                    <MenuItem class="@ItemClass">SVG</MenuItem>
                                </MenuPopup>
                            </MenuPositioner>
                        </MenuPortal>
                    </MenuSubmenuRoot>
                    <Blazix.BaseUI.Separator.Separator class="mx-1 my-1 h-px bg-slate-950 dark:bg-white" />
                    <MenuItem class="@ItemClass">Print</MenuItem>
                </MenuPopup>
            </MenuPositioner>
        </MenuPortal>
    </MenuRoot>

    <MenuRoot Context="_">
        <MenuTrigger class="@TriggerClass">Edit</MenuTrigger>
        <MenuPortal>
            <MenuPositioner SideOffset="4"
                            class="outline-none">
                <MenuPopup class="@PopupClass">
                    <MenuItem class="@ItemClass">Cut</MenuItem>
                    <MenuItem class="@ItemClass">Copy</MenuItem>
                    <MenuItem class="@ItemClass">Paste</MenuItem>
                </MenuPopup>
            </MenuPositioner>
        </MenuPortal>
    </MenuRoot>

    <MenuRoot Context="_">
        <MenuTrigger class="@TriggerClass">View</MenuTrigger>
        <MenuPortal>
            <MenuPositioner SideOffset="4"
                            class="outline-none">
                <MenuPopup class="@PopupClass">
                    <MenuItem class="@ItemClass">Zoom In</MenuItem>
                    <MenuItem class="@ItemClass">Zoom Out</MenuItem>
                    <MenuSubmenuRoot>
                        <MenuSubmenuTrigger class="@SubmenuTriggerClass">
                            Layout
                            <svg class="block size-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                                <path d="M6 12V4l4.5 4z" />
                            </svg>
                        </MenuSubmenuTrigger>
                        <MenuPortal>
                            <MenuPositioner SideOffset="-4"
                                            AlignOffset="-4"
                                            class="outline-none">
                                <MenuPopup class="@PopupClass">
                                    <MenuItem class="@ItemClass">Single Page</MenuItem>
                                    <MenuItem class="@ItemClass">Two Pages</MenuItem>
                                    <MenuItem class="@ItemClass">Continuous</MenuItem>
                                </MenuPopup>
                            </MenuPositioner>
                        </MenuPortal>
                    </MenuSubmenuRoot>
                    <Blazix.BaseUI.Separator.Separator class="mx-1 my-1 h-px bg-slate-950 dark:bg-white" />
                    <MenuItem class="@ItemClass">Full Screen</MenuItem>
                </MenuPopup>
            </MenuPositioner>
        </MenuPortal>
    </MenuRoot>

    <MenuRoot Disabled="true"
              Context="_">
        <MenuTrigger class="@TriggerClass">Help</MenuTrigger>
    </MenuRoot>
</MenuBarRoot>

@code {
    private const string TriggerClass =
        "box-border h-8 border-0 bg-transparent px-3 text-sm font-normal leading-5 text-slate-950 select-none hover:bg-slate-100 active:bg-slate-200 focus-visible:relative focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-slate-950 disabled:text-slate-500 data-[disabled]:text-slate-500 data-[popup-open]:bg-slate-100 data-[pressed]:bg-slate-100 dark:text-white dark:hover:bg-slate-800 dark:active:bg-slate-700 dark:focus-visible:bg-slate-800 dark:focus-visible:outline-white dark:disabled:text-slate-400 dark:data-[disabled]:text-slate-400 dark:data-[popup-open]:bg-slate-800 dark:data-[pressed]:bg-slate-800";

    private const string PopupClass =
        "origin-[var(--transform-origin)] border border-slate-950 bg-white py-1 text-slate-950 shadow-[0.25rem_0.25rem_0] shadow-black/10 outline-none transition-[scale,opacity] duration-100 ease-out data-[ending-style]:scale-[0.98] data-[ending-style]:opacity-0 data-[instant]:transition-none data-[starting-style]:scale-[0.98] data-[starting-style]:opacity-0 dark:border-white dark:bg-slate-950 dark:text-white dark:shadow-none";

    private const string ItemClass =
        "relative z-0 flex cursor-default items-center justify-between gap-4 px-4 py-2 text-sm font-normal leading-4 outline-none select-none data-[highlighted]:text-white data-[highlighted]:before:absolute data-[highlighted]:before:inset-x-1 data-[highlighted]:before:inset-y-0 data-[highlighted]:before:z-[-1] data-[highlighted]:before:bg-slate-950 data-[highlighted]:before:content-[''] dark:data-[highlighted]:text-slate-950 dark:data-[highlighted]:before:bg-white";

    private const string SubmenuTriggerClass =
        "relative z-0 flex cursor-default items-center justify-between gap-4 py-2 pl-4 pr-2 text-sm font-normal leading-4 outline-none select-none data-[highlighted]:text-white data-[highlighted]:before:absolute data-[highlighted]:before:inset-x-1 data-[highlighted]:before:inset-y-0 data-[highlighted]:before:z-[-1] data-[highlighted]:before:bg-slate-950 data-[highlighted]:before:content-[''] data-[popup-open]:before:absolute data-[popup-open]:before:inset-x-1 data-[popup-open]:before:inset-y-0 data-[popup-open]:before:z-[-1] data-[popup-open]:before:bg-slate-100 data-[popup-open]:before:content-[''] dark:data-[highlighted]:text-slate-950 dark:data-[highlighted]:before:bg-white dark:data-[popup-open]:before:bg-slate-800 dark:data-[highlighted]:data-[popup-open]:before:bg-white";
}
