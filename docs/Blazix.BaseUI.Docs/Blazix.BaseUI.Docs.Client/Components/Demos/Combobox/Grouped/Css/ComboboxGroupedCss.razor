<ComboboxRoot TValue="ComboboxDemoProduce"
              ItemGroups="@ComboboxDemoData.GroupedProduce"
              ItemToStringLabel="ComboboxDemoData.GetProduceLabel"
              ItemToStringValue="ComboboxDemoData.GetProduceLabel"
              IsItemEqualToValue="ComboboxDemoData.EqualProduce">
    <div class="blx-combobox-label">
        <label for="combobox-grouped-produce">Select produce</label>
        <ComboboxInputGroup class="blx-combobox-input-group">
            <ComboboxInput id="combobox-grouped-produce" class="blx-combobox-input" placeholder="e.g. Mango" />
            <div class="blx-combobox-action-buttons">
                <ComboboxClear class="blx-combobox-clear" aria-label="Clear selection">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-linecap="square" stroke-linejoin="round" aria-hidden="true"><path d="m4.5 4.5 7 7m-7 0 7-7" /></svg>
                </ComboboxClear>
                <ComboboxTrigger class="blx-combobox-trigger" aria-label="Open popup">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M12 6H4l4 4.5z" /></svg>
                </ComboboxTrigger>
            </div>
        </ComboboxInputGroup>
    </div>

    <ComboboxPortal>
        <ComboboxPositioner class="blx-combobox-positioner" SideOffset="4">
            <ComboboxPopup class="blx-combobox-popup">
                <ComboboxEmpty>
                    <div class="blx-combobox-empty">No produce found.</div>
                </ComboboxEmpty>
                <ComboboxList class="blx-combobox-list">
                    @foreach (var group in ComboboxDemoData.GroupedProduce)
                    {
                        <ComboboxGroup class="blx-combobox-group">
                            <ComboboxGroupLabel class="blx-combobox-group-label">@group.Label</ComboboxGroupLabel>
                            @foreach (var item in group.Items)
                            {
                                <ComboboxItem TValue="ComboboxDemoProduce" class="blx-combobox-item" Value="@item" Label="@item.Label">
                                    <ComboboxItemIndicator class="blx-combobox-item-indicator">
                                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" aria-hidden="true"><path d="m2.5 8.5 4 4 7-9" /></svg>
                                    </ComboboxItemIndicator>
                                    <span class="blx-combobox-item-text">@item.Label</span>
                                </ComboboxItem>
                            }
                        </ComboboxGroup>
                    }
                </ComboboxList>
            </ComboboxPopup>
        </ComboboxPositioner>
    </ComboboxPortal>
</ComboboxRoot>
