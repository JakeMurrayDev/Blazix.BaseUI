<section class="@LiquidGlassClasses.Panel">
    <div class="mb-4 flex items-center justify-between border-b border-white/25 pb-3">
        <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-700 dark:text-slate-300">@Title</h2>
    </div>
    <div class="min-w-0">
        @ChildContent
    </div>
</section>

@code {
    [Parameter]
    public string Title { get; set; } = "Section";

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
