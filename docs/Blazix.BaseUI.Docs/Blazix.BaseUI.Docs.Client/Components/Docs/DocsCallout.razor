<div class="rounded-[24px] border border-sky-100/80 bg-sky-50/75 p-4 text-sm leading-6 text-slate-800 shadow-[inset_0_1px_0_rgba(255,255,255,0.82),0_14px_34px_rgba(14,116,144,0.1)] dark:border-white/20 dark:bg-white/10 dark:text-slate-200">
    <div class="mb-2 text-[11px] font-semibold uppercase tracking-[0.16em] text-sky-700 dark:text-slate-300">@Title</div>
    @ChildContent
</div>

@code {
    [Parameter]
    public string Title { get; set; } = "Note";

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
