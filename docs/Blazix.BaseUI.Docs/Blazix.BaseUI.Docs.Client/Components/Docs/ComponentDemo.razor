@switch (Slug)
{
    case "accordion":
        <DocsSection Title="Live Demo">
            <div class="grid min-w-0 gap-4 xl:grid-cols-[minmax(0,1fr)_minmax(280px,0.7fr)]">
                <div class="@LiquidGlassClasses.InsetPanel">
                    <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-sky-700 dark:text-sky-300">Single Mode</p>
                            <h3 class="text-lg font-semibold tracking-normal text-slate-950 dark:text-white">Setup Guide</h3>
                        </div>
                        <span class="rounded-full border border-white/55 bg-white/60 px-3 py-1 text-xs text-slate-700 shadow-[inset_0_1px_0_rgba(255,255,255,0.78)] dark:border-white/10 dark:bg-white/10 dark:text-slate-200">one panel</span>
                    </div>

                    <AccordionRoot TValue="string" DefaultValue="@(["install"])" ClassValue="@(_ => "grid gap-2")">
                        <AccordionItem TValue="string" Value="@("install")" ClassValue="@(state => AccordionItemClass(state.Open))">
                            <AccordionHeader>
                                <AccordionTrigger ClassValue="@(state => TriggerClass(state.Open))">
                                    <span>Install package</span>
                                    <span class="@TriggerBadgeClass()">toggle</span>
                                </AccordionTrigger>
                            </AccordionHeader>
                            <AccordionPanel ClassValue="@(_ => AccordionPanelClass())">
                                <div class="px-4 pb-4 pt-1">
                                    <p>Reference the library project or install the package, then import the component namespace where the docs examples live.</p>
                                    <code class="@LiquidGlassClasses.CodeInline">dotnet add package Blazix.BaseUI</code>
                                </div>
                            </AccordionPanel>
                        </AccordionItem>

                        <AccordionItem TValue="string" Value="@("compose")" ClassValue="@(state => AccordionItemClass(state.Open))">
                            <AccordionHeader>
                                <AccordionTrigger ClassValue="@(state => TriggerClass(state.Open))">
                                    <span>Compose parts</span>
                                    <span class="@TriggerBadgeClass()">toggle</span>
                                </AccordionTrigger>
                            </AccordionHeader>
                            <AccordionPanel ClassValue="@(_ => AccordionPanelClass())">
                                <div class="px-4 pb-4 pt-1">
                                    <p>Root, item, header, trigger, and panel stay independent so the design system can replace tags, classes, and render fragments.</p>
                                </div>
                            </AccordionPanel>
                        </AccordionItem>

                        <AccordionItem TValue="string" Value="@("motion")" ClassValue="@(state => AccordionItemClass(state.Open))">
                            <AccordionHeader>
                                <AccordionTrigger ClassValue="@(state => TriggerClass(state.Open))">
                                    <span>Animate panels</span>
                                    <span class="@TriggerBadgeClass()">toggle</span>
                                </AccordionTrigger>
                            </AccordionHeader>
                            <AccordionPanel ClassValue="@(_ => AccordionPanelClass())">
                                <div class="px-4 pb-4 pt-1">
                                    <p>Panels publish measured CSS variables, so Tailwind can transition to the natural height without hard-coded dimensions.</p>
                                </div>
                            </AccordionPanel>
                        </AccordionItem>
                    </AccordionRoot>
                </div>

                <div class="@LiquidGlassClasses.InsetPanel">
                    <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-sky-700 dark:text-sky-300">Multiple Mode</p>
                            <h3 class="text-lg font-semibold tracking-normal text-slate-950 dark:text-white">Release Checklist</h3>
                        </div>
                        <span class="rounded-full border border-white/55 bg-white/60 px-3 py-1 text-xs text-slate-700 shadow-[inset_0_1px_0_rgba(255,255,255,0.78)] dark:border-white/10 dark:bg-white/10 dark:text-slate-200">many panels</span>
                    </div>

                    <AccordionRoot TValue="string" Multiple DefaultValue="@(["docs", "a11y"])" ClassValue="@(_ => "grid gap-2")">
                        <AccordionItem TValue="string" Value="@("docs")" ClassValue="@(state => AccordionItemClass(state.Open))">
                            <AccordionHeader>
                                <AccordionTrigger ClassValue="@(state => TriggerClass(state.Open))">
                                    <span>Documentation</span>
                                    <span class="@TriggerBadgeClass()">toggle</span>
                                </AccordionTrigger>
                            </AccordionHeader>
                            <AccordionPanel ClassValue="@(_ => AccordionPanelClass())">
                                <p class="px-4 pb-4 pt-1">Write the usage path, state model, accessibility notes, and raw Markdown route before polishing copy.</p>
                            </AccordionPanel>
                        </AccordionItem>

                        <AccordionItem TValue="string" Value="@("a11y")" ClassValue="@(state => AccordionItemClass(state.Open))">
                            <AccordionHeader>
                                <AccordionTrigger ClassValue="@(state => TriggerClass(state.Open))">
                                    <span>Accessibility</span>
                                    <span class="@TriggerBadgeClass()">toggle</span>
                                </AccordionTrigger>
                            </AccordionHeader>
                            <AccordionPanel ClassValue="@(_ => AccordionPanelClass())">
                                <p class="px-4 pb-4 pt-1">Verify trigger focus, arrow-key movement, aria-expanded, and panel labelling with the rendered DOM.</p>
                            </AccordionPanel>
                        </AccordionItem>
                    </AccordionRoot>
                </div>
            </div>
        </DocsSection>
        break;
    case "alert-dialog":
        <DocsSection Title="Live Demo">
            <AlertDialogRoot>
                <AlertDialogTrigger ClassValue="@(_ => LiquidGlassClasses.Button)">Delete record</AlertDialogTrigger>
                <AlertDialogPortal>
                    <AlertDialogBackdrop ClassValue="@(_ => "fixed inset-0 z-40 bg-slate-950/20 backdrop-blur-sm")" />
                    <AlertDialogPopup ClassValue="@(_ => "liquid-glass fixed left-1/2 top-1/2 z-50 w-[min(92vw,440px)] -translate-x-1/2 -translate-y-1/2 rounded-[34px] border border-white/45 bg-white/40 p-2 shadow-[0_30px_90px_rgba(15,23,42,0.24),inset_0_1px_0_rgba(255,255,255,0.72)]")">
                        <div class="@LiquidGlassClasses.TitleBar">
                            <AlertDialogTitle>Confirm delete</AlertDialogTitle>
                            <span class="@LiquidGlassClasses.TitleButton" aria-hidden="true">!</span>
                        </div>
                        <AlertDialogDescription class="block p-3">
                            This action removes the item from the current list. Choose Cancel to return safely.
                        </AlertDialogDescription>
                        <div class="flex justify-end gap-2 p-2">
                            <AlertDialogClose ClassValue="@(_ => LiquidGlassClasses.Button)">Cancel</AlertDialogClose>
                            <AlertDialogClose ClassValue="@(_ => LiquidGlassClasses.Button)">Delete</AlertDialogClose>
                        </div>
                    </AlertDialogPopup>
                </AlertDialogPortal>
            </AlertDialogRoot>
        </DocsSection>
        break;
    case "autocomplete":
        <DocsSection Title="Live Demo">
            <AutocompleteRoot TValue="string" Items="autocompleteItems" DefaultOpen="true" OpenOnInputClick="true" AutoHighlight="AutocompleteAutoHighlight.True">
                <AutocompleteInputGroup ClassValue="@(_ => "flex max-w-md items-center gap-2 rounded-[28px] border border-white/45 bg-white/55 p-1 shadow-[0_14px_38px_rgba(14,116,144,0.12),inset_0_1px_0_rgba(255,255,255,0.74)]")">
                    <AutocompleteInput class="@($"{LiquidGlassClasses.Input} flex-1")" placeholder="Search component" />
                    <AutocompleteTrigger ClassValue="@(_ => LiquidGlassClasses.Button)">Open</AutocompleteTrigger>
                </AutocompleteInputGroup>
                <AutocompletePositioner ClassValue="@(_ => "z-50")">
                    <AutocompletePopup ClassValue="@(_ => $"{LiquidGlassClasses.Popup} mt-2 w-[320px]")">
                        <AutocompleteEmpty ClassValue="@(_ => "block rounded-2xl bg-white/65 p-3")">No match</AutocompleteEmpty>
                        <AutocompleteList ClassValue="@(_ => "grid gap-1")">
                            <AutocompleteCollection TValue="string" Context="entry">
                                <AutocompleteItem TValue="string" Value="@entry.Item" Index="@entry.Index" ClassValue="@(state => state.Highlighted ? "rounded-2xl bg-sky-200/70 px-3 py-2 text-slate-950 shadow-[inset_0_1px_0_rgba(255,255,255,0.78)]" : "rounded-2xl bg-white/55 px-3 py-2 text-slate-800")">
                                    @entry.Item
                                </AutocompleteItem>
                            </AutocompleteCollection>
                        </AutocompleteList>
                    </AutocompletePopup>
                </AutocompletePositioner>
            </AutocompleteRoot>
        </DocsSection>
        break;
    case "avatar":
        <DocsSection Title="Live Demo">
            <div class="flex flex-wrap items-center gap-4">
                <AvatarRoot class="grid size-16 place-items-center overflow-hidden rounded-[24px] border border-white/50 bg-white/60 shadow-[0_16px_42px_rgba(15,23,42,0.14),inset_0_1px_0_rgba(255,255,255,0.72)] dark:border-white/10 dark:bg-white/10">
                    <AvatarImage src="/favicon.png" alt="Blazix icon" class="size-full object-cover" />
                    <AvatarFallback class="grid size-full place-items-center font-bold">BX</AvatarFallback>
                </AvatarRoot>
                <AvatarRoot class="grid size-16 place-items-center overflow-hidden rounded-full border border-white/50 bg-white/60 shadow-[0_16px_42px_rgba(15,23,42,0.14),inset_0_1px_0_rgba(255,255,255,0.72)] dark:border-white/10 dark:bg-white/10">
                    <AvatarImage src="/missing-user.png" alt="Missing avatar" class="size-full object-cover" />
                    <AvatarFallback class="grid size-full place-items-center font-bold">MS</AvatarFallback>
                </AvatarRoot>
            </div>
        </DocsSection>
        break;
    case "button":
        <DocsSection Title="Live Demo">
            <div class="flex flex-wrap gap-2">
                <Button ClassValue="@(state => state.Disabled ? $"{LiquidGlassClasses.Button} text-slate-400" : LiquidGlassClasses.Button)">Save</Button>
                <Button Disabled="true" FocusableWhenDisabled="true" ClassValue="@(state => state.Disabled ? $"{LiquidGlassClasses.Button} text-slate-400" : LiquidGlassClasses.Button)">Saving...</Button>
                <Button NativeButton="false" ClassValue="@(_ => LiquidGlassClasses.Button)">Custom element mode</Button>
            </div>
        </DocsSection>
        break;
    case "checkbox":
        <DocsSection Title="Live Demo">
            <div class="grid gap-3">
                <label class="flex items-center gap-2">
                    <CheckboxRoot DefaultChecked="true" ClassValue="@(state => CheckboxBoxClass(state.Checked, state.Disabled))">
                        <CheckboxIndicator ClassValue="@(_ => "grid size-full place-items-center font-bold")">x</CheckboxIndicator>
                    </CheckboxRoot>
                    Enable release notes
                </label>
                <label class="flex items-center gap-2">
                    <CheckboxRoot Indeterminate="true" ClassValue="@(state => CheckboxBoxClass(state.Checked || state.Indeterminate, state.Disabled))">
                        <CheckboxIndicator ClassValue="@(_ => "grid size-full place-items-center font-bold")">-</CheckboxIndicator>
                    </CheckboxRoot>
                    Mixed selection
                </label>
            </div>
        </DocsSection>
        break;
    case "checkbox-group":
        <DocsSection Title="Live Demo">
            <CheckboxGroup DefaultValue="@(["docs"])" ClassValue="@(_ => "grid gap-3")">
                <label class="flex items-center gap-2">
                    <CheckboxRoot Value="docs" ClassValue="@(state => CheckboxBoxClass(state.Checked, state.Disabled))">
                        <CheckboxIndicator ClassValue="@(_ => "grid size-full place-items-center font-bold")">x</CheckboxIndicator>
                    </CheckboxRoot>
                    Documentation
                </label>
                <label class="flex items-center gap-2">
                    <CheckboxRoot Value="tests" ClassValue="@(state => CheckboxBoxClass(state.Checked, state.Disabled))">
                        <CheckboxIndicator ClassValue="@(_ => "grid size-full place-items-center font-bold")">x</CheckboxIndicator>
                    </CheckboxRoot>
                    Tests
                </label>
                <label class="flex items-center gap-2">
                    <CheckboxRoot Value="examples" ClassValue="@(state => CheckboxBoxClass(state.Checked, state.Disabled))">
                        <CheckboxIndicator ClassValue="@(_ => "grid size-full place-items-center font-bold")">x</CheckboxIndicator>
                    </CheckboxRoot>
                    Examples
                </label>
            </CheckboxGroup>
        </DocsSection>
        break;
    case "collapsible":
        <DocsSection Title="Live Demo">
            <CollapsibleRoot DefaultOpen="true" ClassValue="@(_ => LiquidGlassClasses.Panel)">
                <CollapsibleTrigger ClassValue="@(state => TriggerClass(state.Open))">System details <span>+</span></CollapsibleTrigger>
                <CollapsiblePanel ClassValue="@(_ => LiquidGlassClasses.InsetPanel)">
                    <p>Interactive Auto starts on the server and can move to WebAssembly after the client bundle is ready.</p>
                </CollapsiblePanel>
            </CollapsibleRoot>
        </DocsSection>
        break;
}

@code {
    private readonly IReadOnlyList<string> autocompleteItems =
    [
        "Accordion",
        "Alert Dialog",
        "Autocomplete",
        "Avatar",
        "Button",
        "Checkbox",
        "Checkbox Group",
        "Collapsible"
    ];

    [Parameter]
    public string? Slug { get; set; }

    private static string TriggerClass(bool open)
    {
        var stateClass = open
            ? "bg-sky-200/65 text-slate-950 shadow-[0_14px_34px_rgba(14,116,144,0.16),inset_0_1px_0_rgba(255,255,255,0.78)] dark:bg-sky-400/25 dark:text-sky-50"
            : "bg-white/50 text-slate-800 dark:bg-white/10 dark:text-slate-200";
        return $"liquid-control flex min-h-12 w-full items-center justify-between rounded-[22px] border border-white/45 px-4 py-2 text-left dark:border-white/10 {stateClass}";
    }

    private static string AccordionItemClass(bool open)
    {
        var stateClass = open ? "bg-white/65 dark:bg-slate-800/70" : "bg-white/45 dark:bg-slate-900/55";
        return $"rounded-[26px] border border-white/55 p-1 shadow-[0_12px_28px_rgba(15,23,42,0.08),inset_0_1px_0_rgba(255,255,255,0.68)] dark:border-white/10 {stateClass}";
    }

    private static string AccordionPanelClass()
    {
        return "h-[var(--accordion-panel-height)] overflow-hidden text-sm leading-6 text-slate-700 transition-[height,opacity,transform] duration-300 ease-out data-[ending-style]:h-0 data-[ending-style]:opacity-0 data-[starting-style]:h-0 data-[starting-style]:opacity-0 dark:text-slate-200";
    }

    private static string TriggerBadgeClass()
    {
        return "rounded-full border border-white/45 bg-white/40 px-2 py-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500 dark:border-white/10 dark:bg-white/10 dark:text-slate-300";
    }

    private static string CheckboxBoxClass(bool active, bool disabled)
    {
        var activeClass = active ? "bg-sky-100/80 dark:bg-sky-400/25" : "bg-white/45 dark:bg-white/10";
        var disabledClass = disabled ? "text-slate-400" : "text-slate-900 dark:text-slate-50";
        return $"liquid-control grid size-6 place-items-center rounded-full border border-white/55 shadow-[0_8px_22px_rgba(15,23,42,0.1),inset_0_1px_0_rgba(255,255,255,0.82)] dark:border-white/10 {activeClass} {disabledClass}";
    }
}
