<section class="@($"{LiquidGlassClasses.Window} {Class}".Trim())">
    <div class="@LiquidGlassClasses.TitleBar">
        <span>@Title</span>
    </div>
    @if (Toolbar)
    {
        <div class="@LiquidGlassClasses.Toolbar">
            <span class="@LiquidGlassClasses.ButtonPressed">Browse</span>
            <span class="@LiquidGlassClasses.Button">Demos</span>
            <span class="@LiquidGlassClasses.Button">API</span>
            <span class="@LiquidGlassClasses.Button">Source</span>
        </div>
    }
    <div class="@($"{LiquidGlassClasses.WindowBody} {BodyClass}".Trim())">
        @ChildContent
    </div>
</section>

@code {
    [Parameter]
    public string Title { get; set; } = "Window";

    [Parameter]
    public bool Toolbar { get; set; }

    /// <summary>Extra classes for the outer window section (e.g. height/flex for a scrollable panel).</summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>Extra classes for the scrollable window body.</summary>
    [Parameter]
    public string? BodyClass { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
