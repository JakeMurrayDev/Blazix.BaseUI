<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <script>
        (() => {
            const stored = localStorage.getItem('blazix-docs-theme');
            const theme = stored === 'dark' || stored === 'light'
                ? stored
                : (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

            document.documentElement.classList.toggle('dark', theme === 'dark');
            document.documentElement.dataset.theme = theme;
        })();
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class'
        };
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <style>
        code.hljs {
            background: transparent;
            padding: 0;
        }
    </style>
    <style type="text/tailwindcss">
        @@layer base {
            html {
                background: #eaf7ff;
                color-scheme: light;
            }

            html.dark {
                background: #05070c;
                color-scheme: dark;
            }

            body {
                font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", sans-serif;
                background:
                    linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(219, 234, 254, 0.5) 34%, rgba(240, 253, 244, 0.5) 64%, rgba(253, 244, 255, 0.62)),
                    conic-gradient(from 220deg at 50% 28%, rgba(56, 189, 248, 0.32), rgba(244, 114, 182, 0.2), rgba(250, 204, 21, 0.2), rgba(45, 212, 191, 0.24), rgba(56, 189, 248, 0.32));
                background-size: 130% 130%, 190% 190%;
                animation: liquid-ambient 22s ease-in-out infinite alternate;
            }

            html.dark body {
                background:
                    linear-gradient(135deg, rgba(5, 7, 12, 0.98), rgba(12, 26, 45, 0.9) 38%, rgba(7, 34, 39, 0.86) 68%, rgba(25, 20, 43, 0.92)),
                    conic-gradient(from 220deg at 52% 28%, rgba(14, 165, 233, 0.22), rgba(168, 85, 247, 0.16), rgba(250, 204, 21, 0.08), rgba(45, 212, 191, 0.16), rgba(14, 165, 233, 0.22));
            }
        }

        @@layer utilities {
            .liquid-grain::before {
                content: "";
                position: fixed;
                inset: 0;
                z-index: -1;
                pointer-events: none;
                opacity: 0.24;
                background-image:
                    linear-gradient(115deg, rgba(255, 255, 255, 0.36), transparent 38%, rgba(255, 255, 255, 0.16) 60%, transparent),
                    repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.14) 0 1px, transparent 1px 9px);
                mix-blend-mode: soft-light;
            }

            .dark .liquid-grain::before {
                opacity: 0.16;
                background-image:
                    linear-gradient(115deg, rgba(255, 255, 255, 0.12), transparent 38%, rgba(255, 255, 255, 0.07) 60%, transparent),
                    repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.05) 0 1px, transparent 1px 9px);
            }

            .liquid-glass {
                position: relative;
                isolation: isolate;
                -webkit-backdrop-filter: blur(20px) saturate(160%);
                backdrop-filter: blur(20px) saturate(160%);
            }

            .liquid-glass::before {
                content: "";
                position: absolute;
                inset: 0;
                z-index: -1;
                pointer-events: none;
                border-radius: inherit;
                background:
                    linear-gradient(135deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.1) 42%, rgba(255, 255, 255, 0.28)),
                    radial-gradient(120% 120% at 12% 0%, rgba(255, 255, 255, 0.36), transparent 48%);
                box-shadow:
                    inset 0 1px 1px rgba(255, 255, 255, 0.55),
                    inset 0 -1px 1px rgba(255, 255, 255, 0.2),
                    inset 1px 0 1px rgba(255, 255, 255, 0.18),
                    inset -1px 0 1px rgba(255, 255, 255, 0.18);
                opacity: 0.52;
            }

            .dark .liquid-glass::before {
                background:
                    linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.03) 42%, rgba(125, 211, 252, 0.08)),
                    radial-gradient(120% 120% at 12% 0%, rgba(255, 255, 255, 0.12), transparent 48%);
                box-shadow:
                    inset 0 1px 1px rgba(255, 255, 255, 0.28),
                    inset 0 -1px 1px rgba(125, 211, 252, 0.12),
                    inset 1px 0 1px rgba(255, 255, 255, 0.1),
                    inset -1px 0 1px rgba(255, 255, 255, 0.1);
                opacity: 0.46;
            }

            .liquid-glass::after {
                content: "";
                position: absolute;
                inset: -20%;
                z-index: -1;
                pointer-events: none;
                border-radius: inherit;
                background: linear-gradient(110deg, transparent 24%, rgba(255, 255, 255, 0.42) 42%, transparent 58%);
                opacity: 0;
                transform: translateX(-115%) rotate(8deg);
            }

            .dark .liquid-glass::after {
                background: linear-gradient(110deg, transparent 24%, rgba(186, 230, 253, 0.18) 42%, transparent 58%);
            }

            .liquid-glass:hover::after {
                animation: liquid-sheen 1.4s cubic-bezier(0.2, 0.8, 0.2, 1);
            }

            .liquid-materialize {
                animation: liquid-materialize 720ms cubic-bezier(0.16, 1, 0.3, 1) both;
            }

            .liquid-sidebar-reveal > * {
                animation: liquid-sidebar-item-in 520ms cubic-bezier(0.16, 1, 0.3, 1) both;
            }

            .liquid-sidebar-reveal > :nth-child(2) {
                animation-delay: 45ms;
            }

            .liquid-sidebar-reveal > :nth-child(3) {
                animation-delay: 90ms;
            }

            .liquid-sidebar-reveal > :nth-child(4) {
                animation-delay: 135ms;
            }

            .liquid-lift {
                transition: transform 340ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 340ms cubic-bezier(0.16, 1, 0.3, 1), background-color 340ms ease;
            }

            .liquid-lift:hover {
                transform: translateY(-2px) scale(1.006);
            }

            .liquid-control {
                transition: transform 240ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 240ms ease, background-color 240ms ease, color 240ms ease;
            }

            .liquid-control:hover {
                transform: translateY(-1px) scale(1.015);
            }

            .liquid-control:active {
                transform: translateY(1px) scale(0.985);
                animation: liquid-press 260ms cubic-bezier(0.16, 1, 0.3, 1);
            }

            @@keyframes liquid-ambient {
                0% {
                    background-position: 0% 0%, 18% 24%;
                }

                100% {
                    background-position: 100% 76%, 82% 64%;
                }
            }

            @@keyframes liquid-materialize {
                0% {
                    opacity: 0;
                    transform: translateY(14px) scale(0.985);
                    filter: blur(10px);
                }

                100% {
                    opacity: 1;
                    transform: translateY(0) scale(1);
                    filter: blur(0);
                }
            }

            @@keyframes liquid-sidebar-item-in {
                0% {
                    opacity: 0;
                    transform: translateX(-10px) scale(0.985);
                    filter: blur(8px);
                }

                100% {
                    opacity: 1;
                    transform: translateX(0) scale(1);
                    filter: blur(0);
                }
            }

            @@keyframes liquid-sheen {
                0% {
                    transform: translateX(-115%) rotate(8deg);
                    opacity: 0;
                }

                12% {
                    opacity: 0.26;
                }

                100% {
                    transform: translateX(115%) rotate(8deg);
                    opacity: 0;
                }
            }

            @@keyframes liquid-press {
                0% {
                    box-shadow: 0 14px 38px rgba(14, 116, 144, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.7);
                }

                55% {
                    box-shadow: 0 5px 18px rgba(14, 116, 144, 0.12), inset 0 0 24px rgba(255, 255, 255, 0.74);
                }

                100% {
                    box-shadow: 0 14px 38px rgba(14, 116, 144, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.7);
                }
            }

            .liquid-wobble:active {
                animation: liquid-press 260ms cubic-bezier(0.16, 1, 0.3, 1), liquid-wobble 460ms cubic-bezier(0.16, 1, 0.3, 1);
            }

            @@keyframes liquid-wobble {
                0% {
                    transform: scale(1, 1);
                }

                25% {
                    transform: scale(0.96, 1.04);
                }

                50% {
                    transform: scale(1.03, 0.97);
                }

                70% {
                    transform: scale(0.985, 1.015);
                }

                100% {
                    transform: scale(1, 1);
                }
            }

            @@media (prefers-reduced-motion: reduce) {
                body,
                .liquid-materialize,
                .liquid-sidebar-reveal > *,
                .liquid-glass:hover::after,
                .liquid-control:active {
                    animation: none !important;
                }

                .liquid-lift,
                .liquid-control,
                [data-open],
                [data-closed],
                [data-starting-style],
                [data-ending-style] {
                    transition: none !important;
                }

                .liquid-wobble:active {
                    animation: none !important;
                }

                .liquid-prism {
                    transition: none !important;
                }

                .liquid-prism:hover {
                    transform: none !important;
                }
            }

            @@media (prefers-reduced-transparency: reduce) {
                .liquid-glass {
                    -webkit-backdrop-filter: none;
                    backdrop-filter: none;
                    background-color: rgba(255, 255, 255, 0.94) !important;
                }

                html.dark .liquid-glass {
                    background-color: rgba(2, 6, 23, 0.94) !important;
                }

                .liquid-glass::before,
                .liquid-glass::after {
                    display: none;
                }
            }

            @@media (prefers-contrast: more) {
                .liquid-glass {
                    -webkit-backdrop-filter: none;
                    backdrop-filter: none;
                    background-color: rgba(255, 255, 255, 0.97) !important;
                }

                html.dark .liquid-glass {
                    background-color: rgba(2, 6, 23, 0.97) !important;
                }

                .liquid-glass::before,
                .liquid-glass::after {
                    display: none;
                }
            }
        }
    </style>
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link rel="stylesheet" href="@Assets["demos/accordion.min.css"]" />
    <link rel="stylesheet" href="@Assets["demos/alert-dialog.min.css"]" />
    <link rel="stylesheet" href="@Assets["demos/avatar.min.css"]" />
    <link rel="stylesheet" href="@Assets["demos/autocomplete.min.css"]" />
    <HeadOutlet @rendermode="ActiveRenderMode" />
</head>

<body class="liquid-grain m-0 min-h-screen overflow-x-hidden text-[15px] leading-normal text-slate-950 antialiased dark:text-slate-100">
    <svg aria-hidden="true" focusable="false" style="position: absolute; width: 0; height: 0">
        <filter id="liquid-prism-intense" x="-35%" y="-35%" width="170%" height="170%">
            <feTurbulence type="fractalNoise" baseFrequency="0.004 0.009" numOctaves="1" seed="3" result="noise" />
            <feDisplacementMap in="SourceGraphic" in2="noise" scale="200" xChannelSelector="R" yChannelSelector="G" />
        </filter>
        <filter id="liquid-prism-intense-2" x="-25%" y="-25%" width="150%" height="150%">
            <feTurbulence type="fractalNoise" baseFrequency="0.015 0.045" numOctaves="2" seed="11" result="noise" />
            <feDisplacementMap in="SourceGraphic" in2="noise" scale="30" xChannelSelector="R" yChannelSelector="G" result="pass1" />
            <feDisplacementMap in="pass1" in2="noise" scale="20" xChannelSelector="B" yChannelSelector="R" />
        </filter>
    </svg>
    <Routes @rendermode="ActiveRenderMode" />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private IComponentRenderMode ActiveRenderMode =>
        string.Equals(HttpContext?.Request.Cookies["blazix-docs-render-mode"], "wasm", StringComparison.OrdinalIgnoreCase)
            ? InteractiveWebAssembly
            : InteractiveServer;
}
