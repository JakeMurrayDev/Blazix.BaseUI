@using Blazix.BaseUI.Button
@using Blazix.BaseUI.Checkbox
@using Blazix.BaseUI.Field
@using Blazix.BaseUI.Fieldset
@using Blazix.BaseUI.Form
@using Blazix.BaseUI.Radio
@using Blazix.BaseUI.RadioGroup
@using Blazix.BaseUI.Switch
@using Blazix.BaseUI.Utilities
@using Blazix.BaseUI.Demo.Client.Shared.Icons

<ComponentShowcase ComponentName="Fieldset"
                   Description="Groups related form controls with an accessible legend."
                   BaseRoute="/fieldset"
                   IsWasmMode="IsWasmMode">

    <DemoSection Title="Basic Fieldset"
                 Description="A fieldset with a legend that automatically associates via aria-labelledby.">
        <FieldsetRoot ClassValue="FieldsetRootClass">
            <FieldsetLegend ClassValue="FieldsetLegendClass">
                Personal Information
            </FieldsetLegend>
            <div class="demo-grid demo-grid--2">
                <FieldRoot ClassValue="FieldRootClass">
                    <FieldLabel ClassValue="FieldLabelClass">First Name</FieldLabel>
                    <FieldControl TValue="string"
                                  DefaultValue="@string.Empty"
                                  ClassValue="FieldControlClass" />
                </FieldRoot>
                <FieldRoot ClassValue="FieldRootClass">
                    <FieldLabel ClassValue="FieldLabelClass">Last Name</FieldLabel>
                    <FieldControl TValue="string"
                                  DefaultValue="@string.Empty"
                                  ClassValue="FieldControlClass" />
                </FieldRoot>
            </div>
        </FieldsetRoot>
    </DemoSection>

    <DemoSection Title="Aria-labelledby Association"
                 Description="The generated legend id is applied to the fieldset aria-labelledby attribute.">
        <FieldsetRoot ClassValue="FieldsetAccentClass">
            <FieldsetLegend ClassValue="FieldsetLegendClass">
                Contact Details
            </FieldsetLegend>
            <div class="demo-grid demo-grid--2">
                <FieldRoot ClassValue="FieldRootClass">
                    <FieldLabel ClassValue="FieldLabelClass">Email</FieldLabel>
                    <FieldControl TValue="string"
                                  DefaultValue="@string.Empty"
                                  type="email"
                                  ClassValue="FieldControlClass" />
                </FieldRoot>
                <FieldRoot ClassValue="FieldRootClass">
                    <FieldLabel ClassValue="FieldLabelClass">Phone</FieldLabel>
                    <FieldControl TValue="string"
                                  DefaultValue="@string.Empty"
                                  type="tel"
                                  ClassValue="FieldControlClass" />
                </FieldRoot>
            </div>
        </FieldsetRoot>
    </DemoSection>

    <DemoSection Title="Custom ID on Legend"
                 Description="When a custom id is provided on the legend, aria-labelledby uses that id.">
        <FieldsetRoot ClassValue="FieldsetAccentClass">
            <FieldsetLegend id="custom-legend-id" ClassValue="FieldsetLegendClass">
                Custom Legend ID
            </FieldsetLegend>
            <div class="demo-state-panel">
                <div class="demo-state-row"><span>expected aria-labelledby</span><strong>custom-legend-id</strong></div>
            </div>
        </FieldsetRoot>
    </DemoSection>

    <DemoSection Title="Disabled State"
                 Description="Disabled state applies to the fieldset, legend, and child fields.">
        <div class="demo-panel">
            <label class="demo-option-row">
                <SwitchRoot Checked="@isDisabled"
                            CheckedChanged="@(v => isDisabled = v)"
                            ClassValue="SwitchRootClass">
                    <SwitchThumb ClassValue="SwitchThumbClass" />
                </SwitchRoot>
                <span>Disabled</span>
            </label>
            <FieldsetRoot Disabled="@isDisabled" ClassValue="FieldsetRootClass">
                <FieldsetLegend ClassValue="FieldsetLegendClass">
                    Account Settings
                </FieldsetLegend>
                <div class="demo-grid demo-grid--2">
                    <FieldRoot Disabled="@isDisabled" ClassValue="FieldRootClass">
                        <FieldLabel ClassValue="FieldLabelClass">Username</FieldLabel>
                        <FieldControl TValue="string"
                                      DefaultValue="@string.Empty"
                                      ClassValue="FieldControlClass" />
                    </FieldRoot>
                    <FieldRoot Disabled="@isDisabled" ClassValue="FieldRootClass">
                        <FieldLabel ClassValue="FieldLabelClass">Access Key</FieldLabel>
                        <FieldControl TValue="string"
                                      DefaultValue="@string.Empty"
                                      ClassValue="FieldControlClass" />
                    </FieldRoot>
                </div>
            </FieldsetRoot>
        </div>
    </DemoSection>

    <DemoSection Title="State-Based Styling"
                 Description="ClassValue and StyleValue receive disabled state and can style the root and legend.">
        <div class="demo-panel">
            <label class="demo-option-row">
                <SwitchRoot Checked="@styledDisabled"
                            CheckedChanged="@(v => styledDisabled = v)"
                            ClassValue="SwitchRootClass">
                    <SwitchThumb ClassValue="SwitchThumbClass" />
                </SwitchRoot>
                <span>Toggle Disabled</span>
            </label>
            <FieldsetRoot Disabled="@styledDisabled"
                          ClassValue="StyledFieldsetClass"
                          StyleValue="@(s => s.Disabled ? "opacity: 0.72;" : "opacity: 1;")">
                <FieldsetLegend ClassValue="StyledLegendClass"
                                StyleValue="@(s => s.Disabled ? "text-decoration: line-through;" : "")">
                    @(styledDisabled ? "Disabled Section" : "Enabled Section")
                </FieldsetLegend>
                <div class="demo-state-panel">
                    <div class="demo-state-row"><span>disabled</span><strong>@styledDisabled</strong></div>
                    <div class="demo-state-row"><span>data-disabled</span><strong>@(styledDisabled ? "present" : "absent")</strong></div>
                </div>
            </FieldsetRoot>
        </div>
    </DemoSection>

    <DemoSection Title="Custom Element"
                 Description="Render can replace fieldset and legend elements while preserving state attributes.">
        <FieldsetRoot Render="RenderAsDiv"
                      ClassValue="FieldsetWarningClass">
            <FieldsetLegend Render="RenderLegendAsH3" ClassValue="FieldsetLegendClass">
                Rendered as div/h3
            </FieldsetLegend>
            <p class="demo-description">
                The root is rendered as a div and the legend as an h3.
            </p>
        </FieldsetRoot>
    </DemoSection>

    <DemoSection Title="Nested Fieldsets"
                 Description="Nested fieldsets keep independent legend associations and state.">
        <FieldsetRoot ClassValue="FieldsetRootClass">
            <FieldsetLegend ClassValue="FieldsetLegendClass">
                Shipping Information
            </FieldsetLegend>
            <div class="demo-stack">
                <FieldsetRoot ClassValue="NestedFieldsetClass">
                    <FieldsetLegend ClassValue="FieldsetLegendClass">
                        Address
                    </FieldsetLegend>
                    <div class="demo-grid demo-grid--2">
                        <FieldRoot ClassValue="FieldRootClass">
                            <FieldControl TValue="string"
                                          DefaultValue="@string.Empty"
                                          placeholder="Street"
                                          ClassValue="FieldControlClass" />
                        </FieldRoot>
                        <div class="demo-grid demo-grid--2">
                            <FieldRoot ClassValue="FieldRootClass">
                                <FieldControl TValue="string"
                                              DefaultValue="@string.Empty"
                                              placeholder="City"
                                              ClassValue="FieldControlClass" />
                            </FieldRoot>
                            <FieldRoot ClassValue="FieldRootClass">
                                <FieldControl TValue="string"
                                              DefaultValue="@string.Empty"
                                              placeholder="ZIP"
                                              ClassValue="FieldControlClass" />
                            </FieldRoot>
                        </div>
                    </div>
                </FieldsetRoot>

                <FieldsetRoot ClassValue="NestedFieldsetClass">
                    <FieldsetLegend ClassValue="FieldsetLegendClass">
                        Delivery Options
                    </FieldsetLegend>
                    <RadioGroup TValue="string"
                                @bind-Value="deliveryOption"
                                DefaultValue="@("standard")"
                                ClassValue="@(_ => "demo-stack")">
                        <label class="demo-option-row">
                            <RadioRoot TValue="string"
                                       Value="@("standard")"
                                       ClassValue="RadioRootClass">
                                <RadioIndicator ClassValue="RadioIndicatorClass">
                                    <span class="demo-radio-dot"></span>
                                </RadioIndicator>
                            </RadioRoot>
                            <span>Standard (5-7 days)</span>
                        </label>
                        <label class="demo-option-row">
                            <RadioRoot TValue="string"
                                       Value="@("express")"
                                       ClassValue="RadioRootClass">
                                <RadioIndicator ClassValue="RadioIndicatorClass">
                                    <span class="demo-radio-dot"></span>
                                </RadioIndicator>
                            </RadioRoot>
                            <span>Express (2-3 days)</span>
                        </label>
                        <label class="demo-option-row">
                            <RadioRoot TValue="string"
                                       Value="@("overnight")"
                                       ClassValue="RadioRootClass">
                                <RadioIndicator ClassValue="RadioIndicatorClass">
                                    <span class="demo-radio-dot"></span>
                                </RadioIndicator>
                            </RadioRoot>
                            <span>Overnight</span>
                        </label>
                    </RadioGroup>
                </FieldsetRoot>
            </div>
        </FieldsetRoot>
    </DemoSection>

    <DemoSection Title="Form Integration with Validation"
                 Description="Fieldset composes with Field components, checkbox controls, and Form submission.">
        <div class="demo-panel demo-panel--wide">
            <Form Model="@formIntegrationModel"
                  OnFormSubmit="@HandleSubmit"
                  ClassValue="@(_ => "demo-stack")">
                <FieldsetRoot ClassValue="FieldsetRootClass">
                    <FieldsetLegend ClassValue="FieldsetLegendClass">
                        Create Account
                    </FieldsetLegend>
                    <div class="demo-stack">
                        <FieldRoot ValidationMode="ValidationMode.OnBlur"
                                   Validate="ValidateEmail"
                                   ClassValue="FieldRootClass">
                            <FieldLabel ClassValue="FieldLabelClass">Email</FieldLabel>
                            <FieldControl TValue="string"
                                          @bind-Value="formEmail"
                                          type="email"
                                          autocomplete="username"
                                          ClassValue="FieldControlClass" />
                            <FieldError ClassValue="FieldErrorClass" />
                        </FieldRoot>

                        <FieldRoot ValidationMode="ValidationMode.OnBlur"
                                   Validate="ValidatePassword"
                                   ClassValue="FieldRootClass">
                            <FieldLabel ClassValue="FieldLabelClass">Password</FieldLabel>
                            <FieldControl TValue="string"
                                          @bind-Value="formPassword"
                                          type="password"
                                          autocomplete="new-password"
                                          ClassValue="FieldControlClass" />
                            <FieldDescription ClassValue="FieldDescriptionClass">
                                Minimum 8 characters.
                            </FieldDescription>
                            <FieldError ClassValue="FieldErrorClass" />
                        </FieldRoot>

                        <FieldsetRoot Disabled="@(!agreeToTerms)"
                                      ClassValue="NestedFieldsetClass">
                            <FieldsetLegend ClassValue="FieldsetLegendClass">
                                Preferences
                            </FieldsetLegend>
                            <div class="demo-stack">
                                <FieldRoot Name="newsletters" Disabled="@(!agreeToTerms)">
                                    <div class="demo-option-row">
                                        <CheckboxRoot DefaultChecked="false"
                                                      ClassValue="CheckboxRootClass">
                                            <CheckboxIndicator ClassValue="CheckboxIndicatorClass">
                                                <CheckIcon />
                                            </CheckboxIndicator>
                                        </CheckboxRoot>
                                        <FieldLabel ClassValue="FieldLabelClass">
                                            Send me newsletters
                                        </FieldLabel>
                                    </div>
                                </FieldRoot>
                                <FieldRoot Name="twoFactor" Disabled="@(!agreeToTerms)">
                                    <div class="demo-option-row">
                                        <CheckboxRoot DefaultChecked="false"
                                                      ClassValue="CheckboxRootClass">
                                            <CheckboxIndicator ClassValue="CheckboxIndicatorClass">
                                                <CheckIcon />
                                            </CheckboxIndicator>
                                        </CheckboxRoot>
                                        <FieldLabel ClassValue="FieldLabelClass">
                                            Enable two-factor authentication
                                        </FieldLabel>
                                    </div>
                                </FieldRoot>
                            </div>
                        </FieldsetRoot>

                        <FieldRoot Name="terms">
                            <div class="demo-option-row">
                                <CheckboxRoot Checked="@agreeToTerms"
                                              CheckedChanged="@(v => agreeToTerms = v)"
                                              ClassValue="CheckboxRootClass">
                                    <CheckboxIndicator ClassValue="CheckboxIndicatorClass">
                                        <CheckIcon />
                                    </CheckboxIndicator>
                                </CheckboxRoot>
                                <FieldLabel ClassValue="FieldLabelClass">
                                    I agree to the terms and conditions
                                </FieldLabel>
                            </div>
                        </FieldRoot>

                        <Button ClassValue="@(_ => "demo-button demo-button--primary demo-button--full")">
                            Create Account
                        </Button>
                    </div>
                </FieldsetRoot>
            </Form>
            @if (formSubmitted)
            {
                <div class="demo-result demo-result--success">
                    Form submitted with email: @formEmail
                </div>
            }
        </div>
    </DemoSection>

    <DemoSection Title="Disabled Propagation Matrix"
                 Description="Nested disabled fieldsets, field roots, and selection controls should stay synchronized.">
        <div class="demo-panel">
            <label class="demo-option-row">
                <SwitchRoot Checked="@matrixDisabled"
                            CheckedChanged="@(v => matrixDisabled = v)"
                            ClassValue="SwitchRootClass">
                    <SwitchThumb ClassValue="SwitchThumbClass" />
                </SwitchRoot>
                <span>Disable matrix</span>
            </label>
            <FieldsetRoot Disabled="@matrixDisabled" ClassValue="FieldsetRootClass">
                <FieldsetLegend ClassValue="FieldsetLegendClass">
                    Notification Settings
                </FieldsetLegend>
                <div class="demo-grid demo-grid--2">
                    <FieldRoot Disabled="@matrixDisabled" ClassValue="FieldRootClass">
                        <FieldLabel ClassValue="FieldLabelClass">Email address</FieldLabel>
                        <FieldControl TValue="string"
                                      DefaultValue="@string.Empty"
                                      type="email"
                                      ClassValue="FieldControlClass" />
                    </FieldRoot>
                    <FieldRoot Name="digest" Disabled="@matrixDisabled">
                        <div class="demo-option-row">
                            <CheckboxRoot Disabled="@matrixDisabled"
                                          DefaultChecked="true"
                                          ClassValue="CheckboxRootClass">
                                <CheckboxIndicator ClassValue="CheckboxIndicatorClass">
                                    <CheckIcon />
                                </CheckboxIndicator>
                            </CheckboxRoot>
                            <FieldLabel ClassValue="FieldLabelClass">
                                Weekly digest
                            </FieldLabel>
                        </div>
                    </FieldRoot>
                </div>
            </FieldsetRoot>
        </div>
    </DemoSection>

    <DemoSection Title="Without Legend"
                 Description="A fieldset can render without a legend, while the demo makes the missing label visually explicit.">
        <FieldsetRoot ClassValue="FieldsetWarningClass">
            <p class="demo-description">
                This fieldset has no legend. Prefer a legend for accessible grouping.
            </p>
            <FieldRoot ClassValue="FieldRootClass">
                <FieldControl TValue="string"
                              DefaultValue="@string.Empty"
                              placeholder="Some input"
                              ClassValue="FieldControlClass" />
            </FieldRoot>
        </FieldsetRoot>
    </DemoSection>

    <DemoSection Title="Multiple Legends"
                 Description="Only the last rendered legend is associated with aria-labelledby.">
        <FieldsetRoot ClassValue="FieldsetAccentClass">
            <FieldsetLegend ClassValue="FieldsetLegendClass">
                First Legend
            </FieldsetLegend>
            <FieldsetLegend ClassValue="FieldsetLegendClass">
                Second Legend
            </FieldsetLegend>
            <p class="demo-description">
                In practice, only use one legend per fieldset.
            </p>
        </FieldsetRoot>
    </DemoSection>
</ComponentShowcase>

@code {
    private bool isDisabled;
    private bool styledDisabled;
    private bool agreeToTerms;
    private bool matrixDisabled;
    private string formEmail = "";
    private string formPassword = "";
    private bool formSubmitted;
    private string? deliveryOption = "standard";
    private readonly object formIntegrationModel = new();

    private RenderFragment<RenderProps<FieldsetRootState>> RenderAsDiv =>
        ctx => RenderUtilities.CreateElement("div", ctx);

    private RenderFragment<RenderProps<FieldsetLegendState>> RenderLegendAsH3 =>
        ctx => RenderUtilities.CreateElement("h3", ctx);

    [Parameter]
    public bool IsWasmMode { get; set; }

    private static string FieldRootClass(FieldRootState state) => "demo-field";

    private static string FieldControlClass(FieldRootState state) => "demo-control";

    private static string FieldLabelClass(FieldRootState state) => "demo-label";

    private static string FieldDescriptionClass(FieldRootState state) => "demo-description";

    private static string FieldErrorClass(FieldErrorState state) => "demo-error";

    private static string FieldsetRootClass(FieldsetRootState state) => "demo-fieldset";

    private static string FieldsetAccentClass(FieldsetRootState state) => "demo-fieldset demo-fieldset--accent";

    private static string FieldsetWarningClass(FieldsetRootState state) => "demo-fieldset demo-fieldset--warning";

    private static string NestedFieldsetClass(FieldsetRootState state) => "demo-fieldset";

    private static string StyledFieldsetClass(FieldsetRootState state) =>
        state.Disabled ? "demo-fieldset demo-fieldset--warning" : "demo-fieldset demo-fieldset--accent";

    private static string FieldsetLegendClass(FieldsetLegendState state) => "demo-legend";

    private static string StyledLegendClass(FieldsetLegendState state) => "demo-legend";

    private static string SwitchRootClass(SwitchRootState state) => "demo-switch";

    private static string SwitchThumbClass(SwitchRootState state) => "demo-switch__thumb";

    private static string CheckboxRootClass(CheckboxRootState state) => "demo-checkbox-control";

    private static string CheckboxIndicatorClass(CheckboxIndicatorState state) => "demo-checkbox-indicator";

    private static string RadioRootClass(RadioRootState state) => "demo-radio-control";

    private static string RadioIndicatorClass(RadioIndicatorState state) => "demo-radio-indicator";

    private void HandleSubmit(FormSubmitEventArgs e)
    {
        formSubmitted = true;
    }

    private Task<string[]?> ValidateEmail(object? value)
    {
        var str = value?.ToString() ?? string.Empty;
        if (string.IsNullOrEmpty(str))
            return Task.FromResult<string[]?>(["Email is required"]);

        if (!str.Contains('@'))
            return Task.FromResult<string[]?>(["Invalid email format"]);

        return Task.FromResult<string[]?>(null);
    }

    private Task<string[]?> ValidatePassword(object? value)
    {
        var str = value?.ToString() ?? string.Empty;
        if (string.IsNullOrEmpty(str))
            return Task.FromResult<string[]?>(["Password is required"]);

        if (str.Length < 8)
            return Task.FromResult<string[]?>(["Password must be at least 8 characters"]);

        return Task.FromResult<string[]?>(null);
    }
}
