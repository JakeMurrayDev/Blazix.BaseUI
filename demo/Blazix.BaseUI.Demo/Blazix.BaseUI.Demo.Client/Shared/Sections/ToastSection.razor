@using Blazix.BaseUI
@using Blazix.BaseUI.Toast

<ToastProvider ToastManager="stackedToastManager" Timeout="5000" Limit="4" Context="stacked">
    <ComponentShowcase ComponentName="Toast"
                       Description="A notification that appears temporarily and can expose actions, priority, positioning, promise updates, and focus management."
                       BaseRoute="/toast"
                       IsWasmMode="IsWasmMode">

        <DemoSection Title="Basic Stack"
                     Description="Create polite and high-priority toasts in the global stack.">
            <div class="toast-demo-centered-panel">
                <div class="toast-demo-trigger-row">
                    <button type="button"
                            class="demo-button demo-button--primary"
                            data-demo-toast-trigger="basic"
                            @onclick="ShowBasicToast">
                        Create toast
                    </button>
                    <button type="button"
                            class="demo-button"
                            data-demo-toast-trigger="priority"
                            @onclick="ShowPriorityToast">
                        High priority
                    </button>
                </div>
                <div class="toast-demo-status-strip" aria-live="polite">
                    <span>Created @createdCount</span>
                    <span>Closed @closedCount</span>
                    <span>Removed @removedCount</span>
                </div>
            </div>
        </DemoSection>

        <DemoSection Title="Anchored Toast"
                     Description="Attach a toast to the trigger element with ToastPositioner anchor options.">
            <div class="toast-demo-centered-panel">
                <button type="button"
                        class="demo-button demo-button--primary"
                        data-demo-toast-trigger="anchored"
                        disabled="@copyState"
                        @ref="copyButtonReference"
                        @onclick="ShowAnchoredToast">
                    Copy invite link
                </button>
                <span class="toast-demo-inline-status">@(copyState ? "Copied" : "Idle")</span>
            </div>
        </DemoSection>

        <DemoSection Title="Custom Position"
                     Description="Move the shared viewport between bottom-end and top-center positions.">
            <div class="toast-demo-centered-panel">
                <div class="toast-demo-segmented" aria-label="Toast viewport position">
                    <button type="button"
                            class="@GetPositionButtonClass(ToastViewportPosition.BottomEnd)"
                            aria-pressed="@GetPressedState(ToastViewportPosition.BottomEnd)"
                            @onclick="@(() => SetViewportPosition(ToastViewportPosition.BottomEnd))">
                        Bottom end
                    </button>
                    <button type="button"
                            class="@GetPositionButtonClass(ToastViewportPosition.TopCenter)"
                            aria-pressed="@GetPressedState(ToastViewportPosition.TopCenter)"
                            @onclick="@(() => SetViewportPosition(ToastViewportPosition.TopCenter))">
                        Top center
                    </button>
                </div>
                <button type="button"
                        class="demo-button demo-button--primary"
                        data-demo-toast-trigger="position"
                        @onclick="ShowPositionToast">
                    Create positioned toast
                </button>
            </div>
        </DemoSection>

        <DemoSection Title="Undo Action"
                     Description="Render ToastAction content from action props and close the toast after the undo callback.">
            <div class="toast-demo-centered-panel">
                <button type="button"
                        class="demo-button demo-button--primary"
                        data-demo-toast-trigger="undo"
                        @onclick="ShowUndoToast">
                    Archive document
                </button>
                <span class="toast-demo-inline-status">Undo actions @undoCount</span>
            </div>
        </DemoSection>

        <DemoSection Title="Promise"
                     Description="Bind a loading toast to an asynchronous operation, then update it on success or error.">
            <div class="toast-demo-centered-panel">
                <div class="toast-demo-trigger-row">
                    <button type="button"
                            class="demo-button demo-button--primary"
                            data-demo-toast-trigger="promise-success"
                            @onclick="ShowPromiseSuccessAsync">
                        Resolve request
                    </button>
                    <button type="button"
                            class="demo-button"
                            data-demo-toast-trigger="promise-error"
                            @onclick="ShowPromiseErrorAsync">
                        Reject request
                    </button>
                </div>
                <span class="toast-demo-inline-status">Promise runs @promiseRunCount</span>
            </div>
        </DemoSection>

        <DemoSection Title="Custom Data"
                     Description="Attach typed payload data to a toast and render domain-specific metadata in the content.">
            <div class="toast-demo-centered-panel">
                <button type="button"
                        class="demo-button demo-button--primary"
                        data-demo-toast-trigger="custom-data"
                        @onclick="ShowCustomDataToast">
                    Queue incident toast
                </button>
            </div>
        </DemoSection>

        <DemoSection Title="Deduplicated Toast"
                     Description="Use a stable id to upsert the same toast and verify update state without duplicating notifications.">
            <div class="toast-demo-centered-panel">
                <button type="button"
                        class="demo-button demo-button--primary"
                        data-demo-toast-trigger="dedupe"
                        @onclick="ShowDeduplicatedToast">
                    Sync again
                </button>
                <span class="toast-demo-inline-status">Updates @dedupeCount</span>
            </div>
        </DemoSection>

        <DemoSection Title="Varying Heights"
                     Description="Create compact and multiline toasts to verify measured height, stacking offsets, and expansion.">
            <div class="toast-demo-centered-panel">
                <div class="toast-demo-trigger-row">
                    <button type="button"
                            class="demo-button demo-button--primary"
                            data-demo-toast-trigger="short-height"
                            @onclick="ShowCompactToast">
                        Compact
                    </button>
                    <button type="button"
                            class="demo-button"
                            data-demo-toast-trigger="tall-height"
                            @onclick="ShowTallToast">
                        Multiline
                    </button>
                </div>
            </div>
        </DemoSection>

        <DemoSection Title="Live Testing"
                     Description="Create long-lived focus and swipe candidates for manual keyboard, close, action, timer, and swipe checks.">
            <div class="toast-demo-centered-panel">
                <div class="toast-demo-trigger-row">
                    <button type="button"
                            class="demo-button demo-button--primary"
                            data-demo-toast-trigger="focus"
                            @onclick="ShowFocusToast">
                        Focus candidate
                    </button>
                    <button type="button"
                            class="demo-button"
                            data-demo-toast-trigger="swipe"
                            @onclick="ShowSwipeToast">
                        Swipe candidate
                    </button>
                    <button type="button"
                            class="demo-button"
                            data-demo-toast-trigger="close-all"
                            @onclick="CloseAllToasts">
                        Close all
                    </button>
                </div>
            </div>
        </DemoSection>

        <ToastPortal>
            <ToastViewport class="@StackedViewportClass">
                @foreach (var item in stacked.Toasts)
                {
                    <ToastRoot @key="item.Id"
                               Toast="item"
                               SwipeDirection="StackedSwipeDirections"
                               class="@GetStackedRootClass(item)">
                        <ToastContent class="toast-demo-content">
                            <span class="toast-demo-status-mark" aria-hidden="true"></span>
                            <div class="toast-demo-copy">
                                <ToastTitle class="toast-demo-title" />
                                <ToastDescription class="toast-demo-description" />
                                @if (item.Data is ToastDemoIncident incident)
                                {
                                    <dl class="toast-demo-data-grid">
                                        <div>
                                            <dt>Owner</dt>
                                            <dd>@incident.Owner</dd>
                                        </div>
                                        <div>
                                            <dt>Queue</dt>
                                            <dd>@incident.Queue</dd>
                                        </div>
                                        <div>
                                            <dt>SLA</dt>
                                            <dd>@incident.Sla</dd>
                                        </div>
                                    </dl>
                                }
                                @if (item.UpdateKey > 0)
                                {
                                    <span class="toast-demo-update-pill">Update @item.UpdateKey</span>
                                }
                            </div>
                            <div class="toast-demo-command-column">
                                <ToastAction class="toast-demo-action" />
                                <ToastClose class="toast-demo-close">Close</ToastClose>
                            </div>
                        </ToastContent>
                    </ToastRoot>
                }
            </ToastViewport>
        </ToastPortal>

        <ToastProvider ToastManager="anchoredToastManager" Timeout="1800" Limit="3" Context="anchored">
            <ToastPortal>
                <ToastViewport class="toast-demo-anchored-viewport">
                    @foreach (var item in anchored.Toasts)
                    {
                        <ToastPositioner @key="item.Id" Toast="item" class="toast-demo-positioner">
                            <ToastRoot @key="item.Id" Toast="item" class="@GetAnchoredRootClass(item)">
                                <ToastArrow class="toast-demo-arrow" />
                                <ToastContent class="toast-demo-anchored-content">
                                    <ToastDescription class="toast-demo-description" />
                                </ToastContent>
                            </ToastRoot>
                        </ToastPositioner>
                    }
                </ToastViewport>
            </ToastPortal>
        </ToastProvider>
    </ComponentShowcase>
</ToastProvider>

@code {
    private const string DeduplicatedToastId = "toast-demo-deduplicated";

    private readonly ToastManager stackedToastManager = new();
    private readonly ToastManager anchoredToastManager = new();
    private readonly IReadOnlyList<ToastSwipeDirection> bottomSwipeDirections =
        [ToastSwipeDirection.Down, ToastSwipeDirection.Right];
    private readonly IReadOnlyList<ToastSwipeDirection> topSwipeDirections =
        [ToastSwipeDirection.Up];

    private ElementReference copyButtonReference;
    private ToastViewportPosition viewportPosition = ToastViewportPosition.BottomEnd;
    private int createdCount;
    private int closedCount;
    private int removedCount;
    private int undoCount;
    private int promiseRunCount;
    private int dedupeCount;
    private int incidentCount;
    private bool copyState;

    private string StackedViewportClass => viewportPosition == ToastViewportPosition.TopCenter
        ? "toast-demo-viewport toast-demo-viewport--top-center"
        : "toast-demo-viewport toast-demo-viewport--bottom-end";

    private IReadOnlyList<ToastSwipeDirection> StackedSwipeDirections =>
        viewportPosition == ToastViewportPosition.TopCenter ? topSwipeDirections : bottomSwipeDirections;

    [Parameter]
    public bool IsWasmMode { get; set; }

    private void ShowBasicToast()
    {
        createdCount++;
        stackedToastManager.Add(new ToastManagerAddOptions
        {
            Title = "Message sent",
            Type = "success",
            Description = $"Delivery confirmed for item {createdCount}.",
            OnCloseCallback = EventCallback.Factory.Create(this, HandleToastClosed),
            OnRemoveCallback = EventCallback.Factory.Create(this, HandleToastRemoved)
        });
    }

    private void ShowPriorityToast()
    {
        createdCount++;
        stackedToastManager.Add(new ToastManagerAddOptions
        {
            Title = "Policy attention required",
            Type = "warning",
            Description = "This high-priority toast is announced assertively while the visual toast remains focusable.",
            Priority = ToastPriority.High,
            Timeout = 7000,
            OnCloseCallback = EventCallback.Factory.Create(this, HandleToastClosed),
            OnRemoveCallback = EventCallback.Factory.Create(this, HandleToastRemoved)
        });
    }

    private void ShowAnchoredToast()
    {
        copyState = true;
        anchoredToastManager.Add(new ToastManagerAddOptions
        {
            Type = "success",
            Description = "Invite link copied",
            Timeout = 1800,
            PositionerProps = new ToastPositionerOptions
            {
                Anchor = copyButtonReference,
                Side = Side.Top,
                Align = Align.Center,
                SideOffset = 10,
                CollisionPadding = 12
            },
            OnCloseCallback = EventCallback.Factory.Create(this, () => copyState = false),
            OnRemoveCallback = EventCallback.Factory.Create(this, () => copyState = false)
        });
    }

    private void SetViewportPosition(ToastViewportPosition position)
    {
        viewportPosition = position;
    }

    private void ShowPositionToast()
    {
        var label = viewportPosition == ToastViewportPosition.TopCenter ? "top center" : "bottom end";
        stackedToastManager.Add(new ToastManagerAddOptions
        {
            Title = "Viewport updated",
            Type = "info",
            Description = $"The next stack renders from {label}.",
            Timeout = 4500
        });
    }

    private void ShowUndoToast()
    {
        var id = $"toast-demo-undo-{Guid.NewGuid():N}";
        stackedToastManager.Add(new ToastManagerAddOptions
        {
            Id = id,
            Title = "Document archived",
            Type = "neutral",
            Description = "The document moved to archive.",
            Timeout = 8000,
            ActionProps = new ToastActionOptions
            {
                ChildContent = TextFragment("Undo"),
                OnClick = EventCallback.Factory.Create<MouseEventArgs>(this, _ => UndoArchive(id))
            }
        });
    }

    private async Task ShowPromiseSuccessAsync()
    {
        promiseRunCount++;
        await stackedToastManager.Promise(
            SimulateSuccessfulRequestAsync(promiseRunCount),
            new ToastManagerPromiseOptions<string>
            {
                Loading = new ToastManagerUpdateOptions
                {
                    Title = "Saving changes",
                    HasTitle = true,
                    Description = "Waiting for the server response.",
                    HasDescription = true,
                    Timeout = 0,
                    HasTimeout = true
                },
                Success = ToastPromiseOption<string>.From(result => new ToastManagerUpdateOptions
                {
                    Title = "Changes saved",
                    HasTitle = true,
                    Description = result,
                    HasDescription = true,
                    Type = "success",
                    HasType = true,
                    Timeout = 4200,
                    HasTimeout = true
                }),
                Error = ToastPromiseOption<Exception>.From(error => new ToastManagerUpdateOptions
                {
                    Title = "Save failed",
                    HasTitle = true,
                    Description = error.Message,
                    HasDescription = true,
                    Type = "error",
                    HasType = true,
                    Timeout = 6500,
                    HasTimeout = true
                })
            });
    }

    private async Task ShowPromiseErrorAsync()
    {
        promiseRunCount++;
        try
        {
            await stackedToastManager.Promise(
                SimulateFailedRequestAsync(),
                new ToastManagerPromiseOptions<string>
                {
                    Loading = new ToastManagerUpdateOptions
                    {
                        Title = "Uploading asset",
                        HasTitle = true,
                        Description = "The upload toast will resolve through the error branch.",
                        HasDescription = true,
                        Timeout = 0,
                        HasTimeout = true
                    },
                    Success = ToastPromiseOption<string>.From(result => new ToastManagerUpdateOptions
                    {
                        Title = "Upload complete",
                        HasTitle = true,
                        Description = result,
                        HasDescription = true,
                        Type = "success",
                        HasType = true,
                        Timeout = 4200,
                        HasTimeout = true
                    }),
                    Error = ToastPromiseOption<Exception>.From(error => new ToastManagerUpdateOptions
                    {
                        Title = "Upload failed",
                        HasTitle = true,
                        Description = error.Message,
                        HasDescription = true,
                        Type = "error",
                        HasType = true,
                        Timeout = 6500,
                        HasTimeout = true
                    })
                });
        }
        catch (InvalidOperationException)
        {
        }
    }

    private void ShowCustomDataToast()
    {
        incidentCount++;
        stackedToastManager.Add(new ToastManagerAddOptions
        {
            Title = "Incident assigned",
            Type = "info",
            Description = $"Incident INC-{2400 + incidentCount} is ready for triage.",
            Data = new ToastDemoIncident("Avery Stone", "Payments", "18 min"),
            Timeout = 7000
        });
    }

    private void ShowDeduplicatedToast()
    {
        dedupeCount++;
        stackedToastManager.Add(new ToastManagerAddOptions
        {
            Id = DeduplicatedToastId,
            Title = "Sync in progress",
            Type = "info",
            Description = $"The sync request has been refreshed {dedupeCount} time{(dedupeCount == 1 ? string.Empty : "s")}.",
            Timeout = 6500
        });
    }

    private void ShowCompactToast()
    {
        stackedToastManager.Add(new ToastManagerAddOptions
        {
            Title = "Compact toast",
            Type = "success",
            Description = "Short content.",
            Timeout = 5000
        });
    }

    private void ShowTallToast()
    {
        stackedToastManager.Add(new ToastManagerAddOptions
        {
            Title = "Multiline toast",
            Type = "warning",
            Description = "This toast has enough content to exercise measured height, stack offset, and expansion behavior while remaining inside the same viewport.",
            Timeout = 8000
        });
    }

    private void ShowFocusToast()
    {
        stackedToastManager.Add(new ToastManagerAddOptions
        {
            Title = "Focus management target",
            Type = "info",
            Description = "Use the viewport hotkey and Escape handling against this long-lived toast.",
            Timeout = 0,
            Priority = ToastPriority.High,
            ActionProps = new ToastActionOptions
            {
                ChildContent = TextFragment("Acknowledge"),
                OnClick = EventCallback.Factory.Create<MouseEventArgs>(this, _ => stackedToastManager.Close())
            }
        });
    }

    private void ShowSwipeToast()
    {
        var id = $"toast-demo-swipe-{Guid.NewGuid():N}";
        stackedToastManager.Add(new ToastManagerAddOptions
        {
            Id = id,
            Title = "Swipe target",
            Type = "neutral",
            Description = "Swipe down or right to dismiss, or activate the ignored action button.",
            Timeout = 0,
            ActionProps = new ToastActionOptions
            {
                ChildContent = TextFragment("Ignore"),
                OnClick = EventCallback.Factory.Create<MouseEventArgs>(this, _ => stackedToastManager.Close(id)),
                AdditionalAttributes = new Dictionary<string, object>
                {
                    ["data-base-ui-swipe-ignore"] = true
                }
            }
        });
    }

    private void CloseAllToasts()
    {
        stackedToastManager.Close();
        anchoredToastManager.Close();
    }

    private void HandleToastClosed()
    {
        closedCount++;
    }

    private void HandleToastRemoved()
    {
        removedCount++;
    }

    private void UndoArchive(string id)
    {
        undoCount++;
        stackedToastManager.Close(id);
    }

    private string GetPositionButtonClass(ToastViewportPosition position) =>
        viewportPosition == position
            ? "toast-demo-segment toast-demo-segment--active"
            : "toast-demo-segment";

    private string GetPressedState(ToastViewportPosition position) =>
        viewportPosition == position ? "true" : "false";

    private string GetStackedRootClass(ToastObject toast)
    {
        var typeClass = string.IsNullOrWhiteSpace(toast.Type) ? "neutral" : toast.Type;
        return $"toast-demo-root toast-demo-root--{typeClass}";
    }

    private string GetAnchoredRootClass(ToastObject toast)
    {
        var typeClass = string.IsNullOrWhiteSpace(toast.Type) ? "neutral" : toast.Type;
        return $"toast-demo-anchored-root toast-demo-root--{typeClass}";
    }

    private static async Task<string> SimulateSuccessfulRequestAsync(int run)
    {
        await Task.Delay(900);
        return $"Request {run} completed successfully.";
    }

    private static async Task<string> SimulateFailedRequestAsync()
    {
        await Task.Delay(900);
        throw new InvalidOperationException("The simulated upload service rejected the asset.");
    }

    private static RenderFragment TextFragment(string value) => builder =>
    {
        builder.AddContent(0, value);
    };

    private sealed record ToastDemoIncident(string Owner, string Queue, string Sla);

    private enum ToastViewportPosition
    {
        BottomEnd,
        TopCenter
    }
}
